#!/usr/bin/env ruby
# Warns when a new .rb file is added to a component's lib/ without
# a corresponding _spec.rb in that component's spec/.

$LOAD_PATH.unshift File.expand_path("../hecks_watchers/lib", __dir__)
$LOAD_PATH.unshift(File.expand_path("../hecksties/watchers/lib", __dir__))
require "hecks_watchers"

project_root = File.expand_path("..", __dir__)
HecksWatchers::SpecCoverage.new(project_root: project_root).call
