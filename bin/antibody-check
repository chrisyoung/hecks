#!/usr/bin/env ruby
# antibody-check — fail when a commit or PR adds non-Bluebook code.
#
# Bluebook is the source of truth AND the thing that runs. The runtime
# dispatches bluebook directly — there is no compile-to-Ruby step and
# there are no generated artifacts. Bluebook is Turing complete and
# more readable than anything else in this repo.
#
# Therefore: every non-bluebook code file in this repo is a gap. Either
# the concept should be re-expressed as a bluebook that the runtime
# dispatches, or it's a thin shell wrapper gluing bluebook to the OS
# (acceptable, but still worth naming).
#
# This check compares the current branch to a base (default origin/main)
# and lists every file *added OR modified* whose extension (or shebang)
# marks it as code-that-should-be-bluebook. Touching any of them counts
# — editing existing Ruby/Rust/Python/shell is also a reaffirmation of
# the gap. If any are flagged without an exemption, exits 1 —
# pre-commit warns, CI blocks.
#
# Exemption:
#   Put "[antibody-exempt: <reason>]" in any commit message on the
#   branch. Common reasons: "thin shell wrapper", "external Python
#   dep (Modal/MLX)", "generator scaffolding pending <ref>". The
#   reason is captured in the hook output and on the PR.
#
# Flags:
#   --base <ref>   ref to diff against (default: origin/main)
#   --advisory     warn only, exit 0 even on failures (pre-commit use)
#   --staged       also scan currently staged additions (pre-commit use)

require "optparse"
require "open3"

# Extensions the antibody flags as should-be-bluebook:
#   - code: rb rs py sh js ts go html css
#   - config-as-data: yml yaml (→ .fixtures in Hecks)
# Not listed: .bluebook, .behaviors, .fixtures, .hecksagon, .world,
# .md, .toml, .json, .heki — source or artifacts outside the
# self-hosting path.
CODE_EXTS = %w[rb rs py sh js ts go html css yml yaml].freeze

# Map shebang keywords → logical extension, so extensionless binaries
# under bin/ get classified by their interpreter. Any shebang not in
# this map falls through as "not code" — e.g. `#!/usr/bin/env awk`
# is rare enough we don't mind it slipping.
SHEBANG_EXT = {
  "ruby"   => "rb",
  "python" => "py",
  "bash"   => "sh",
  "sh"     => "sh",
  "node"   => "js",
}.freeze

def shebang_ext(path)
  return nil unless File.file?(path) && File.readable?(path)
  first = File.open(path, &:readline) rescue nil
  return nil unless first&.start_with?("#!")
  SHEBANG_EXT.each { |k, v| return v if first.include?(k) }
  nil
end

def run(cmd)
  out, _, status = Open3.capture3(*cmd)
  [out.strip, status.success?]
end

# Allowed-signers file for SSH signature verification. Without this
# pointed at a valid file, `git log --format=%G?` returns N for every
# SSH-signed commit — git cannot verify without the key list, so the
# whole gate would silently reject correctly-signed commits.
#
# We pass it inline via `git -c gpg.ssh.allowedSignersFile=…` so the
# check works in CI without depending on a per-developer or workflow-
# level git config. The path is repo-relative to keep the file
# version-controlled and auditable alongside the gate it feeds.
ALLOWED_SIGNERS = File.expand_path("../.github/allowed_signers", __dir__).freeze

def git_log_with_signers(args)
  cmd = ["git", "-c", "gpg.ssh.allowedSignersFile=#{ALLOWED_SIGNERS}", "log"] + args
  out, _, status = Open3.capture3(*cmd)
  [out.strip, status.success?]
end

def touched_files(base_ref, include_staged)
  touched = []
  if base_ref
    out, ok = run(["git", "diff", "--name-only", "--diff-filter=AM",
                   "#{base_ref}...HEAD"])
    touched.concat(out.lines.map(&:strip).reject(&:empty?)) if ok
  end
  if include_staged
    out, ok = run(["git", "diff", "--cached", "--name-only", "--diff-filter=AM"])
    touched.concat(out.lines.map(&:strip).reject(&:empty?)) if ok
  end
  touched.uniq
end

def exempt_reasons(message_file)
  # Exemptions are PER COMMIT, not per branch. Each commit that
  # touches a flagged file must carry its own justification.
  # Scanning the branch range would let an old exemption marker
  # silently cover later commits — a major slip-through.
  #
  # commit-msg hook: git passes the message file path as $1, which
  #   we relay via --message-file. Read only that file.
  # CI / manual invocation: HEAD IS the commit being checked. Read
  #   HEAD's message only.
  #
  # Note: pre-commit has no access to the message at all (it runs
  # before the message stage), so pre-commit can only warn, never
  # block on exemptions.
  reasons = []
  text = nil
  if message_file && File.exist?(message_file)
    text = File.read(message_file)
  else
    out, ok = run(["git", "log", "-1", "--format=%B", "HEAD"])
    text = out if ok
  end
  return reasons unless text
  # Marker must anchor at start of line (leading whitespace allowed).
  # Prevents slip-through via inline prose like "add [antibody-exempt: X]
  # to your message" — that was silently treated as a valid exemption.
  text.scan(/^\s*\[antibody-exempt:\s*([^\]]+)\]/i).each { |m| reasons << m[0].strip }
  reasons
end

def filter_code_files(paths)
  paths.select do |p|
    ext = File.extname(p).delete_prefix(".").downcase
    next true if CODE_EXTS.include?(ext)
    # Extensionless binaries: classify by shebang.
    ext.empty? && !shebang_ext(p).nil?
  end
end

# i7: forbid new `Kernel.load` (or bare `load(...)`) calls against any of
# the five DSL extensions. Those five must be parsed, not executed.
# Returns the list of "path:lineno: source" triples that violate the
# rule, scanning ONLY the paths given (so we're looking at what this
# commit/branch touched, never existing code).
DSL_LOAD_PATTERN = /(?:Kernel\.)?load\s*[( ]\s*["'][^"']*\.(?:hecksagon|world|bluebook|behaviors|fixtures)["']/.freeze

def kernel_load_violations(paths)
  violations = []
  paths.each do |p|
    next unless File.file?(p) && File.readable?(p)
    ext = File.extname(p).delete_prefix(".").downcase
    next unless %w[rb rs py sh].include?(ext)
    File.foreach(p).with_index(1) do |line, ln|
      next unless line =~ DSL_LOAD_PATTERN
      # Whitelist spec/parity/*_test.rb — those intentionally exercise
      # the old Kernel.load path to prove the NEW loader matches it.
      next if p.start_with?("spec/parity/")
      # Whitelist the Loader itself — it owns the one allowed caller.
      next if p.end_with?("lib/hecksagon/loader.rb")
      violations << "#{p}:#{ln}: #{line.strip}"
    end
  end
  violations
end

options = { base: "origin/main", staged: false, message_file: nil,
            list_only: false, each_commit: false }
OptionParser.new do |o|
  o.on("--base REF")           { |v| options[:base] = v }
  o.on("--staged")             { options[:staged]   = true }
  o.on("--message-file PATH")  { |v| options[:message_file] = v }
  o.on("--list-only")          { options[:list_only] = true }
  o.on("--each-commit")        { options[:each_commit] = true }
end.parse!

# If the base ref doesn't resolve (e.g. shallow clone in CI), fall back
# to staged-only. Better to be advisory than to false-green.
_, base_ok = run(["git", "rev-parse", "--verify", options[:base]])
base_ref = base_ok ? options[:base] : nil

# --each-commit: walk every commit in base..HEAD and check each one
# in isolation. Each commit is responsible for files IT touches; its
# own message must carry the exemption. Used by CI to validate that
# multi-commit PRs don't lean on one commit to exempt another's work.
if options[:each_commit]
  unless base_ref
    warn "antibody: --each-commit needs a resolvable --base ref"
    exit 2
  end
  shas, ok = run(["git", "log", "--format=%H", "--reverse", "#{base_ref}..HEAD"])
  unless ok
    warn "antibody: could not list commits in #{base_ref}..HEAD"
    exit 2
  end
  any_fail = false
  shas.lines.map(&:strip).reject(&:empty?).each do |sha|
    files_out, fok = run(["git", "show", "--name-only", "--diff-filter=AM",
                          "--format=", sha])
    next unless fok
    files = files_out.lines.map(&:strip).reject(&:empty?)
    code  = filter_code_files(files)
    next if code.empty?
    msg_out, _ = run(["git", "log", "-1", "--format=%B", sha])
    reasons = msg_out.to_s
                     .scan(/^\s*\[antibody-exempt:\s*([^\]]+)\]/i)
                     .map { |m| m[0].strip }
    subject, = run(["git", "log", "-1", "--format=%s", sha])
    if reasons.any?
      # Exemption markers require a valid signature (SSH or GPG) on the
      # commit. Prevents the "Miette self-exempts" drift from earlier
      # in the Phase F arc : the rule is that only the operator can
      # authorise an exemption, enforced mechanically via `git verify-
      # commit`. Both SSH and GPG signatures validate here — git
      # handles both transparently.
      sig_status, = git_log_with_signers(["-1", "--format=%G?", sha])
      signed_ok = %w[G U E].include?(sig_status.to_s.strip)
      # G : good signature
      # U : good signature, untrusted key (still a real signature — CI
      #     may not have the operator's trust DB ; presence is the
      #     gate, trust is out of band)
      # E : expired signature — accept rather than silently fail CI
      #     on the day the key rolls over ; the audit trail still
      #     names the operator
      # N : no signature — reject
      # B : bad signature — reject
      # X / Y / R : edge cases — reject
      if signed_ok
        puts "✓ #{sha[0, 7]} #{subject.to_s.slice(0, 60)} — #{reasons.size} exemption(s) [signed: #{sig_status.strip}]"
      else
        puts "✗ #{sha[0, 7]} #{subject.to_s.slice(0, 60)} — #{reasons.size} exemption(s) but UNSIGNED"
        code.each { |p| puts "    #{p}" }
        puts "    exemption markers require a signed commit (git commit -S)"
        puts "    signature status: #{sig_status.strip.empty? ? 'N (none)' : sig_status.strip}"
        any_fail = true
      end
    else
      puts "✗ #{sha[0, 7]} #{subject.to_s.slice(0, 60)}"
      code.each { |p| puts "    #{p}" }
      puts "    no exemption in this commit's message"
      any_fail = true
    end
  end
  exit(any_fail ? 1 : 0)
end

# Scope split: --staged mode (commit-msg / pre-commit) checks ONLY
# files this commit contributes, so earlier commits' files stay the
# earlier commits' responsibility. Branch-diff mode (manual / CI on
# HEAD) checks the whole PR-against-base range.
touched =
  if options[:staged]
    touched_files(nil, true)
  else
    touched_files(base_ref, base_ref.nil?)
  end
code    = filter_code_files(touched)

# i7 rule: any new Kernel.load / load(...) targeting a DSL extension is
# a hard stop. No exemption — this is the "5/5 parsed, not executed"
# antibody moment; re-opening the hole is always a regression.
dsl_load_hits = kernel_load_violations(touched)
unless dsl_load_hits.empty?
  puts ""
  puts "✗ antibody: Kernel.load on DSL file(s) is forbidden"
  dsl_load_hits.each { |h| puts "    #{h}" }
  puts ""
  puts "  Route through Hecksagon::Loader.load / .load_world, or the"
  puts "  matching parser on the Rust side. DSLs are parsed, not executed."
  exit 1
end

if code.empty?
  puts "✓ antibody: no non-bluebook files touched"
  exit 0
end

puts ""
puts "⚠ antibody: #{code.size} non-bluebook file(s) touched"
code.each { |p| puts "    #{p}" }
puts ""
puts "  Hecks source vocabulary: .bluebook .hecksagon .fixtures"
puts "  .behaviors .world. Everything else is a gap."
puts ""

# --list-only: pre-commit uses this to surface the list without
# opining on exemptions (it can't see the message yet). Exit 0.
if options[:list_only]
  puts "  commit-msg hook will enforce — add [antibody-exempt: <reason>]"
  puts "  to the commit message for each file you're not fixing."
  exit 0
end

reasons = exempt_reasons(options[:message_file])

if reasons.any?
  puts "  Exempted by commit-message marker:"
  reasons.each { |r| puts "    [antibody-exempt: #{r}]" }
  puts ""
  puts "✓ antibody: exempted — gap named and searchable"
  exit 0
end

puts "  To proceed: add '[antibody-exempt: <reason>]' to this commit's"
puts "  message with a concrete per-change justification."
puts ""

exit 1
