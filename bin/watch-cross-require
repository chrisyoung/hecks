#!/usr/bin/env ruby
# Fails if any staged file has a require_relative that escapes its component.
# Cross-component loading must use bare `require`, not `require_relative`.

$LOAD_PATH.unshift File.expand_path("../hecks_watchers/lib", __dir__)
require "hecks_watchers"

project_root = File.expand_path("..", __dir__)
results = HecksWatchers::CrossRequire.new(project_root: project_root).call
exit(results.empty? ? 0 : 1)
