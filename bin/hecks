#!/usr/bin/env ruby

# Resolve HECKS_HOME from this script's real location (not symlink)
hecks_home = File.dirname(File.dirname(File.realpath(__FILE__)))
ENV["HECKS_HOME"] = hecks_home
$LOAD_PATH.unshift(File.join(hecks_home, "lib"))

ENV["BUNDLE_GEMFILE"] ||= File.join(hecks_home, "Gemfile")
require "bundler/setup" if File.exist?(ENV["BUNDLE_GEMFILE"])

require "hecks"
require "set"
require "hecks_cli/argv"

argv = Hecks::CLI::Argv.new

# Register commands from chapter Bluebooks — the source of truth
chapters = {
  "cli"        => "Commands",
  "ai"         => "Commands",
  "persist"    => "Commands",
  "extensions" => "Commands",
  "workshop"   => "Commands",
  "targets"    => "Commands",
}

chapters.each do |chapter, group_name|
  begin
    require "hecks/chapters/#{chapter}"
    mod_name = chapter == "ai" ? "AI" : chapter.split("_").map(&:capitalize).join
    mod = Hecks::Chapters.const_get(mod_name)
    domain = mod.definition
    argv.register_from_domain(domain, group: group_name, commands_only: true)
  rescue => e
    $stderr.puts "  [argv] skip chapter #{chapter}: #{e.message}" if ENV["HECKS_DEBUG"]
  end
end

# Also load bluebooks from current project's hecks/ dir (user domains)
hecks_dir = File.join(Dir.pwd, "hecks")
if File.directory?(hecks_dir)
  Dir[File.join(hecks_dir, "*.bluebook")].sort.each do |path|
    argv.register_from_bluebook(path)
  end
end

# Load CLI command handlers (just handler blocks, no registration)
lib_root = File.join(hecks_home, "lib")
Dir[File.join(lib_root, "**/commands/*.rb")].sort.each do |path|
  argv.load_handler_file(path)
end

argv.run(ARGV)
