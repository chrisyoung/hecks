#!/usr/bin/env ruby
# Warns when any staged .rb file exceeds 180 lines of code (headers excluded).
# The hard limit is 200 — this catches files approaching it.

$LOAD_PATH.unshift File.expand_path("../hecks_watchers/lib", __dir__)
require "hecks_watchers"

project_root = File.expand_path("..", __dir__)
results = HecksWatchers::FileSize.new(project_root: project_root).call
exit(results.empty? ? 0 : 0)
