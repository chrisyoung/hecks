#!/usr/bin/env ruby
# Checks which components have uncommitted changes and reminds
# the developer to update the relevant CHANGELOGs and READMEs.

COMPONENTS = %w[hecksties hecks_model hecks_domain hecks_runtime hecks_workshop hecks_cli hecks_persist hecks_on_rails].freeze

changed = `git diff --cached --name-only`.split("\n")
touched = COMPONENTS.select { |c| changed.any? { |f| f.start_with?("#{c}/lib/") } }

exit 0 if touched.empty?

warnings = []
touched.each do |component|
  changelog = "#{component}/CHANGELOG.md"
  readme = "#{component}/README.md"
  unless changed.include?(changelog)
    warnings << "  #{changelog} — not updated"
  end
end

unless warnings.empty?
  puts "\n⚠  Component changes detected without changelog updates:"
  warnings.each { |w| puts w }
  puts "  Consider updating before committing.\n\n"
end
