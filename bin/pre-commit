#!/bin/bash
#
# Pre-commit hook: runs rspec and fails if tests fail or take over 1 second.
#

output=$(bundle exec rspec --order defined 2>&1)
exit_code=$?

# Check for test failures
if [ $exit_code -ne 0 ]; then
  echo "COMMIT BLOCKED: Tests failed."
  echo "$output" | tail -5
  exit 1
fi

# Parse the time from rspec output (e.g., "Finished in 0.95 seconds")
duration=$(echo "$output" | grep "Finished in" | sed 's/Finished in \([0-9.]*\) seconds.*/\1/')

if [ -z "$duration" ]; then
  echo "WARNING: Could not parse test duration."
  exit 0
fi

# Compare: fail if over the limit (default: 1.5s, configurable via env var)
limit=${SPEC_RUN_LENGTH_IN_SECONDS:-1.5}
over_limit=$(echo "$duration > $limit" | bc -l)
if [ "$over_limit" = "1" ]; then
  examples=$(echo "$output" | grep "examples" | head -1)
  echo "COMMIT BLOCKED: Tests took ${duration}s (limit: ${limit}s)"
  echo "  $examples"
  echo ""
  echo "  Set SPEC_RUN_LENGTH_IN_SECONDS to adjust the limit"
  exit 1
fi

echo "Tests passed: ${duration}s"

# Cross-component require_relative check (blocks commit)
ruby bin/watch-cross-require 2>/dev/null
if [ $? -ne 0 ]; then
  exit 1
fi

# Advisory watchers (warn but don't block)
ruby bin/watch-file-size 2>/dev/null
ruby bin/check-docs 2>/dev/null
ruby bin/watch-spec-coverage 2>/dev/null
ruby bin/watch-autoloads 2>/dev/null
