#!/bin/bash
#
# Pre-commit hook: the Bluebook is the spec.
# Verifies all chapters load and validates their IR.
#

# Bluebook self-verification
output=$(bin/verify 2>&1)
exit_code=$?

if [ $exit_code -ne 0 ]; then
  echo "COMMIT BLOCKED: Bluebook verification failed."
  echo "$output"
  exit 1
fi

echo "Bluebook verified."

# Smoke test
smoke_output=$(ruby -Ilib examples/pizzas/pizzas.rb 2>&1)
smoke_exit=$?
if [ $smoke_exit -ne 0 ]; then
  echo "COMMIT BLOCKED: Smoke test failed."
  echo "$smoke_output" | tail -5
  exit 1
fi
echo "Smoke test passed."

# Run all watchers (cross-require blocks; others are advisory)
ruby -Ilib -I hecksties/watchers/lib -r hecks_watchers -e \
  'exit(HecksWatchers::PreCommit.new(project_root: Dir.pwd).call ? 0 : 1)'
