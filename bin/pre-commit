#!/bin/bash
#
# Pre-commit hook: validate + smoke test.
#

# Validate all projects
output=$(ruby -Ilib -e 'require "hecks"; require "hecks/validate"; result = Hecks::Validate.run(Dir.pwd); exit(result[:errors].any? ? 1 : 0)' 2>&1)
exit_code=$?

if [ $exit_code -ne 0 ]; then
  echo "COMMIT BLOCKED:"
  echo "$output"
  exit 1
fi

echo "Validated."

# Smoke test
smoke_output=$(ruby -Ilib examples/pizzas/pizzas.rb 2>&1)
smoke_exit=$?
if [ $smoke_exit -ne 0 ]; then
  echo "COMMIT BLOCKED: Smoke test failed."
  echo "$smoke_output" | tail -5
  exit 1
fi
echo "Smoke test passed."
