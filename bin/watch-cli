#!/usr/bin/env ruby
# Watches lib/hecks_cli/ for changes and reinstalls the gem automatically.
# Pure Ruby — works on macOS, Linux, and Windows. No dependencies.
#
# Usage: bin/watch-cli

Dir.chdir(File.expand_path("..", __dir__))

def snapshot
  Dir["lib/hecks_cli/**/*.rb"].each_with_object({}) do |f, h|
    h[f] = File.mtime(f).to_i
  end
end

def rebuild
  puts ""
  puts "==> Change detected, reinstalling gem..."
  Dir.glob("hecks-*.gem").each { |f| File.delete(f) }
  system("gem build hecks.gemspec --silent")
  gem_file = Dir["hecks-*.gem"].max_by { |f| File.mtime(f) }
  if gem_file && system("gem install #{gem_file} --no-document")
    puts "==> Installed #{gem_file}"
  else
    puts "==> Build failed"
  end
end

$stdout.sync = true

puts "Watching lib/hecks_cli/ for changes..."
puts "Press Ctrl-C to stop."

begin
  rebuild
rescue => e
  puts "==> Error during initial build: #{e.message}"
end
last = snapshot

loop do
  sleep 2
  begin
    current = snapshot
    if current != last
      rebuild
      last = snapshot
    end
  rescue => e
    puts "==> Error: #{e.message}"
  end
end
