#!/usr/bin/env ruby
# = bin/reinstall
#
# Uninstalls all existing Hecks gems, then rebuilds and installs
# everything from source in dependency order. Standalone — no CLI dependency.
#
#   bin/reinstall
#
require "date"
require "set"
require "rubygems"

root = File.expand_path("..", __dir__)

# --- Discover components (directories with gemspecs) ---

components = Dir[File.join(root, "*/")].filter_map do |dir|
  name = File.basename(dir)
  next if name == "examples" || name.start_with?(".")
  gemspec = File.join(dir, "#{name}.gemspec")
  name if File.exist?(gemspec)
end.sort

all_gems = components + ["hecks"]

# --- Uninstall old gems ---

puts "=== Uninstalling old Hecks gems ==="
all_gems.each do |name|
  installed = `gem list ^#{name}$ --no-versions`.strip
  next if installed.empty?

  system("gem uninstall #{name} --all --executables --force")
  puts "Removed #{name}"
end

# --- Bump CalVer version ---

version_file_path = File.join(root, ".hecks_version")
today = Date.today.strftime("%Y.%m.%d")
prev = File.exist?(version_file_path) ? File.read(version_file_path).strip : nil

build = if prev && prev.start_with?(today)
          prev.split(".").last.to_i + 1
        else
          1
        end

new_version = "#{today}.#{build}"
File.write(version_file_path, new_version)

version_rb = File.join(root, "hecksties", "lib", "hecks", "version.rb")
content = File.read(version_rb)
File.write(version_rb, content.gsub(/VERSION = ".*"/, "VERSION = \"#{new_version}\""))
puts "Version: #{new_version}"

# --- Topo-sort components by runtime dependencies ---

def topo_sort(names, root)
  set = names.to_set
  deps = {}
  names.each do |name|
    spec = Gem::Specification.load(File.join(root, name, "#{name}.gemspec"))
    deps[name] = spec ? spec.runtime_dependencies.map(&:name).select { |d| set.include?(d) } : []
  end
  sorted = []
  visited = {}
  visit = ->(n) do
    return if visited[n]
    visited[n] = true
    deps[n].each { |d| visit.call(d) }
    sorted << n
  end
  names.each { |n| visit.call(n) }
  sorted
end

# --- Build all gems ---

puts "\n=== Building gems ==="
gem_files = {}

components.each do |name|
  puts "Building #{name}..."
  Dir.chdir(File.join(root, name)) do
    unless system("gem build #{name}.gemspec")
      abort "Build failed for #{name}"
    end
    gem_file = Dir["#{name}-*.gem"].max_by { |f| File.mtime(f) }
    abort "No gem file produced for #{name}" unless gem_file
    gem_files[name] = File.expand_path(gem_file)
  end
end

puts "Building hecks meta-gem..."
Dir.chdir(root) do
  unless system("gem build hecks.gemspec")
    abort "Build failed for hecks"
  end
  gem_file = Dir["hecks-*.gem"].max_by { |f| File.mtime(f) }
  abort "No gem file produced for hecks" unless gem_file
  gem_files["hecks"] = File.expand_path(gem_file)
end

# --- Install in dependency order ---

puts "\n=== Installing in dependency order ==="
sorted = topo_sort(components, root)

sorted.each do |name|
  path = gem_files[name]
  unless system("gem install --local #{path}")
    abort "Install failed for #{name}"
  end
  File.delete(path)
  puts "Installed #{File.basename(path)}"
end

meta = gem_files["hecks"]
unless system("gem install --local #{meta}")
  abort "Install failed for hecks"
end
File.delete(meta)
puts "Installed #{File.basename(meta)}"

puts "\nDone. All Hecks gems reinstalled."
