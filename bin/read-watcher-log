#!/usr/bin/env ruby
# Reads and clears tmp/watcher.log so Claude Code sessions see watcher output.
# Called by the PostToolUse hook.

log_file = File.join(File.expand_path("..", __dir__), "tmp", "watcher.log")
exit 0 unless File.exist?(log_file)

content = File.read(log_file).strip
exit 0 if content.empty?

File.write(log_file, "")
puts content
