#!/usr/bin/env ruby
# Reads and clears tmp/watcher.log so Claude Code sessions see watcher output.
# Called by the PostToolUse hook.

$LOAD_PATH.unshift File.expand_path("../hecks_watchers/lib", __dir__)
require "hecks_watchers"

project_root = File.expand_path("..", __dir__)
HecksWatchers::LogReader.call(project_root)
