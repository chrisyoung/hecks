#!/usr/bin/env ruby
#
# Bluebook self-verification: discovers all projects and validates them.
# Same output as server boot. One system.
#
# Usage:
#   bin/verify                # validate everything
#   bin/verify --format json  # machine-readable
#

$LOAD_PATH.unshift(File.join(__dir__, "../lib"))

require "hecks"
require "hecks/validate"

format = ARGV.include?("--format") ? ARGV[ARGV.index("--format") + 1] : "text"

result = Hecks::Validate.run(Dir.pwd, format: format)
exit(result[:errors].any? ? 1 : 0)
