#!/usr/bin/env ruby
#
# Bluebook self-verification: the Bluebook IS the spec.
# Loads every chapter, validates its IR, reports issues.
#
# Usage:
#   bin/verify           # quiet — exits 0 or 1
#   bin/verify --verbose # prints each chapter summary
#

$LOAD_PATH.unshift(*Dir.glob(File.join(__dir__, "../*/lib")))
$LOAD_PATH.unshift(File.join(__dir__, "../hecks_targets/ruby/lib"))
$LOAD_PATH.unshift(File.join(__dir__, "../hecks_targets/go/lib"))
$LOAD_PATH.unshift(File.join(__dir__, "../hecks_targets/node/lib"))
$LOAD_PATH.unshift(File.join(__dir__, "../hecksties/watchers/lib"))
$LOAD_PATH.unshift(File.join(__dir__, "../examples/lib"))

require "hecks"
Kernel.load(File.join(__dir__, "../HecksBluebook"))
require "hecks/chapters/verify"

format = :progress
format = :documentation if ARGV.include?("--verbose") || ARGV.include?("-v")

if (idx = ARGV.index("--format"))
  format = ARGV[idx + 1]&.to_sym || :progress
end

Hecks::Chapters.verify(format: format)
