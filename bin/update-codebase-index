#!/usr/bin/env ruby
# Regenerates the codebase_index.md memory file by scanning lib/ for .rb files
# and producing a grouped, annotated index. Run automatically via SessionStart hook.

require "fileutils"

REPO = File.expand_path("..", __dir__)
INDEX = File.join(ENV["HOME"], ".claude/projects/-Users-christopheryoung-Projects-hecks/memory/codebase_index.md")

Dir.chdir(REPO)

files = Dir["lib/**/*.rb"].sort
spec_count = Dir["spec/**/*.rb"].size

groups = files.group_by { |f| File.dirname(f) }

lines = []
lines << "---"
lines << "name: codebase_index"
lines << "description: Complete file-by-file index of every .rb file in the hecks repo for fast navigation"
lines << "type: reference"
lines << "---"
lines << ""
lines << "## Summary"
lines << "- #{files.size} Ruby files in lib/"
lines << "- #{spec_count} spec files"
lines << "- Generated #{Time.now.strftime('%Y-%m-%d')}"
lines << ""

groups.each do |dir, dir_files|
  lines << "## #{dir}/"
  dir_files.each do |f|
    basename = File.basename(f)
    # Read first comment line for description
    desc = ""
    File.open(f) do |fh|
      fh.each_line do |line|
        if line.start_with?("#") && !line.start_with?("#!/") && line.strip.size > 2
          desc = line.sub(/^#\s*/, "").strip
          # Skip class/module name lines, get the description
          next if desc.match?(/\A\w+::/)
          break
        elsif !line.strip.empty? && !line.start_with?("#")
          break
        end
      end
    end
    desc = "" if desc.match?(/\A\w+::/) # still a class name, skip
    lines << "- #{basename}#{desc.empty? ? '' : " — #{desc}"}"
  end
  lines << ""
end

File.write(INDEX, lines.join("\n"))
