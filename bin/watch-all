#!/usr/bin/env ruby
# Polls every second for .rb file changes and runs all watchers.
# Started automatically when Claude Code opens the project.

$LOAD_PATH.unshift File.expand_path("../hecks_watchers/lib", __dir__)
$LOAD_PATH.unshift(File.expand_path("../hecksties/watchers/lib", __dir__))
require "hecks_watchers"

project_root = File.expand_path("..", __dir__)
$stdout.sync = true

runner = HecksWatchers::Runner.new(project_root: project_root)
runner.start
