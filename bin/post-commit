#!/bin/bash
#
# Post-commit hook: if watcher log has issues, run the watcher agent
# in the background to create a fix PR.
#

log_file="tmp/watcher.log"

if [ -f "$log_file" ] && [ -s "$log_file" ]; then
  echo ""
  echo "Watcher issues detected — launching fix agent in background..."
  ruby -I hecks_watcher_agent/lib -r hecks_watcher_agent -e \
    'HecksWatcherAgent::Agent.new(project_root: Dir.pwd).call' &
fi
