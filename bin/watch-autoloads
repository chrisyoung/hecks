#!/usr/bin/env ruby
# Warns when a new class/module file is added but not registered in autoloads.rb.

$LOAD_PATH.unshift File.expand_path("../hecks_watchers/lib", __dir__)
$LOAD_PATH.unshift(File.expand_path("../hecksties/watchers/lib", __dir__))
require "hecks_watchers"

project_root = File.expand_path("..", __dir__)
HecksWatchers::Autoloads.new(project_root: project_root).call
