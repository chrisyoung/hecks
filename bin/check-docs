#!/usr/bin/env ruby
# Pre-commit check: reminds about doc updates when lib/ files change.
# Checks FEATURES.md, component READMEs, and component CHANGELOGs.

COMPONENTS = %w[hecksties hecks_model hecks_domain hecks_runtime hecks_workbench hecks_cli hecks_persist hecks_on_rails].freeze

staged = `git diff --cached --name-only`.split("\n")
lib_changes = staged.select { |f| f.match?(%r{/lib/}) }
exit 0 if lib_changes.empty?

warnings = []

# Check FEATURES.md
unless staged.include?("FEATURES.md")
  new_files = `git diff --cached --diff-filter=A --name-only`.split("\n")
  if new_files.any? { |f| f.match?(%r{/lib/}) }
    warnings << "  FEATURES.md — new lib files added but FEATURES.md not updated"
  end
end

# Check component CHANGELOGs
COMPONENTS.each do |c|
  next unless lib_changes.any? { |f| f.start_with?("#{c}/") }
  unless staged.include?("#{c}/CHANGELOG.md")
    warnings << "  #{c}/CHANGELOG.md — lib changes without changelog entry"
  end
end

unless warnings.empty?
  puts "\n📝 Doc reminders:"
  warnings.each { |w| puts w }
  puts ""
end
