#!/usr/bin/env bash
set -e
trap 'echo "\nAborted."; exit 1' INT

echo "=== Updating doc headers ==="
claude -p "Update the doc headers in all lib/**/*.rb files to match current features. Don't change code, just the comment block at the top of each file." --allowedTools Read,Edit,Glob,Grep --verbose

echo ""
echo "=== Updating docs/active_hecks.md ==="
claude -p "Update docs/active_hecks.md to match the current codebase. Read the relevant source files and make sure the doc accurately reflects how things work now." --allowedTools Read,Edit,Glob,Grep --verbose

echo ""
echo "=== Updating docs/active_record.md ==="
claude -p "Update docs/active_record.md to match the current codebase. Read the relevant source files and make sure the doc accurately reflects how things work now." --allowedTools Read,Edit,Glob,Grep --verbose

echo ""
echo "=== Updating docs/ddd.md ==="
claude -p "Update docs/ddd.md to match the current codebase. Read the relevant source files and make sure the doc accurately reflects how things work now." --allowedTools Read,Edit,Glob,Grep --verbose

echo ""
echo "=== Updating docs/hexagonal.md ==="
claude -p "Update docs/hexagonal.md to match the current codebase. Read the relevant source files and make sure the doc accurately reflects how things work now." --allowedTools Read,Edit,Glob,Grep --verbose

echo ""
echo "=== Updating docs/why_hecks.md ==="
claude -p "Update docs/why_hecks.md to match the current codebase. Read the relevant source files and make sure the doc accurately reflects how things work now." --allowedTools Read,Edit,Glob,Grep --verbose

echo ""
echo "=== Docs updated ==="
