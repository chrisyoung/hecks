#!/usr/bin/env bash
set -e

echo "=== Updating doc headers ==="
claude -p "Update the doc headers in all lib/**/*.rb files to match current features. Don't change code, just the comment block at the top of each file." --allowedTools Read,Edit,Glob,Grep

for doc in docs/*.md; do
  name=$(basename "$doc")
  echo ""
  echo "=== Updating $name ==="
  claude -p "Update $doc to match the current codebase. Read the relevant source files and make sure the doc accurately reflects how things work now." --allowedTools Read,Edit,Glob,Grep
done

echo ""
echo "=== Docs updated ==="
