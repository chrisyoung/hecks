# HecksBluebook
#
# Hecks describes itself as a Bluebook. Each gem is a chapter — a domain
# defined using the same DSL that Hecks provides to its users.
#
# The chapter definitions live in each gem:
#   bluebook/lib/hecks/chapters/bluebook.rb
#   hecksties/lib/hecks/chapters/runtime.rb
#   hecks_workshop/lib/hecks/chapters/workshop.rb
#   hecksagon/lib/hecks/chapters/hecksagon.rb
#   hecks_targets/lib/hecks/chapters/targets.rb
#
# This file composes them and wires cross-chapter policies.

require_relative "bluebook/lib/hecks/chapters/bluebook"
require_relative "hecksties/lib/hecks/chapters/runtime"
require_relative "hecks_workshop/lib/hecks/chapters/workshop"
require_relative "hecksagon/lib/hecks/chapters/hecksagon"
require_relative "hecks_targets/lib/hecks/chapters/targets"

module Hecks
  module Chapters
    def self.bluebook
      @bluebook ||= DomainModel::Structure::BluebookStructure.new(
        name: "Hecks",
        chapters: [
          Bluebook.definition,
          Runtime.definition,
          Workshop.definition,
          Hecksagon.definition,
          Targets.definition,
        ]
      )
    end
  end
end
