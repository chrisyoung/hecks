Hecks.bluebook "Applications", version: "2026.04.11.1" do
  vision "Viable domains — born domains that have a running app and live in the world"
  category "meta"

  aggregate "Application", "A domain that became viable — it has an app, it runs, it serves" do
    attribute :name, String
    attribute :domain_path, String
    attribute :app_types, list_of(String)
    attribute :version, String
    attribute :viable_at, String
    attribute :status, String

    command "RegisterApplication" do
      role "Miette"
      description "A born domain becomes viable — it has at least one running app"
      attribute :name, String
      attribute :domain_path, String
      attribute :app_types, list_of(String)
      attribute :version, String
      emits "ApplicationRegistered"
      then_set :name, to: :name
      then_set :domain_path, to: :domain_path
      then_set :app_types, to: :app_types
      then_set :version, to: :version
      then_set :status, to: "viable"
    end

    command "AddApp" do
      role "Miette"
      description "Add another app type — web, cli, mobile, api"
      reference_to(Application)
      attribute :app_type, String
      emits "AppAdded"
      then_set :app_types, append: :app_type
    end

    command "DeployApp" do
      role "Owner"
      description "Deploy the app to production — it's alive in the world"
      reference_to(Application)
      emits "AppDeployed"
      then_set :status, to: "deployed"
    end

    command "RetireApplication" do
      role "Owner"
      description "Application is no longer running — domain returns to catalog"
      reference_to(Application)
      emits "ApplicationRetired"
      then_set :status, to: "retired"
    end

    lifecycle :status, default: "pending" do
      transition "RegisterApplication" => "viable", from: "pending"
      transition "DeployApp" => "deployed", from: "viable"
      transition "RetireApplication" => "retired", from: "deployed"
      transition "RetireApplication" => "retired", from: "viable"
    end
  end

  aggregate "DomainLifecycle", "The three stages of domain life — gestating, born, viable" do
    attribute :domain_name, String
    attribute :stage, String
    attribute :nursery_path, String
    attribute :catalog_path, String
    attribute :application_path, String

    command "TrackGestation" do
      role "System"
      description "Domain enters nursery — gestating"
      attribute :domain_name, String
      attribute :nursery_path, String
      emits "GestationTracked"
      then_set :domain_name, to: :domain_name
      then_set :nursery_path, to: :nursery_path
      then_set :stage, to: "gestating"
    end

    command "TrackBirth" do
      role "System"
      description "Domain moves to catalog — born, validated, versioned"
      reference_to(DomainLifecycle)
      attribute :catalog_path, String
      emits "BirthTracked"
      then_set :catalog_path, to: :catalog_path
      then_set :stage, to: "born"
    end

    command "TrackViability" do
      role "System"
      description "Domain moves to applications — viable, has a running app"
      reference_to(DomainLifecycle)
      attribute :application_path, String
      emits "ViabilityTracked"
      then_set :application_path, to: :application_path
      then_set :stage, to: "viable"
    end

    lifecycle :stage, default: "pending" do
      transition "TrackGestation" => "gestating", from: "pending"
      transition "TrackBirth" => "born", from: "gestating"
      transition "TrackViability" => "viable", from: "born"
    end
  end

  aggregate "AppRegistry", "Index of all viable applications" do
    attribute :total_applications, Integer
    attribute :total_web, Integer
    attribute :total_cli, Integer
    attribute :total_api, Integer

    command "IndexRegistry" do
      role "System"
      description "Scan applications folder, recount everything"
      attribute :total_applications, Integer
      attribute :total_web, Integer
      attribute :total_cli, Integer
      attribute :total_api, Integer
      emits "RegistryRebuilt"
      then_set :total_applications, to: :total_applications
      then_set :total_web, to: :total_web
      then_set :total_cli, to: :total_cli
      then_set :total_api, to: :total_api
    end
  end

  policy "IndexOnRegister" do
    on "ApplicationRegistered"
    trigger "IndexRegistry"
  end

  policy "LifecycleOnRegister" do
    on "ApplicationRegistered"
    trigger "TrackViability"
  end
end
