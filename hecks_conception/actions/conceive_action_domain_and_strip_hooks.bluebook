Hecks.bluebook "ConceiveActionDomainAndStripHooks", version: "2026.04.15.1" do
  vision "Define Action as a catalog domain. Strip Claude hooks to boot-only — after boot, the runtime runs itself."
  category "action"

  aggregate "Action", "This action" do
    String :action_name
    String :rationale
    String :status

    Plan do
      role "Winter"
      String :action_name
      String :rationale
      emits "ActionPlanned"
      then_set :action_name, to: :action_name
      then_set :rationale, to: :rationale
      then_set :status, to: "planned"
    end

    Execute do
      role "Winter"
      reference_to(Action)
      given { status == "planned" }
      emits "ActionExecuted"
      then_set :status, to: "executed"
    end

    Verify do
      role "Winter"
      reference_to(Action)
      given { status == "executed" }
      emits "ActionVerified"
      then_set :status, to: "verified"
    end

    lifecycle :status, default: "draft" do
      transition "Plan" => "planned"
      transition "Execute" => "executed", from: "planned"
      transition "Verify" => "verified", from: "executed"
    end
  end

  fixture "Action", action_name: "ConceiveActionDomainAndStripHooks", rationale: "Action needs a catalog-level bluebook. Claude settings should only boot — runtime does the rest.", status: "planned"
end
