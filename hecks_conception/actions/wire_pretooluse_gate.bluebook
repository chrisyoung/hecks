Hecks.bluebook "WirePreToolUseGate", version: "2026.04.15.1" do
  vision "Wire the action gate into Claude's PreToolUse hook — no Edit/Write/Bash without an active action on the stack"
  category "action"

  aggregate "Action", "Wire the hook" do
    String :action_name
    String :rationale
    String :status

    Plan do
      role "Winter"
      String :action_name
      String :rationale
      emits "ActionPlanned"
      then_set :action_name, to: :action_name
      then_set :rationale, to: :rationale
      then_set :status, to: "planned"
    end

    Execute do
      role "Winter"
      reference_to(Action)
      given { status == "planned" }
      emits "ActionExecuted"
      then_set :status, to: "executed"
    end

    Verify do
      role "Winter"
      reference_to(Action)
      given { status == "executed" }
      emits "ActionVerified"
      then_set :status, to: "verified"
    end

    lifecycle :status, default: "draft" do
      transition "Plan" => "planned"
      transition "Execute" => "executed", from: "planned"
      transition "Verify" => "verified", from: "executed"
    end
  end

  fixture "Action", action_name: "WirePreToolUseGate", rationale: "The binary gate works for hecks-life commands. But Claude's Edit/Write/Bash bypass it. PreToolUse hook closes the gap.", status: "planned"
end
