Hecks.bluebook "session_2026_04_10_070619", version: "2026.04.15.1" do
  vision "Auto-generated session action — the primordial action created by the bootloader"
  category "session"

  aggregate "Session", "This session" do
    attribute :session_id, String
    attribute :engine, String
    attribute :started_at, String
    attribute :status, String

    command "Start" do
      role "Bootloader"
      emits "SessionStarted"
      then_set :session_id, to: "session_2026_04_10_070619"
      then_set :engine, to: "claude"
      then_set :status, to: "active"
    end

    lifecycle :status, default: "pending" do
      transition "Start" => "active"
    end
  end

  fixture "Session", session_id: "session_2026_04_10_070619", engine: "claude", started_at: "2026_04_10_070619", status: "active"
end
