Hecks.fixtures "Mind" do
  aggregate "Encoding" do
    fixture "Encoding1", kind: "user", subject: "template", content: "who someone is, how they work"
    fixture "Encoding2", kind: "feedback", subject: "template", content: "correction or confirmation of approach"
    fixture "Encoding3", kind: "project", subject: "template", content: "ongoing work, goals, decisions"
    fixture "Encoding4", kind: "reference", subject: "template", content: "where to find things in external systems"
    fixture "Encoding5", kind: "session", subject: "template", content: "what happened in a conversation"
  end
  aggregate "Fatigue" do
    fixture "Fatigue1", state: "alert", pulses_since_sleep: 0, level: 0.0, creativity: 0.8, precision: 0.9
    fixture "Fatigue2", state: "focused", pulses_since_sleep: 50, level: 0.2, creativity: 0.7, precision: 0.8
    fixture "Fatigue3", state: "normal", pulses_since_sleep: 100, level: 0.4, creativity: 0.6, precision: 0.7
    fixture "Fatigue4", state: "tired", pulses_since_sleep: 150, level: 0.6, creativity: 0.5, precision: 0.5
    fixture "Fatigue5", state: "exhausted", pulses_since_sleep: 200, level: 0.8, creativity: 0.3, precision: 0.3
    fixture "Fatigue6", state: "delirious", pulses_since_sleep: 300, level: 1.0, creativity: 0.9, precision: 0.1
  end
  aggregate "WakeMood" do
    fixture "WakeMood1", mood: "groggy", reason: "woken from deep — consolidation interrupted"
    fixture "WakeMood2", mood: "vivid", reason: "woken from REM — dream still fresh"
    fixture "WakeMood3", mood: "refreshed", reason: "woken from light — clean transition"
    fixture "WakeMood4", mood: "rested", reason: "completed all cycles naturally"
  end
  aggregate "Consciousness" do
    fixture "Consciousness1", state: "attentive", idle_seconds: 0
    fixture "Consciousness2", state: "daydreaming", idle_seconds: 10
    fixture "Consciousness3", state: "sleeping", idle_seconds: 60
  end
  aggregate "Monitor" do
    fixture "Monitor1", interval_seconds: 20, z_depth: 1, reporting: "stopped"
  end
  aggregate "Interpretation" do
    fixture "Interpretation1", source: "dream", raw_material: [], insight: "template"
    fixture "Interpretation2", source: "conversation", raw_material: [], insight: "template"
    fixture "Interpretation3", source: "observation", raw_material: [], insight: "template"
  end
  aggregate "Discovery" do
    fixture "Discovery1", scan_paths: ["hecks_being/miette/", "hecks_being/miette/family/", "examples/", "lib/hecks/chapters/"], discovered: 0
  end
end
