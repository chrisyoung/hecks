Hecks.bluebook "Appeal", version: "2026.04.11.1" do
  vision "Browser-based IDE for domain modeling"
  category "framework"

  aggregate "Project" do
  description "A domain project workspace. Loads, creates, and manages domain directories."
  String :name
  String :path
  String :status

  OpenProject do
    description "Load an existing domain from a directory"
    String :path
    emits "ProjectOpened"
  end

  CreateProject do
    description "Initialize a new domain with a name"
    String :name
    String :path
    emits "ProjectCreated"
  end

  CloseProject do
    description "Close the current project and release resources"
    emits "ProjectClosed"
  end

  DiscoverProjects do
    description "Scan a directory for hecks apps -- looks for hecks/*.bluebook"
    String :search_path
    emits "ProjectsDiscovered"
  end

  LoadProjects do
    description "Discover and open all projects in a directory"
    String :search_path
    emits "ProjectsLoaded"
  end

  validation :name, presence: true
  validation :path, presence: true
end

  aggregate "Explorer" do
  description "Browse and inspect parsed domain structure -- aggregates, commands, references."
  String :domain_name
  list_of(ExplorerEntry) :aggregate_names
  String :last_opened_path
  String :last_opened_domain

  value_object "ExplorerEntry" do
    description "A named item in the domain structure"
    String :name
    String :kind
  end

  reference_to(Project)

  LoadDomain do
    description "Parse the project domain and populate the explorer tree"
    reference_to(Project)
    emits "DomainLoaded"
  end

  InspectAggregate do
    description "Show details of an aggregate"
    String :aggregate_name
    emits "AggregateInspected"
  end

  InspectCommand do
    description "Show details of a command"
    String :aggregate_name
    String :command_name
    emits "CommandInspected"
  end

  OpenFile do
    description "Open a file from the project tree and record it as the last opened"
    reference_to(Project)
    String :path
    String :domain
    emits "FileOpened"
  end

  GetLastOpened do
    description "Return the last opened file path and domain"
    emits "LastOpenedReturned"
  end

  ExportBluebook do
    description "Export the current domain as a .bluebook file"
    String :format
    emits "BluebookExported"
  end

  query "ByKind" do |kind|
    where(kind: kind)
  end
end

  aggregate "Document" do
  description "A source file open for editing. Tracks content, parse state, and dirty status."
  String :filename
  String :content
  String :dirty
  list_of(Diagnostic) :diagnostics

  value_object "Diagnostic" do
    description "A validation finding at a source location"
    Integer :line
    Integer :column
    String :severity
    String :message
  end

  reference_to(Project)

  OpenDocument do
    description "Load a .hec file into the editor"
    reference_to(Project)
    String :filename
    emits "DocumentOpened"
  end

  EditDocument do
    description "Apply a text change to the document"
    String :content
    emits "DocumentEdited"
  end

  SaveDocument do
    description "Persist the document back to disk"
    emits "DocumentSaved"
  end

  ValidateDocument do
    description "Parse and validate the document, producing diagnostics"
    emits "DocumentValidated"
  end

  validation :filename, presence: true
end

  aggregate "Timeline" do
  description "Edit history with undo/redo. Tracks document changes as a linear sequence."
  list_of(TimelineEntry) :entries
  Integer :cursor

  value_object "TimelineEntry" do
    description "A recorded change with before/after content"
    String :action
    String :detail
    String :timestamp
  end

  reference_to(Document)

  RecordChange do
    description "Append a change to the timeline"
    reference_to(Document)
    String :action
    String :detail
  end

  Undo do
    description "Move the cursor back one step and revert the change"
    end

  Redo do
    description "Move the cursor forward and reapply the change"
    end
end

  aggregate "Generator" do
  description "Build domain code for a target language. Preview output, diff against existing."
  String :target
  String :status
  String :output_path
  list_of(Artifact) :artifacts

  value_object "Artifact" do
    description "A generated file with its content and diff status"
    String :filename
    String :content
    String :changed
  end

  reference_to(Project)

  SelectTarget do
    description "Choose a build target -- ruby, go, rails, sinatra"
    reference_to(Project)
    String :target
  end

  BuildTarget do
    description "Generate all code for the selected target"
    end

  PreviewArtifact do
    description "Show the content of a single generated file"
    String :filename
  end

  CompareArtifact do
    description "Compare generated output against existing file on disk"
    String :filename
  end

  validation :target, presence: true
end

  aggregate "Pattern" do
  description "Reusable domain pattern library -- CRUD, event-sourced, saga, process manager."
  String :name
  String :category
  String :template
  list_of(PatternParameter) :parameters

  value_object "PatternParameter" do
    description "A configurable parameter when applying a pattern"
    String :name
    String :param_type
    String :default_value
    String :required
  end

  CreatePattern do
    description "Define a new reusable pattern from an existing aggregate shape"
    String :name
    String :category
    String :template
  end

  ApplyPattern do
    description "Scaffold an aggregate by applying a pattern with parameters"
    reference_to(Project)
    String :pattern_name
    String :aggregate_name
    String :parameters
  end

  ListPatterns do
    description "Show all available patterns, optionally filtered by category"
    String :category
  end

  validation :name, presence: true
end

  aggregate "Feature" do
  description "A feature to build. Decomposes into domain additions tracked against the live IR."
  String :title
  String :description
  String :status
  list_of(DomainAddition) :additions
  Integer :total_additions
  Integer :completed_additions

  value_object "DomainAddition" do
    description "A planned domain change — aggregate, command, event, attribute, or policy"
    String :kind
    String :name
    String :parent
    String :description
    String :exists_in_domain
  end

  CreateFeature do
    description "Define a new feature with a title and description"
    String :title
    String :description
    emits "FeatureCreated"
  end

  PlanFeature do
    description "Ask the AI agent to plan all domain additions for this feature"
    emits "FeaturePlanned"
  end

  AddDomainAddition do
    description "Manually add a planned domain change to the feature"
    String :kind
    String :name
    String :parent
    String :description
    emits "DomainAdditionAdded"
  end

  VerifyAdditions do
    description "Check the live domain IR for each planned addition"
    emits "AdditionsVerified"
  end

  BuildFeature do
    description "Ask the AI agent to implement all remaining additions"
    emits "FeatureBuildStarted"
  end

  CompleteFeature do
    description "Mark the feature as done — all additions verified"
    emits "FeatureCompleted"
  end

  lifecycle :status, default: "draft" do
    transition "PlanFeature" => "planned", from: "draft"
    transition "BuildFeature" => "building", from: "planned"
    transition "VerifyAdditions" => "planned", from: "building"
    transition "CompleteFeature" => "done", from: "planned"
  end

  validation :title, presence: true
end

  aggregate "Backlog" do
  description "Ordered collection of features. Tracks progress."
  String :name
  list_of(BacklogEntry) :features

  value_object "BacklogEntry" do
    description "A feature in the backlog with its position"
    String :feature_title
    Integer :position
    String :status
  end

  AddToBacklog do
    description "Add a feature to the backlog"
    String :feature_title
    emits "AddedToBacklog"
  end

  Prioritize do
    description "Reorder a feature within the backlog"
    String :feature_title
    Integer :position
    emits "Reprioritized"
  end

  TrackProgress do
    description "Recalculate completion across all features"
    emits "ProgressTracked"
  end

  validation :name, presence: true
end

  aggregate "ProductExecutor" do
  description "Eight-agent product team: plan, build domain, build app, UX, UI, product owner, scrum master, event storming"
  String :active_agent
  list_of(AgentConversation) :conversations

  value_object "AgentConversation" do
    description "A named agent's chat history"
    String :agent_name
    list_of(String) :messages
  end

  SendToAgent do
    description "Send a message to a named agent"
    String :agent_name
    String :content
    emits "AgentMessageSent"
  end

  SwitchAgent do
    description "Switch the active agent tab"
    String :agent_name
    emits "AgentSwitched"
  end

  ClearAgent do
    description "Clear an agent's conversation"
    String :agent_name
    emits "AgentCleared"
  end
end

  aggregate "FeatureFlag" do
  description "Runtime toggle for shipped features. Enabled on ship, removed on acceptance."
  String :feature_title
  String :enabled
  String :permanent

  CreateFlag do
    description "Create a feature flag when a feature ships"
    String :feature_title
    emits "FlagCreated"
  end

  ToggleFlag do
    description "Enable or disable a feature flag at runtime"
    emits "FlagToggled"
  end

  RemoveFlag do
    description "Remove the flag — feature becomes permanent"
    emits "FlagRemoved"
  end
end

  aggregate "Review" do
  description "Domain change review workflow -- propose changes, discuss, approve or reject."
  String :title
  String :status
  String :author
  String :changes_summary
  list_of(ReviewComment) :comments

  value_object "ReviewComment" do
    description "A comment on a proposed domain change"
    String :author
    String :body
    String :element_name
    String :timestamp
  end

  ProposeChange do
    description "Open a review for a set of domain changes"
    String :title
    String :author
    String :changes_summary
  end

  AddComment do
    description "Comment on the proposed changes"
    String :author
    String :body
    String :element_name
  end

  ApproveReview do
    description "Approve the proposed domain changes"
    String :author
  end

  RejectReview do
    description "Reject the proposed changes with a reason"
    String :author
    String :reason
  end

  validation :title, presence: true
end

  aggregate "Annotation" do
  description "Comments and notes attached to specific domain elements."
  String :element_type
  String :element_name
  String :body
  String :resolved
  list_of(Reply) :replies

  value_object "Reply" do
    description "A threaded reply to an annotation"
    String :author
    String :body
    String :timestamp
  end

  Annotate do
    description "Attach a comment to a domain element"
    String :element_type
    String :element_name
    String :body
  end

  ResolveAnnotation do
    description "Mark an annotation as resolved"
    end

  ReplyToAnnotation do
    description "Add a threaded reply to an existing annotation"
    String :author
    String :body
  end

  query "Unresolved" do
    where(resolved: "false")
  end
end

  aggregate "Agent" do
  description "AI assistant for domain modeling. Ask questions, get suggestions, apply changes."
  String :adapter_mode
  String :thinking
  list_of(Message) :messages
  list_of(Suggestion) :suggestions
  String :loaded_domain

  value_object "Message" do
    description "A conversation message -- user or assistant"
    String :role
    String :content
    String :timestamp
  end

  value_object "Suggestion" do
    description "A proposed domain change with rationale and diff preview"
    String :title
    String :rationale
    String :diff_preview
    String :status
  end

  SendMessage do
    description "Send a message to the AI assistant about the domain"
    String :content
    emits "MessageReceived"
  end

  ToggleAdapter do
    description "Switch between memory and live LLM adapter"
    String :mode
    emits "AdapterChanged"
  end

  ClearConversation do
    description "Reset the conversation history"
    emits "ConversationCleared"
  end

  ApplySuggestion do
    description "Accept and apply a suggested domain change"
    String :title
    emits "SuggestionApplied"
  end

  RequestReview do
    description "Ask the AI to review the current domain"
    emits "ReviewRequested"
  end

  LoadDomainContext do
    description "Set which domain the agent introspects for tools and system prompt"
    String :domain_name
    emits "DomainContextLoaded"
  end

  lifecycle :adapter_mode, default: "memory" do
    transition "ToggleAdapter" => "live", from: "memory"
    transition "ToggleAdapter" => "memory", from: "live"
  end

  lifecycle :thinking, default: "idle" do
    transition "SendMessage" => "thinking", from: "idle"
    transition "ReceiveResponse" => "idle", from: "thinking"
  end
end

  aggregate "Insight" do
  description "Domain health analysis -- coupling metrics, design smells, completeness checks."
  list_of(Finding) :findings
  Integer :score

  value_object "Finding" do
    description "A single analysis finding with severity and recommendation"
    String :rule
    String :severity
    String :element_name
    String :message
    String :recommendation
  end

  AnalyzeDomain do
    description "Run all analysis rules against the current domain"
    String :scope
  end

  DismissInsight do
    description "Acknowledge and hide a specific finding"
    String :rule
    String :element_name
  end

  ConfigureRules do
    description "Enable or disable specific analysis rules"
    String :rule
    String :enabled
  end
end

  aggregate "Migration" do
  description "Breaking change detection and migration path generation."
  String :from_version
  String :to_version
  String :status
  list_of(DomainChange) :changes

  value_object "DomainChange" do
    description "A detected change -- added, removed, renamed, or modified element"
    String :kind
    String :element_type
    String :element_name
    String :detail
  end

  DetectChanges do
    description "Compare current bluebook against a previous version"
    String :from_version
  end

  GenerateMigration do
    description "Produce a migration script for the detected changes"
    end

  ApplyMigration do
    description "Execute the migration against a target environment"
    end
end

  aggregate "Comparison" do
  description "Side-by-side diff of two domain versions."
  String :left_version
  String :right_version
  list_of(Difference) :differences

  value_object "Difference" do
    description "A single difference between two domain versions"
    String :element_type
    String :element_name
    String :change_kind
    String :left_value
    String :right_value
    String :breaking
  end

  CompareVersions do
    description "Diff two versions of the domain"
    String :left_version
    String :right_version
  end

  HighlightBreaking do
    description "Filter the comparison to show only breaking changes"
    end
end

policy "ShowDiagramOnTabSelect" do
  on "TabSelected"
  trigger "GenerateDiagram"
  condition do |event|
    data = event.respond_to?(:to_h) ? event.to_h : (event.respond_to?(:data) ? event.data : event)
    tab = data.is_a?(Hash) ? (data[:active_tab] || data["active_tab"]) : nil
    tab == "diagrams"
  end
end

  aggregate "Diagram" do
  description "Generated domain visualizations -- aggregate maps, event flows, command graphs."
  String :view_type
  list_of(DiagramNode) :nodes
  list_of(DiagramEdge) :edges

  value_object "DiagramNode" do
    description "An element in the diagram -- aggregate, command, event, or value object"
    String :name
    String :kind
    String :metadata
  end

  value_object "DiagramEdge" do
    description "A relationship between two nodes"
    String :from_node
    String :to_node
    String :relationship
  end

  GenerateDiagram do
    description "Build a diagram for a file. Uses Explorer.last_opened_path when path is not provided."
    String :view_type
    String :path
    String :domain
    emits "DiagramGenerated"
  end

  GenerateOverview do
    description "Build a cross-domain relationship diagram showing all domains and their connections"
    String :scope
    emits "OverviewGenerated"
  end

  SelectView do
    description "Switch between aggregate map, event flow, or command graph"
    String :view_type
    emits "ViewSelected"
  end

  FilterByAggregate do
    description "Show only nodes related to a specific aggregate"
    String :aggregate_name
    emits "DiagramFiltered"
  end

  RunAnalysis do
    description "Analyze domain patterns — coupling, cohesion, naming issues"
    emits "AnalysisCompleted"
  end
end

  aggregate "EventStorm" do
  description "Interactive event storming session. Stickies represent domain concepts."
  String :name
  String :status
  list_of(Sticky) :stickies

  value_object "Sticky" do
    description "A virtual sticky note -- event, command, policy, hotspot, or external system"
    String :label
    String :kind
    String :color
    Integer :position_x
    Integer :position_y
    String :notes
  end

  StartStorm do
    description "Begin a new event storming session"
    String :name
  end

  AddSticky do
    description "Place a new sticky note on the board"
    String :label
    String :kind
  end

  MoveSticky do
    description "Reposition a sticky on the board"
    String :label
    Integer :position_x
    Integer :position_y
  end

  ConvertToDomain do
    description "Transform stickies into Bluebook DSL aggregates, commands, and events"
    end

  validation :name, presence: true
end

  aggregate "Glossary" do
  description "Ubiquitous language dictionary. Defines terms, enforces naming consistency."
  list_of(Term) :terms

  value_object "Term" do
    description "A domain term with its definition and category"
    String :name
    String :definition
    String :category
    String :aliases
  end

  ShowGlossary do
    description "Display the full glossary of domain terms"
    emits "GlossaryShown"
  end

  DefineTerm do
    description "Add a new term to the glossary"
    String :name
    String :definition
    String :category
  end

  RenameTerm do
    description "Rename a term and update all references"
    String :old_name
    String :new_name
  end

  FlagAmbiguity do
    description "Mark a term as ambiguous -- needs clarification"
    String :term_name
    String :reason
  end

  LinkTerms do
    description "Declare a relationship between two terms"
    String :from_term
    String :to_term
    String :relationship
  end
end

  aggregate "Console" do
  description "Interactive command runner GUI. Select aggregate and command, fill form, execute."
  String :selected_aggregate
  String :selected_command
  String :status
  String :last_result
  list_of(ConsoleEvent) :event_log
  list_of(FormField) :form

  value_object "FormField" do
    description "A generated input field from a command attribute"
    String :name
    String :field_type
    String :required
    String :input_value
    String :error
  end

  value_object "ConsoleEvent" do
    description "An event recorded from command execution in the console"
    String :event_name
    String :payload
    String :timestamp
  end

  OpenConsole do
    description "Open the console -- loads available aggregates and commands"
    emits "ConsoleOpened"
  end

  SelectCommand do
    description "Pick an aggregate and command -- generates the input form"
    String :aggregate_name
    String :command_name
    emits "CommandSelected"
  end

  SubmitForm do
    description "Execute the selected command with the filled form values"
    String :values
    emits "CommandExecuted"
  end

  ViewResult do
    description "Display the result of the last command execution"
    emits "ResultViewed"
  end
end

  aggregate "AcceptanceTest" do
  description "Automated test runner. Dispatches every domain command and validates the event log."
  String :status
  list_of(TestResult) :results
  Integer :passed
  Integer :failed
  Integer :total

  value_object "TestResult" do
    description "Result of a single command dispatch test"
    String :command_name
    String :aggregate_name
    String :status
    String :event_name
    String :error
  end

  RunAll do
    description "Dispatch every command and validate events are emitted"
    emits "AllTestsCompleted"
  end

  RunCommand do
    description "Test a single command dispatch"
    String :aggregate_name
    String :command_name
    emits "CommandTested"
  end

  Reset do
    description "Clear all test results"
    emits "TestsReset"
  end

  lifecycle :status, default: "idle" do
    transition "RunAll" => "running", from: "idle"
    transition "AllTestsCompleted" => "idle", from: "running"
    transition "Reset" => "idle"
  end
end

  aggregate "EventStream" do
  description "Live event feed. Subscribes to domain events and streams them to the UI."
  String :status
  list_of(StreamEvent) :events
  String :filter_aggregate
  String :filter_event_type

  value_object "StreamEvent" do
    description "A domain event captured from any running aggregate"
    String :event_name
    String :aggregate_name
    String :aggregate_id
    String :payload
    String :timestamp
    String :source_command
    String :source_policy
  end

  SubscribeToEvents do
    description "Start streaming events from a project's domains"
    emits "EventsSubscribed"
  end

  StopStreaming do
    description "Stop streaming events"
    emits "StreamingStopped"
  end

  PauseStream do
    description "Temporarily pause the event stream without disconnecting"
    emits "StreamPaused"
  end

  ResumeStream do
    description "Resume a paused event stream"
    emits "StreamResumed"
  end

  ClearEvents do
    description "Remove all events from the stream display"
    emits "EventsCleared"
  end

  FilterEvents do
    description "Filter the stream by aggregate name or event type"
    String :aggregate_name
    String :event_type
    emits "EventsFiltered"
  end

  InspectEvent do
    description "Expand an event row to show its full payload data"
    String :event_name
    String :timestamp
    emits "EventInspected"
  end
end

  aggregate "Scenario" do
  description "Executable given/when/then specification. Tests domain commands without implementation."
  String :name
  String :status
  list_of(Step) :steps
  String :result

  value_object "Step" do
    description "A single step in a scenario -- given, when, or then"
    String :phase
    String :aggregate_name
    String :command_name
    String :attributes
    String :expectation
  end

  CreateScenario do
    description "Define a new scenario with a name"
    String :name
  end

  AddStep do
    description "Append a given/when/then step to the scenario"
    String :phase
    String :aggregate_name
    String :command_name
    String :attributes
  end

  RunScenario do
    description "Execute all steps and record pass/fail"
    end

  RecordResult do
    description "Store the outcome of a scenario run"
    String :result
  end

  validation :name, presence: true
end

  aggregate "Fixture" do
  description "Reusable data set for populating scenarios with known state."
  String :name
  list_of(FixtureEntry) :entries

  value_object "FixtureEntry" do
    description "A single data record -- aggregate name, attribute values"
    String :aggregate_name
    String :attributes
  end

  CreateFixture do
    description "Define a new fixture set"
    String :name
  end

  AddEntry do
    description "Add a data record to the fixture"
    String :aggregate_name
    String :attributes
  end

  ApplyToScenario do
    description "Load this fixture as the given state for a scenario"
    reference_to(Scenario)
  end

  validation :name, presence: true
end

  aggregate "Playground" do
  description "Interactive sandbox for running domain commands and inspecting state."
  list_of(PlaygroundEvent) :events
  String :state_snapshot

  value_object "PlaygroundEvent" do
    description "A recorded event from command execution"
    String :name
    String :payload
    String :timestamp
  end

  ExecuteCommand do
    description "Run a domain command in the sandbox"
    String :aggregate_name
    String :command_name
    String :attributes
  end

  InspectState do
    description "View current aggregate state in the sandbox"
    String :aggregate_name
  end

  ResetPlayground do
    description "Clear all sandbox state and events"
    end

  query "RecentEvents" do
    where(timestamp: "recent")
  end
end

  aggregate "Workbench" do
  description "Live domain interaction. Select a project, execute commands, inspect state."
  String :active_project
  String :active_aggregate

  ShowWorkbench do
    description "Open the workbench REPL for this domain"
    emits "WorkbenchShown"
  end

  SelectProject do
    description "Set the active project for command dispatch"
    String :project_name
    emits "ProjectSelected"
  end

  SelectAggregate do
    description "Set the active aggregate for inspection"
    String :aggregate_name
    emits "AggregateSelected"
  end

  ExecuteCommand do
    description "Dispatch a command against the active project's runtime"
    String :command_name
    String :args
    emits "CommandExecuted"
  end

  InspectRepository do
    description "List all records in an aggregate's repository"
    String :aggregate_name
    emits "RepositoryInspected"
  end

  FindRecord do
    description "Find a single record by ID"
    String :aggregate_name
    String :record_id
    emits "RecordFound"
  end

  ShowEventHistory do
    description "Show all events for the active project"
    emits "EventHistoryShown"
  end
end

  aggregate "Session" do
  description "IDE session with sketch/play modes and WebSocket connection state."
  String :mode
  String :connection_status

  EnterSketch do
    description "Switch to sketch mode for editing domain structure"
    emits "SketchEntered"
  end

  EnterPlay do
    description "Switch to play mode for executing domain commands"
    emits "PlayEntered"
  end

  Connect do
    description "Establish WebSocket connection to the IDE server"
    emits "Connected"
  end

  Disconnect do
    description "Close the WebSocket connection"
    emits "Disconnected"
  end

  RestoreConnection do
    description "Drop and re-establish the WebSocket connection"
    emits "ConnectionRestored"
  end
end

  aggregate "Layout" do
  description "IDE panel and tab state. Tracks which panels are open, active tabs, sizes, and arrangement."
  list_of(PanelState) :panels
  String :active_tab
  String :sidebar_collapsed
  String :events_panel_collapsed

  value_object "PanelState" do
    description "State of a single IDE panel -- name, visibility, dimensions"
    String :name
    String :open
    Integer :width
    Integer :height
    String :position
  end


  OpenPanel do
    description "Show a hidden panel"
    String :panel_name
    emits "PanelOpened"
  end

  ClosePanel do
    description "Hide a panel"
    String :panel_name
    emits "PanelClosed"
  end

  SelectTab do
    description "Switch the active tab in the main area"
    String :tab_name
    emits "TabSelected"
  end

  ResizePanel do
    description "Change a panel's dimensions"
    String :panel_name
    Integer :width
    Integer :height
    emits "PanelResized"
  end

  ToggleSidebar do
    description "Collapse or expand the sidebar"
    emits "SidebarToggled"
  end

  ToggleEventsPanel do
    description "Collapse or expand the bottom events panel"
    emits "EventsPanelToggled"
  end

  HideProjects do
    description "Hide the projects sidebar panel"
    emits "ProjectsHidden"
  end

  ShowProjects do
    description "Show the projects sidebar panel"
    emits "ProjectsShown"
  end

end

  aggregate "LayoutState" do
  description "Persisted layout preferences — current file, saved panel arrangement."
  String :current_file
  String :current_domain

  TrackCurrentFile do
    description "Record the currently open file and domain for context"
    String :path
    String :domain
    emits "CurrentFileTracked"
  end

  SaveState do
    description "Persist the current layout state to disk"
    emits "StateSaved"
  end

  RestoreState do
    description "Load persisted layout state from disk"
    emits "StateRestored"
  end
end

  aggregate "Menu" do
  description "IDE menu bar with File, View, and Domain menus."
  String :open_menu
  list_of(MenuItem) :items

  value_object "MenuItem" do
    description "A single menu entry -- label, action, keyboard shortcut, enabled state"
    String :label
    String :action
    String :shortcut
    String :enabled
    String :separator
  end

  OpenMenu do
    description "Open a menu dropdown -- File, View, or Domain"
    String :menu_name
    emits "MenuOpened"
  end

  CloseMenu do
    description "Close any open menu dropdown"
    emits "MenuClosed"
  end

  SelectMenuItem do
    description "Execute a menu item action"
    String :menu_name
    String :action
    emits "MenuItemSelected"
  end
end

  aggregate "KeyboardShortcut" do
  description "Keyboard shortcut binding. Maps key combinations to domain commands."
  String :key
  String :modifiers
  String :command_aggregate
  String :command_name

  BindShortcut do
    description "Register a keyboard shortcut for a command"
    String :key
    String :modifiers
    String :command_aggregate
    String :command_name
    emits "ShortcutBound"
  end

  TriggerShortcut do
    description "Fire the command associated with a key combination"
    String :key
    String :modifiers
    emits "ShortcutTriggered"
  end
end

  aggregate "Notification" do
  description "Feedback messages -- errors, warnings, success confirmations, progress updates."
  String :severity
  String :message
  String :context
  String :dismissed

  Notify do
    description "Create a notification for the user"
    String :severity
    String :message
    String :context
    emits "Notified"
  end

  DismissNotification do
    description "Mark a notification as seen"
    emits "NotificationDismissed"
  end

  query "Active" do
    where(dismissed: "false")
  end
end

  aggregate "Screenshot" do
  description "Rolling buffer of browser screenshots for visual debugging."
  Integer :buffer_size
  Integer :capture_interval
  String :status

  CaptureScreen do
    description "Save a screenshot frame from the browser"
    String :frame_data
    String :timestamp
    emits "ScreenshotCaptured"
  end

  PauseCapture do
    description "Stop capturing screenshots"
    emits "CapturePaused"
  end

  ResumeCapture do
    description "Resume capturing screenshots"
    emits "CaptureResumed"
  end
end

  aggregate "Search" do
  description "Full-text search across domains, aggregates, commands, and attributes."
  String :query_text
  list_of(SearchResult) :results
  Integer :result_count

  value_object "SearchResult" do
    description "A single search match with context"
    String :element_type
    String :element_name
    String :domain_name
    String :context
    Integer :relevance
  end

  SearchDomain do
    description "Search across all domain elements for a query string"
    String :query_text
    emits "SearchCompleted"
  end

  ClearSearch do
    description "Reset search results"
    emits "SearchCleared"
  end

  FilterSearchResults do
    description "Narrow results by element type"
    String :element_type
    emits "SearchResultsFiltered"
  end
end

policy "SwitchToEditorOnFileOpen" do
  on "FileOpened"
  trigger "SelectTab"
  defaults tab: "editor"
end

end
