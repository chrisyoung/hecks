Hecks.behaviors "Mind" do
  vision "Behavioral tests for the Mind domain — exercises every command and query in memory"

  # ── Attention aggregate ──────────────────────────────────────────

  test "AttendTo sets target + intensity" do
    tests "AttendTo", on: "Attention"
    input  target: "sample", intensity: 1.0
    expect target: "sample", intensity: 1.0
  end

  test "AttendTo cascades through policy chain" do
    tests "AttendTo", on: "Attention", kind: :cascade
    setup  "FormIntention", goal: "sample", origin: "sample", strength: 1.0
    setup  "Observe", observing: "sample"
    setup  "UpdateSelfModel", organs: 1, impulses: 1, fatigue_state: "sample", consciousness_state: "sample", nursery_size: 1, family_size: 1
    input  target: "sample", intensity: 1.0
    expect emits: ["AttentionDirected", "IntentionFormed", "Observed", "SelfModelUpdated"]
  end

  test "ReleaseAttention runs" do
    tests "ReleaseAttention", on: "Attention"
    setup  "AttendTo", target: "sample", intensity: 1.0
    expect intensity: 0
  end


  # ── Sensation aggregate ──────────────────────────────────────────

  test "Sense sets source + content + valence" do
    tests "Sense", on: "Sensation"
    input  source: "sample", content: "sample", valence: 1.0
    expect source: "sample", content: "sample", valence: 1.0
  end

  test "Sense cascades through policy chain" do
    tests "Sense", on: "Sensation", kind: :cascade
    setup  "Recognize", sensation: "sample", recognized_as: "sample", confidence: 1.0
    setup  "AttendTo", target: "sample", intensity: 1.0
    setup  "FormIntention", goal: "sample", origin: "sample", strength: 1.0
    setup  "Observe", observing: "sample"
    setup  "UpdateSelfModel", organs: 1, impulses: 1, fatigue_state: "sample", consciousness_state: "sample", nursery_size: 1, family_size: 1
    input  source: "sample", content: "sample", valence: 1.0
    expect emits: ["Sensed", "Recognized", "AttentionDirected", "IntentionFormed", "Observed", "SelfModelUpdated"]
  end


