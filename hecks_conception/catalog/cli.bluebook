    end
  end

  aggregate "DocsCommand", definition: "Serve domain as executable docs in browser" do

    command "Serve" do
      attribute :bluebook, String
    end
  end

  aggregate "ArchitectureCommand", definition: "Show hexagonal architecture diagram" do

    command "Show" do
    end
  end

  aggregate "CoverageCommand", definition: "Show missing domain concepts in app code" do

    command "Check" do
    end
  end

