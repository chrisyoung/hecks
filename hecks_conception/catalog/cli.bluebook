Hecks.bluebook "Cli", version: "2026.04.11.1" do
  category "framework"
  aggregate "CLI", definition: "Thor-based command-line interface entry point" do

    command "Start" do
      attribute :argv, String
    end
  end

  aggregate "InitCommand", definition: "Scaffolds a new Hecks domain project" do

    command "Init" do
      attribute :project_name, String
    end
  end

  aggregate "BuildCommand", definition: "Compiles domain DSL into Ruby classes" do

    command "Build" do
      attribute :target, String
    end
  end

  aggregate "ValidateCommand", definition: "Lints a domain definition for errors" do

    command "Validate" do
      attribute :domain_path, String
    end
  end

  aggregate "ListCommand", definition: "Lists aggregates and commands in a domain" do

    command "List" do
      attribute :domain_path, String
    end
  end

  aggregate "InspectCommand", definition: "Displays detailed domain structure" do

    command "Inspect" do
      attribute :domain_path, String
    end
  end

  aggregate "TreeCommand", definition: "Renders domain as ASCII tree" do

    command "Tree" do
      attribute :domain_path, String
    end
  end

  aggregate "DiffCommand", definition: "Shows diff between domain versions" do

    command "Diff" do
      attribute :from_version, String
      attribute :to_version, String
    end
  end

  aggregate "DumpCommand", definition: "Exports domain in various formats" do

    command "Dump" do
      attribute :format, String
    end
  end

  aggregate "GemCommand", definition: "Packages domain as a Ruby gem" do

    command "Package" do
      attribute :domain_path, String
    end
  end

  aggregate "ImportCommand", definition: "Imports Rails models into domain DSL" do

    command "Import" do
      attribute :source_path, String
    end
  end

  aggregate "InterviewCommand", definition: "Runs interactive domain wizard" do

    command "Interview" do
      attribute :domain_name, String
    end
  end

  aggregate "VersionCommand", definition: "Shows framework version" do

    command "Show" do
      attribute :format, String
    end
  end

  aggregate "VersionTagCommand", definition: "Tags a domain version snapshot" do

    command "Tag" do
      attribute :version, String
    end
  end

  aggregate "VersionLogCommand", definition: "Lists domain version history" do

    command "Log" do
      attribute :domain_path, String
    end
  end

  aggregate "VisualizeCommand", definition: "Generates domain diagrams" do

    command "Visualize" do
      attribute :format, String
    end
  end

  aggregate "ContextMapCommand", definition: "Generates context map for multi-domain" do

    command "Generate" do
      attribute :domain_path, String
    end
  end

  aggregate "GlossaryCommand", definition: "Outputs ubiquitous language glossary" do

    command "Generate" do
      attribute :domain_path, String
    end
  end

  aggregate "LlmsCommand", definition: "Generates LLM context file" do

    command "Generate" do
      attribute :domain_path, String
    end
  end

  aggregate "ExtractCommand", definition: "Extracts aggregate to new domain" do

    command "Extract" do
      attribute :aggregate_name, String
    end
  end

  aggregate "GenerateStubCommand", definition: "Generates test stubs for domain" do

    command "Generate" do
      attribute :domain_path, String
    end
  end

  aggregate "GenerateSinatraCommand", definition: "Generates Sinatra app from domain" do

    command "Generate" do
      attribute :domain_path, String
    end
  end

  aggregate "GenerateConfigCommand", definition: "Generates configuration files" do

    command "Generate" do
      attribute :domain_path, String
    end
  end

  aggregate "InfoCommand", definition: "Shows domain metadata and stats" do

    command "Show" do
      attribute :domain_path, String
    end
  end

  aggregate "CompileCommand", definition: "Compiles Hecks into a self-contained binary" do

    command "Compile" do
      attribute :output, String
    end
  end

  aggregate "ClaudeCommand", definition: "Starts file watchers and launches Claude Code" do

    command "Launch" do
      attribute :args, String
    end
  end

  aggregate "AppealCommand", definition: "Launches the HecksAppeal IDE server" do

    command "Launch" do
      attribute :path, String
    end
  end

  aggregate "NewProjectCommand", definition: "Scaffolds a new Hecks domain project" do

    command "Create" do
      attribute :project_name, String
    end
  end

  aggregate "SelfDiffCommand", definition: "Compares generated code against actual gem code" do

    command "Diff" do
      attribute :chapter, String
      attribute :framework, String
    end
  end

  aggregate "VerifyCommand", definition: "Runs Bluebook self-verification" do

    command "Verify" do
      attribute :format, String
    end
  end

  aggregate "SmoketestCommand", definition: "Runs all example domain tests" do

    command "Run" do
      attribute :format, String
    end
  end

  aggregate "AllureCommand", definition: "Terminal UI — domain concepts as panels" do

    command "Launch" do
