    RunRule do
      String :domain_id
    end
  end

  aggregate "ValidationMessage", definition: "Structured validation result with severity and context" do

    CreateMessage do
      String :message
      String :severity
    end
  end

  aggregate "CommandNaming", definition: "Validates command names follow verb-noun convention" do

    CheckCommandNaming do
      String :domain_id
    end
  end

  aggregate "UniqueAggregateNames", definition: "Validates no duplicate aggregate names in domain" do

    CheckUniqueNames do
      String :domain_id
    end
  end

  aggregate "SafeIdentifierNames", definition: "Validates names are safe Ruby/Go identifiers" do

    CheckIdentifiers do
      String :domain_id
    end
  end

  aggregate "ReservedNames", definition: "Validates names do not clash with language reserved words" do

    CheckReservedNames do
      String :domain_id
    end
  end

  aggregate "NameCollisions", definition: "Detects naming collisions between aggregates and value objects" do

    CheckNameCollisions do
      String :domain_id
    end
  end

  aggregate "ComputedNameCollisions", definition: "Detects collisions between computed and declared attributes" do

    CheckComputedCollisions do
      String :domain_id
    end
  end

  aggregate "GlossaryTermViolations", definition: "Enforces ubiquitous language glossary term usage" do

    CheckGlossaryTerms do
      String :domain_id
    end
  end

  aggregate "AggregatesHaveCommands", definition: "Validates every aggregate has at least one command" do

    CheckAggregateCommands do
      String :domain_id
    end
  end

  aggregate "CommandsHaveAttributes", definition: "Validates commands declare at least one attribute" do

    CheckCommandAttributes do
      String :domain_id
    end
  end

  aggregate "SingleAttributeAggregate", definition: "Warns when aggregate has only one attribute" do

    CheckSingleAttribute do
      String :domain_id
    end
  end

  aggregate "TooManyCommands", definition: "Warns when aggregate has excessive commands" do

    CheckCommandCount do
      String :domain_id
    end
  end

  aggregate "ValidPolicyEvents", definition: "Validates policy event references exist in domain" do

    CheckPolicyEvents do
      String :domain_id
    end
  end

  aggregate "ValidPolicyTriggers", definition: "Validates policy trigger commands exist in domain" do

    CheckPolicyTriggers do
      String :domain_id
    end
  end

  aggregate "NoPiiInIdentity", definition: "Warns against PII fields used as identity attributes" do

    CheckPiiIdentity do
      String :domain_id
    end
  end

  aggregate "ValidReferences", definition: "Validates reference targets exist in domain" do

    CheckReferences do
      String :domain_id
    end
  end

  aggregate "NoSelfReferences", definition: "Detects invalid self-referencing aggregate associations" do

    CheckSelfReferences do
      String :domain_id
    end
  end

  aggregate "NoBidirectionalReferences", definition: "Detects bidirectional reference cycles between aggregates" do

    CheckBidirectional do
      String :domain_id
    end
  end

  aggregate "NoForeignKeyAttributes", definition: "Detects attributes that should be references instead" do

    CheckForeignKeys do
      String :domain_id
    end
  end

  aggregate "Transparency", definition: "Validates domain design supports transparency concern" do

    CheckTransparency do
      String :domain_id
    end
  end

  aggregate "Consent", definition: "Validates domain design supports user consent concern" do

    CheckConsent do
      String :domain_id
    end
  end

  aggregate "Privacy", definition: "Validates domain design supports privacy concern" do

    CheckPrivacy do
      String :domain_id
    end
  end

  aggregate "Security", definition: "Validates domain design supports security concern" do

    CheckSecurity do
      String :domain_id
    end
  end

  aggregate "BoundaryAdvisor", definition: "Warns when aggregates are suspiciously thin (single attribute, no VOs)" do

    Advise do
      String :domain_id
    end
  end

  aggregate "WorldConcerns", definition: "Validates that aggregate world concerns are permitted by domain policy" do

    CheckConcerns do
      String :domain_id
    end
  end

