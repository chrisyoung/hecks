    GenerateAggregate do
      String :aggregate_id
      String :output_dir
    end
  end

  aggregate "CommandGenerator", definition: "Generates command class with typed attributes and validations" do

    GenerateCommand do
      String :command_id
      String :output_dir
    end
  end

