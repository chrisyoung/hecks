    expect ok: "true"
  end


  # ── DomainDeclaration aggregate ──────────────────────────────────────────

  test "DeclareDomain sets name" do
    tests "DeclareDomain", on: "DomainDeclaration"
    input  name: "sample"
    expect name: "sample", expressed: "true"
  end

  test "WireDependency sets target_domain" do
    tests "WireDependency", on: "DomainDeclaration"
    setup  "DeclareDomain", name: "sample"
    input  target_domain: "sample"
    expect listens_to_size: 1
  end

  test "SilenceDomain runs" do
    tests "SilenceDomain", on: "DomainDeclaration"
    setup  "DeclareDomain", name: "sample"
    expect expressed: "false"
  end


  # ── CapabilityDeclaration aggregate ──────────────────────────────────────────

  test "DeclareCapability sets name + category" do
    tests "DeclareCapability", on: "CapabilityDeclaration"
    input  name: "sample", category: "sample"
    expect name: "sample", category: "sample"
  end


  # ── WorldConfig aggregate ──────────────────────────────────────────

  test "SetConfig sets config_key + config_value + environment" do
    tests "SetConfig", on: "WorldConfig"
    input  config_key: "sample", config_value: "sample", environment: "sample"
    expect config_key: "sample", config_value: "sample", environment: "sample"
  end


  # ── AppOverride aggregate ──────────────────────────────────────────

  test "RegisterApp sets app_name + app_type" do
    tests "RegisterApp", on: "AppOverride"
    input  app_name: "sample", app_type: "sample"
    expect app_name: "sample", app_type: "sample"
  end

