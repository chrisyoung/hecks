Hecks.behaviors "Hecksagon" do
  vision "Behavioral tests for the Hecksagon domain — exercises every command and query in memory"

  # ── SerializationLines aggregate ──────────────────────────────────────────

  test "SerializeLines runs" do
    tests "SerializeLines", on: "SerializationLines"
    expect ok: "true"
  end

  test "DeserializeLines runs" do
    tests "DeserializeLines", on: "SerializationLines"
    expect ok: "true"
  end


  # ── SqlAdapterGenerator aggregate ──────────────────────────────────────────

  test "Generate runs" do
    tests "Generate", on: "SqlAdapterGenerator"
    expect ok: "true"
  end


  # ── SqlBuilder aggregate ──────────────────────────────────────────

  test "BuildInsert runs" do
    tests "BuildInsert", on: "SqlBuilder"
