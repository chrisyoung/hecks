  test "Apply runs" do
    tests "Apply", on: "DomainMixin"
    expect ok: "true"
  end


  # ── DatabaseConnection aggregate ──────────────────────────────────────────

  test "Connect sets url" do
    tests "Connect", on: "DatabaseConnection"
    input  url: "sample"
    expect ok: "true"
