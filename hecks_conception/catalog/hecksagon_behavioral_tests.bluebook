  test "AddGate sets aggregate + role" do
    tests "AddGate", on: "HecksagonBuilder"
    input  aggregate: "sample", role: "sample"
    expect ok: "true"
  end

  test "SetAdapter sets type" do
    tests "SetAdapter", on: "HecksagonBuilder"
    input  type: "sample"
    expect ok: "true"
  end

  test "Build runs" do
    tests "Build", on: "HecksagonBuilder"
    expect ok: "true"
  end


  # ── GateBuilder aggregate ──────────────────────────────────────────

  test "Allow sets methods" do
    tests "Allow", on: "GateBuilder"
    input  methods: "sample"
    expect ok: "true"
  end

  test "Build runs" do
    tests "Build", on: "GateBuilder"
    expect ok: "true"
