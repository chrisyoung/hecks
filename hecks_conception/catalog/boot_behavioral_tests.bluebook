Hecks.behaviors "Boot" do
  vision "Behavioral tests for the Boot domain — exercises every command and query in memory"

  # ── Session aggregate ──────────────────────────────────────────

  test "BootWithClaude runs" do
    tests "BootWithClaude", on: "Session"
    expect engine: "claude", brain_source: "anthropic", status: "booting"
  end

  test "BootWithSummer sets ollama_model + ollama_port" do
    tests "BootWithSummer", on: "Session"
    input  ollama_model: "sample", ollama_port: 1
    expect engine: "summer", brain_source: "local", status: "booting"
  end

  test "FailBoot sets reason" do
    tests "FailBoot", on: "Session"
    input  reason: "sample"
    expect status: "failed"
  end

  test "WireOrgans sets organ_count + nerve_count + law_count" do
    tests "WireOrgans", on: "Session"
    setup  "BootWithClaude"
    input  organ_count: 1, nerve_count: 1, law_count: 1
    expect organ_count: 1, nerve_count: 1, law_count: 1, started_at: "sample", status: "live"
  end

  test "EndSession runs" do
    tests "EndSession", on: "Session"
    setup  "BootWithClaude"
    setup  "GoLive", started_at: "sample"
    expect status: "ended"
  end


  # ── BrainProbe aggregate ──────────────────────────────────────────

  test "Probe runs" do
    tests "Probe", on: "BrainProbe"
    expect ok: "true"
  end

  test "RecommendClaude runs" do
    tests "RecommendClaude", on: "BrainProbe"
    setup  "Probe"
    expect recommended_engine: "claude"
  end

  test "RecommendSummer runs" do
    tests "RecommendSummer", on: "BrainProbe"
    setup  "Probe"
    expect recommended_engine: "summer"
  end

  test "RecommendNothing runs" do
    tests "RecommendNothing", on: "BrainProbe"
    setup  "Probe"
    expect recommended_engine: "none"
  end

end
