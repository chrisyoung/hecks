Hecks.behaviors "MietteBody" do
  vision "Behavioral tests for the MietteBody domain — exercises every command and query in memory"

  # ── Pulse aggregate ──────────────────────────────────────────

  test "Beat sets carrying" do
    tests "Beat", on: "Pulse"
    input  carrying: "sample"
    expect beats: 1, carrying: "sample"
  end

  test "Accelerate runs" do
    tests "Accelerate", on: "Pulse"
    setup  "Beat", carrying: "sample"
    input  pulse: 1
    expect flow_rate: "rushing"
  end

  test "Steady runs" do
    tests "Steady", on: "Pulse"
    setup  "Beat", carrying: "sample"
    input  pulse: 1
    expect flow_rate: "steady"
  end


  # ── Gut aggregate ──────────────────────────────────────────

  test "Ingest sets raw_input" do
    tests "Ingest", on: "Gut"
    input  raw_input: "sample"
    expect raw_input: "sample", digestion_stage: "ingested", stage: "ingested"
  end

  test "ExtractAggregate sets aggregate_name" do
    tests "ExtractAggregate", on: "Gut"
    setup  "Ingest", raw_input: "sample"
    input  gut: 1, aggregate_name: "sample"
    expect extracted_aggregates_size: 1, stage: "digesting"
  end

  test "ExtractCommand sets command_name" do
    tests "ExtractCommand", on: "Gut"
    setup  "Ingest", raw_input: "sample"
    setup  "ExtractAggregate", gut: 1, aggregate_name: "sample"
    input  gut: 1, command_name: "sample"
    expect extracted_commands_size: 1, stage: "digesting"
  end

  test "ExtractEvent sets event_name" do
    tests "ExtractEvent", on: "Gut"
    setup  "Ingest", raw_input: "sample"
    setup  "ExtractAggregate", gut: 1, aggregate_name: "sample"
    input  gut: 1, event_name: "sample"
    expect extracted_events_size: 1, stage: "digesting"
  end

  test "Absorb runs" do
    tests "Absorb", on: "Gut"
    setup  "Ingest", raw_input: "sample"
    setup  "ExtractAggregate", gut: 1, aggregate_name: "sample"
    input  gut: 1
    expect digestion_stage: "absorbed", stage: "absorbed"
  end


  # ── Immunity aggregate ──────────────────────────────────────────

  test "DetectThreat sets threat_pattern" do
    tests "DetectThreat", on: "Immunity"
    input  threat_pattern: "sample"
    expect ok: "true"
  end

  test "GraftVerbImmunity sets noun_suffixes + adjective_suffixes + dual_words" do
    tests "GraftVerbImmunity", on: "Immunity"
    setup  "DetectThreat", threat_pattern: "sample"
    input  immunity: 1, noun_suffixes: "sample", adjective_suffixes: "sample", dual_words: "sample"
    expect noun_suffixes: "sample", adjective_suffixes: "sample", dual_words: "sample"
  end

  test "GenerateAntibody sets pattern + learned_from" do
    tests "GenerateAntibody", on: "Immunity"
    input  pattern: "sample", learned_from: "sample"
    expect antibodies_size: 1
  end

  test "StrengthenAntibody sets pattern" do
    tests "StrengthenAntibody", on: "Immunity"
    setup  "DetectThreat", threat_pattern: "sample"
    input  immunity: 1, pattern: "sample"
    expect ok: "true"
  end

  test "Neutralize runs" do
    tests "Neutralize", on: "Immunity"
    setup  "DetectThreat", threat_pattern: "sample"
    input  immunity: 1
    expect threats_neutralized: 1
  end


  # ── Mood aggregate ──────────────────────────────────────────

  test "Express sets state" do
    tests "Express", on: "Mood"
    input  state: "sample"
    expect current_state: "sample"
  end

  test "Excite runs" do
    tests "Excite", on: "Mood"
    setup  "Express", state: "sample"
    input  mood: 1
    expect creativity_level: 1, precision_level: 1, current_state: "excited"
  end

  test "Focus runs" do
    tests "Focus", on: "Mood"
    setup  "Express", state: "sample"
    input  mood: 1
    expect precision_level: 1, creativity_level: 1, current_state: "focused"
  end

  test "Regulate runs" do
    tests "Regulate", on: "Mood"
    setup  "Express", state: "sample"
    input  mood: 1
    expect creativity_level: 0.7, precision_level: 0.7, current_state: "curious"
  end


  # ── DomainCell aggregate ──────────────────────────────────────────

  test "Conceive sets domain_name" do
    tests "Conceive", on: "DomainCell"
    input  domain_name: "sample"
    expect domain_name: "sample", maturity: 0, phase: "conceived"
  end

  test "Mature runs" do
    tests "Mature", on: "DomainCell"
    setup  "Conceive", domain_name: "sample"
    input  domain_cell: 1
    expect maturity: 1, phase: "growing"
  end

  test "PassCheckpoint sets checkpoint_name" do
    tests "PassCheckpoint", on: "DomainCell"
    setup  "Conceive", domain_name: "sample"
    setup  "Mature", domain_cell: 1
    input  domain_cell: 1, checkpoint_name: "sample"
    expect checkpoints_passed_size: 1, phase: "validated"
  end

  test "Divide runs" do
    tests "Divide", on: "DomainCell"
    setup  "Conceive", domain_name: "sample"
    setup  "Mature", domain_cell: 1
    setup  "PassCheckpoint", domain_cell: 1, checkpoint_name: "sample"
    input  domain_cell: 1
    expect phase: "divided"
  end

  test "TriggerApoptosis runs" do
    tests "TriggerApoptosis", on: "DomainCell"
    setup  "Conceive", domain_name: "sample"
    input  domain_cell: 1
    expect alive: false, phase: "dead"
  end


  # ── Gene aggregate ──────────────────────────────────────────

  test "ExpressCapability sets capability + level" do
    tests "ExpressCapability", on: "Gene"
    input  capability: "sample", level: 1.0
    expect capability: "sample", expression_level: 1.0
  end

  test "SilenceCapability runs" do
    tests "SilenceCapability", on: "Gene"
    setup  "ExpressCapability", capability: "sample", level: 1.0
    input  gene: 1
    expect expression_level: 0.0
  end

  test "Imprint sets source + effect" do
    tests "Imprint", on: "Gene"
    setup  "ExpressCapability", capability: "sample", level: 1.0
    input  gene: 1, source: "sample", effect: "sample"
    expect epigenetic_marks_size: 1
  end


  # ── Proprioception aggregate ──────────────────────────────────────────

  test "SenseOrgans sets organ_count + expressed_count + silenced_count + total_records" do
    tests "SenseOrgans", on: "Proprioception"
    input  organ_count: 1, expressed_count: 1, silenced_count: 1, total_records: 1
    expect organ_count: 1, expressed_count: 1, silenced_count: 1, total_records: 1, awareness: "sensing"
  end

  test "SenseLimb sets organ_name + expressed + record_count + load" do
    tests "SenseLimb", on: "Proprioception"
    setup  "SenseOrgans", organ_count: 1, expressed_count: 1, silenced_count: 1, total_records: 1
    input  organ_name: "sample", expressed: "sample", record_count: 1, load: "sample"
    expect limbs_size: 1, awareness: "sensing"
  end

  test "AssessBalance sets balance + schema_hash" do
    tests "AssessBalance", on: "Proprioception"
    setup  "SenseOrgans", organ_count: 1, expressed_count: 1, silenced_count: 1, total_records: 1
    input  proprioception: 1, balance: "sample", schema_hash: "sample"
    expect balance: "sample", schema_hash: "sample", awareness: "aware"
  end

  test "DetectDrift runs" do
    tests "DetectDrift", on: "Proprioception"
    setup  "SenseOrgans", organ_count: 1, expressed_count: 1, silenced_count: 1, total_records: 1
    setup  "AssessBalance", proprioception: 1, balance: "sample", schema_hash: "sample"
    input  proprioception: 1
    expect awareness: "recalibrating"
  end

end
