Hecks.behaviors "Nutrition" do
  vision "Behavioral tests for the Nutrition domain — exercises every command and query in memory"

  # ── FoodItem aggregate ──────────────────────────────────────────

  test "CatalogFood sets name + food_group + serving_size_g + calories_kcal" do
    tests "CatalogFood", on: "FoodItem"
    input  name: "sample", food_group: "sample", serving_size_g: 1.0, calories_kcal: 1.0
    expect ok: "true"
  end

  test "UpdateComposition sets calories_kcal" do
    tests "UpdateComposition", on: "FoodItem"
    setup  "CatalogFood", name: "sample", food_group: "sample", serving_size_g: 1.0, calories_kcal: 1.0
    input  calories_kcal: 1.0
    expect ok: "true"
  end

  test "RetireFood runs" do
    tests "RetireFood", on: "FoodItem"
    setup  "CatalogFood", name: "sample", food_group: "sample", serving_size_g: 1.0, calories_kcal: 1.0
    expect ok: "true"
  end


  # ── MealPlan aggregate ──────────────────────────────────────────

  test "Compose sets plan_name + duration_days + target_calories" do
    tests "Compose", on: "MealPlan"
    input  plan_name: "sample", duration_days: 1, target_calories: 1.0
    expect ok: "true"
  end

  test "AddMeal sets meal_type + servings" do
    tests "AddMeal", on: "MealPlan"
    setup  "CatalogFood", name: "sample", food_group: "sample", serving_size_g: 1.0, calories_kcal: 1.0
    setup  "Compose", plan_name: "sample", duration_days: 1, target_calories: 1.0
    input  meal_type: "sample", servings: 1.0
    expect ok: "true"
  end


  # ── DietaryGoal aggregate ──────────────────────────────────────────

  test "SetGoal sets goal_type + nutrient + target_value" do
    tests "SetGoal", on: "DietaryGoal"
    input  goal_type: "sample", nutrient: "sample", target_value: 1.0
    expect ok: "true"
  end

  test "AdjustTarget sets new_target" do
    tests "AdjustTarget", on: "DietaryGoal"
    setup  "SetGoal", goal_type: "sample", nutrient: "sample", target_value: 1.0
    input  new_target: 1.0
    expect ok: "true"
  end


  # ── Deficiency aggregate ──────────────────────────────────────────

  test "DetectDeficiency sets nutrient + severity" do
    tests "DetectDeficiency", on: "Deficiency"
    setup  "SetGoal", goal_type: "sample", nutrient: "sample", target_value: 1.0
    input  nutrient: "sample", severity: "sample"
    expect ok: "true"
  end

end
