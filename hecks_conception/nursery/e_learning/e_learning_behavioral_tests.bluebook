Hecks.behaviors "ELearning" do
  vision "Behavioral tests for the ELearning domain — exercises every command and query in memory"

  # ── Course aggregate ──────────────────────────────────────────

  test "CreateCourse sets course_title + instructor + subject_area + difficulty_level + estimated_hours" do
    tests "CreateCourse", on: "Course"
    input  course_title: "sample", instructor: "sample", subject_area: "sample", difficulty_level: "sample", estimated_hours: 1
    expect course_title: "sample", instructor: "sample", subject_area: "sample", difficulty_level: "sample", estimated_hours: 1
  end

  test "PublishCourse runs" do
    tests "PublishCourse", on: "Course"
    setup  "CreateCourse", course_title: "sample", instructor: "sample", subject_area: "sample", difficulty_level: "sample", estimated_hours: 1
    input  course: 1
    expect ok: "true"
  end

  test "RetireCourse runs" do
    tests "RetireCourse", on: "Course"
    setup  "CreateCourse", course_title: "sample", instructor: "sample", subject_area: "sample", difficulty_level: "sample", estimated_hours: 1
    input  course: 1
    expect ok: "true"
  end


  # ── Enrollment aggregate ──────────────────────────────────────────

  test "EnrollStudent sets enrollment_id + student_email" do
    tests "EnrollStudent", on: "Enrollment"
    setup  "CreateCourse", course_title: "sample", instructor: "sample", subject_area: "sample", difficulty_level: "sample", estimated_hours: 1
    input  course: 1, enrollment_id: "sample", student_email: "sample"
    expect ok: "true"
  end

  test "UpdateProgress sets progress_pct" do
    tests "UpdateProgress", on: "Enrollment"
    input  enrollment: 1, progress_pct: 1.0
    expect ok: "true"
  end

  test "WithdrawEnrollment runs" do
    tests "WithdrawEnrollment", on: "Enrollment"
    input  enrollment: 1
    expect ok: "true"
  end


  # ── Lesson aggregate ──────────────────────────────────────────

  test "AuthorLesson sets lesson_title + content_type + body + duration_minutes + sequence_order" do
    tests "AuthorLesson", on: "Lesson"
    setup  "CreateCourse", course_title: "sample", instructor: "sample", subject_area: "sample", difficulty_level: "sample", estimated_hours: 1
    input  course: 1, lesson_title: "sample", content_type: "sample", body: "sample", duration_minutes: 1, sequence_order: 1
    expect ok: "true"
  end

  test "UpdateLesson sets body" do
    tests "UpdateLesson", on: "Lesson"
    input  lesson: 1, body: "sample"
    expect ok: "true"
  end

  test "ArchiveLesson runs" do
    tests "ArchiveLesson", on: "Lesson"
    input  lesson: 1
    expect ok: "true"
  end


  # ── Quiz aggregate ──────────────────────────────────────────

  test "CreateQuiz sets quiz_title + passing_score + time_limit_minutes + max_attempts" do
    tests "CreateQuiz", on: "Quiz"
    input  lesson: 1, quiz_title: "sample", passing_score: 1, time_limit_minutes: 1, max_attempts: 1
    expect quiz_title: "sample", passing_score: 1, time_limit_minutes: 1, max_attempts: 1
  end

  test "SubmitAttempt sets student_email + score" do
    tests "SubmitAttempt", on: "Quiz"
    setup  "CreateQuiz", quiz_title: "sample", passing_score: 1, time_limit_minutes: 1, max_attempts: 1
    input  quiz: 1, student_email: "sample", score: 1
    expect ok: "true"
  end

  test "SuspendQuiz runs" do
    tests "SuspendQuiz", on: "Quiz"
    setup  "CreateQuiz", quiz_title: "sample", passing_score: 1, time_limit_minutes: 1, max_attempts: 1
    input  quiz: 1
    expect ok: "true"
  end


  # ── Certificate aggregate ──────────────────────────────────────────

  test "IssueCertificate sets certificate_id + student_email + course_title + verification_code" do
    tests "IssueCertificate", on: "Certificate"
    input  enrollment: 1, certificate_id: "sample", student_email: "sample", course_title: "sample", verification_code: "sample"
    expect ok: "true"
  end

  test "VerifyCertificate sets verification_code" do
    tests "VerifyCertificate", on: "Certificate"
    input  certificate: 1, verification_code: "sample"
    expect ok: "true"
  end

  test "RevokeCertificate runs" do
    tests "RevokeCertificate", on: "Certificate"
    input  certificate: 1
    expect ok: "true"
  end

end
