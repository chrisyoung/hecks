Hecks.behaviors "Astronomy" do
  vision "Behavioral tests for the Astronomy domain — exercises every command and query in memory"

  # ── CelestialBody aggregate ──────────────────────────────────────────

  test "RegisterBody sets designation + body_type + right_ascension + declination" do
    tests "RegisterBody", on: "CelestialBody"
    input  designation: "sample", body_type: "sample", right_ascension: 1.0, declination: 1.0
    expect designation: "sample", body_type: "sample", right_ascension: 1.0, declination: 1.0
  end

  test "UpdateEphemeris sets new_ra + new_dec" do
    tests "UpdateEphemeris", on: "CelestialBody"
    setup  "RegisterBody", designation: "sample", body_type: "sample", right_ascension: 1.0, declination: 1.0
    input  new_ra: 1.0, new_dec: 1.0
    expect ok: "true"
  end

  test "ReclassifyBody sets new_type" do
    tests "ReclassifyBody", on: "CelestialBody"
    setup  "RegisterBody", designation: "sample", body_type: "sample", right_ascension: 1.0, declination: 1.0
    input  new_type: "sample"
    expect ok: "true"
  end


  # ── Observation aggregate ──────────────────────────────────────────

  test "LogObservation sets observer_name + timestamp" do
    tests "LogObservation", on: "Observation"
    setup  "ActivateTelescope", name: "sample", aperture_mm: 1.0, focal_length_mm: 1.0
    setup  "RegisterBody", designation: "sample", body_type: "sample", right_ascension: 1.0, declination: 1.0
    input  observer_name: "sample", timestamp: "sample"
    expect ok: "true"
  end


  # ── Telescope aggregate ──────────────────────────────────────────

  test "ActivateTelescope sets name + aperture_mm + focal_length_mm" do
    tests "ActivateTelescope", on: "Telescope"
    input  name: "sample", aperture_mm: 1.0, focal_length_mm: 1.0
    expect ok: "true"
  end

  test "CalibrateOptics runs" do
    tests "CalibrateOptics", on: "Telescope"
    setup  "ActivateTelescope", name: "sample", aperture_mm: 1.0, focal_length_mm: 1.0
    expect ok: "true"
  end

  test "RetireTelescope runs" do
    tests "RetireTelescope", on: "Telescope"
    setup  "ActivateTelescope", name: "sample", aperture_mm: 1.0, focal_length_mm: 1.0
    expect ok: "true"
  end


  # ── Catalog aggregate ──────────────────────────────────────────

  test "Establish sets name + authority" do
    tests "Establish", on: "Catalog"
    input  name: "sample", authority: "sample"
    expect ok: "true"
  end

  test "PublishCatalog runs" do
    tests "PublishCatalog", on: "Catalog"
    setup  "Establish", name: "sample", authority: "sample"
    expect ok: "true"
  end

end
