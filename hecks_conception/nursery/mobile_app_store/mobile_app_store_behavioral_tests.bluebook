Hecks.behaviors "MobileAppStore" do
  vision "Behavioral tests for the MobileAppStore domain — exercises every command and query in memory"

  # ── App aggregate ──────────────────────────────────────────

  test "SubmitApp sets bundle_id + title + developer_name + category + price" do
    tests "SubmitApp", on: "App"
    input  bundle_id: "sample", title: "sample", developer_name: "sample", category: "sample", price: 1.0
    expect status: "pending_review"
  end

  test "ApproveApp runs" do
    tests "ApproveApp", on: "App"
    setup  "SubmitApp", bundle_id: "sample", title: "sample", developer_name: "sample", category: "sample", price: 1.0
    expect ok: "true"
  end

  test "SuspendApp runs" do
    tests "SuspendApp", on: "App"
    setup  "SubmitApp", bundle_id: "sample", title: "sample", developer_name: "sample", category: "sample", price: 1.0
    expect ok: "true"
  end


  # ── Review aggregate ──────────────────────────────────────────

  test "FlagReview sets reason" do
    tests "FlagReview", on: "Review"
    setup  "PostReview", review_id: "sample", author_name: "sample", rating: 1, comment: "sample"
    input  reason: "sample"
    expect status: "flagged"
  end


  # ── Download aggregate ──────────────────────────────────────────

  test "RecordDownload sets download_id + user_id + device_type + os_version" do
    tests "RecordDownload", on: "Download"
    setup  "SubmitApp", bundle_id: "sample", title: "sample", developer_name: "sample", category: "sample", price: 1.0
    input  download_id: "sample", user_id: "sample", device_type: "sample", os_version: "sample"
    expect status: "active"
  end

  test "RecordUninstall runs" do
    tests "RecordUninstall", on: "Download"
    setup  "RecordDownload", download_id: "sample", user_id: "sample", device_type: "sample", os_version: "sample"
    expect ok: "true"
  end

  test "RefundPurchase runs" do
    tests "RefundPurchase", on: "Download"
    setup  "RecordDownload", download_id: "sample", user_id: "sample", device_type: "sample", os_version: "sample"
    expect ok: "true"
  end


  # ── AppUpdate aggregate ──────────────────────────────────────────

  test "SubmitUpdate sets update_id + version_number + release_notes + size_mb" do
    tests "SubmitUpdate", on: "AppUpdate"
    setup  "SubmitApp", bundle_id: "sample", title: "sample", developer_name: "sample", category: "sample", price: 1.0
    input  update_id: "sample", version_number: "sample", release_notes: "sample", size_mb: 1
    expect status: "pending"
  end

  test "ApproveUpdate runs" do
    tests "ApproveUpdate", on: "AppUpdate"
    setup  "SubmitUpdate", update_id: "sample", version_number: "sample", release_notes: "sample", size_mb: 1
    expect ok: "true"
  end

  test "RejectUpdate sets rejection_reason" do
    tests "RejectUpdate", on: "AppUpdate"
    setup  "SubmitUpdate", update_id: "sample", version_number: "sample", release_notes: "sample", size_mb: 1
    input  rejection_reason: "sample"
    expect ok: "true"
  end


  # ── RevenueSplit aggregate ──────────────────────────────────────────

  test "CalculateSplit sets split_id + gross_amount + period" do
    tests "CalculateSplit", on: "RevenueSplit"
    setup  "SubmitApp", bundle_id: "sample", title: "sample", developer_name: "sample", category: "sample", price: 1.0
    input  split_id: "sample", gross_amount: 1.0, period: "sample"
    expect status: "calculated"
  end

  test "DisburseDeveloperShare runs" do
    tests "DisburseDeveloperShare", on: "RevenueSplit"
    setup  "CalculateSplit", split_id: "sample", gross_amount: 1.0, period: "sample"
    expect ok: "true"
  end

  test "DisputeSplit sets dispute_reason" do
    tests "DisputeSplit", on: "RevenueSplit"
    setup  "CalculateSplit", split_id: "sample", gross_amount: 1.0, period: "sample"
    input  dispute_reason: "sample"
    expect ok: "true"
  end

end
