Hecks.bluebook "Generators" do
  vision "Generate artifacts from domain IR — stubs, config, Sinatra apps, SQL, gems"

  aggregate "GenerateStubCommand", "Scaffold a domain file for hand-editing" do
    command("GenerateStub") { attribute :domain_path, String }
  end

  aggregate "GenerateSinatraCommand", "Scaffold a Sinatra app from a domain" do
    command("GenerateSinatra") { attribute :domain_path, String }
  end

  aggregate "GenerateConfigCommand", "Generate config reflecting current wiring" do
    command("GenerateConfig") { attribute :domain_path, String }
  end

  aggregate "GemCommand", "Package domain as a Ruby gem" do
    command("PackageGem") { attribute :domain_path, String }
  end

  aggregate "DumpCommand", "Extract docs from a domain (schema, swagger, rpc, domain, glossary)" do
    command("RunDump") { attribute :format, String }
  end

  aggregate "LlmsCommand", "Generate AI-readable llms.txt summary of the domain" do
    command("GenerateLlms") { attribute :domain_path, String }
  end
end
