Hecks.bluebook "Testing" do
  vision "Smoke tests, end-to-end verification, example regeneration"

  aggregate "SmoketestCommand", "Run smoke tests — single domain or all examples" do
    command("RunSmoketest") { attribute :target, String }
  end

  aggregate "RegenerateExamplesCommand", "Regenerate all example outputs from the pizzas domain" do
    command("RunRegenerate") { attribute :target, String }
  end
end
