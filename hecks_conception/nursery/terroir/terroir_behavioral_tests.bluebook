Hecks.behaviors "Terroir" do
  vision "Behavioral tests for the Terroir domain — exercises every command and query in memory"

  # ── GeologicalSurvey aggregate ──────────────────────────────────────────

  test "StartSurvey sets survey_id + location" do
    tests "StartSurvey", on: "GeologicalSurvey"
    input  survey_id: "sample", location: "sample"
    expect ok: "true"
  end

  test "RecordStratum sets rock_type + depth_m + mineral_content" do
    tests "RecordStratum", on: "GeologicalSurvey"
    setup  "StartSurvey", survey_id: "sample", location: "sample"
    input  geological_survey: 1, rock_type: "sample", depth_m: 1.0, mineral_content: "sample"
    expect strata_size: 1
  end

  test "CompleteSurvey runs" do
    tests "CompleteSurvey", on: "GeologicalSurvey"
    setup  "StartSurvey", survey_id: "sample", location: "sample"
    input  geological_survey: 1
    expect ok: "true"
  end


  # ── Vineyard aggregate ──────────────────────────────────────────

  test "PlantVineyard sets block_name + grape_variety + acres" do
    tests "PlantVineyard", on: "Vineyard"
    setup  "StartSurvey", survey_id: "sample", location: "sample"
    input  geological_survey: 1, block_name: "sample", grape_variety: "sample", acres: 1.0
    expect ok: "true"
  end

  test "AddVineRow sets row_number + vine_count + rootstock" do
    tests "AddVineRow", on: "Vineyard"
    setup  "AddVineRow", row_number: 1, vine_count: 1, rootstock: "sample"
    input  vineyard: 1, row_number: 1, vine_count: 1, rootstock: "sample"
    expect vines_size: 1
  end


  # ── Harvest aggregate ──────────────────────────────────────────

  test "StartHarvest sets harvest_date + brix" do
    tests "StartHarvest", on: "Harvest"
    setup  "AddVineRow", row_number: 1, vine_count: 1, rootstock: "sample"
    input  vineyard: 1, harvest_date: "sample", brix: 1.0
    expect ok: "true"
  end

  test "AddLot sets lot_number + weight_kg + quality_grade" do
    tests "AddLot", on: "Harvest"
    setup  "AddLot", lot_number: "sample", weight_kg: 1.0, quality_grade: "sample"
    input  harvest: 1, lot_number: "sample", weight_kg: 1.0, quality_grade: "sample"
    expect lots_size: 1
  end


  # ── Fermentation aggregate ──────────────────────────────────────────

  test "StartFermentation sets vessel_type + yeast_strain" do
    tests "StartFermentation", on: "Fermentation"
    setup  "AddLot", lot_number: "sample", weight_kg: 1.0, quality_grade: "sample"
    input  harvest: 1, vessel_type: "sample", yeast_strain: "sample"
    expect ok: "true"
  end

  test "RecordReading sets day + temperature_c + sugar_pct" do
    tests "RecordReading", on: "Fermentation"
    input  fermentation: 1, day: 1, temperature_c: 1.0, sugar_pct: 1.0
    expect readings_size: 1
  end

  test "CompleteFermentation runs" do
    tests "CompleteFermentation", on: "Fermentation"
    input  fermentation: 1
    expect ok: "true"
  end

end
