Hecks.behaviors "PerishableRescue" do
  vision "Behavioral tests for the PerishableRescue domain — exercises every command and query in memory"

  # ── FoodDonation aggregate ──────────────────────────────────────────

  test "ReceiveDonation sets donor_name + donation_date" do
    tests "ReceiveDonation", on: "FoodDonation"
    input  donor_name: "sample", donation_date: "sample"
    expect ok: "true"
  end

  test "AddItem sets food_type + weight_kg + expiry_date + temp_requirement_c" do
    tests "AddItem", on: "FoodDonation"
    setup  "ReceiveDonation", donor_name: "sample", donation_date: "sample"
    input  food_donation: 1, food_type: "sample", weight_kg: 1.0, expiry_date: "sample", temp_requirement_c: 1.0
    expect items_size: 1
  end

  test "ApproveDonation runs" do
    tests "ApproveDonation", on: "FoodDonation"
    setup  "ReceiveDonation", donor_name: "sample", donation_date: "sample"
    input  food_donation: 1
    expect ok: "true"
  end


  # ── ColdChainRoute aggregate ──────────────────────────────────────────

  test "PlanRoute sets route_id + vehicle_id" do
    tests "PlanRoute", on: "ColdChainRoute"
    input  route_id: "sample", vehicle_id: "sample"
    expect ok: "true"
  end

  test "RecordCheckpoint sets location + target_temp_c + actual_temp_c + timestamp" do
    tests "RecordCheckpoint", on: "ColdChainRoute"
    setup  "PlanRoute", route_id: "sample", vehicle_id: "sample"
    input  cold_chain_route: 1, location: "sample", target_temp_c: 1.0, actual_temp_c: 1.0, timestamp: "sample"
    expect checkpoints_size: 1
  end

  test "CompleteRoute runs" do
    tests "CompleteRoute", on: "ColdChainRoute"
    setup  "PlanRoute", route_id: "sample", vehicle_id: "sample"
    input  cold_chain_route: 1
    expect ok: "true"
  end


  # ── Distribution aggregate ──────────────────────────────────────────

  test "ScheduleDistribution sets site_name + distribution_date" do
    tests "ScheduleDistribution", on: "Distribution"
    setup  "ReceiveDonation", donor_name: "sample", donation_date: "sample"
    input  food_donation: 1, site_name: "sample", distribution_date: "sample"
    expect ok: "true"
  end

  test "RegisterRecipient sets family_id + family_size + dietary_needs" do
    tests "RegisterRecipient", on: "Distribution"
    input  distribution: 1, family_id: "sample", family_size: 1, dietary_needs: "sample"
    expect recipients_size: 1
  end

  test "ExecuteDistribution runs" do
    tests "ExecuteDistribution", on: "Distribution"
    input  distribution: 1
    expect ok: "true"
  end


  # ── TempAlert aggregate ──────────────────────────────────────────

  test "RaiseAlert sets alert_type + temp_deviation_c" do
    tests "RaiseAlert", on: "TempAlert"
    setup  "PlanRoute", route_id: "sample", vehicle_id: "sample"
    input  cold_chain_route: 1, alert_type: "sample", temp_deviation_c: 1.0
    expect ok: "true"
  end

  test "RespondToAlert sets action + responder + timestamp" do
    tests "RespondToAlert", on: "TempAlert"
    input  temp_alert: 1, action: "sample", responder: "sample", timestamp: "sample"
    expect responses_size: 1
  end

  test "ResolveAlert runs" do
    tests "ResolveAlert", on: "TempAlert"
    input  temp_alert: 1
    expect ok: "true"
  end

end
