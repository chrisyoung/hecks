Hecks.behaviors "DentalPractice" do
  vision "Behavioral tests for the DentalPractice domain — exercises every command and query in memory"

  # ── Patient aggregate ──────────────────────────────────────────

  test "RegisterPatient sets first_name + last_name + date_of_birth + phone + insurance_provider + policy_number" do
    tests "RegisterPatient", on: "Patient"
    input  first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    expect first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample", status: "active"
  end

  test "UpdateInsurance sets insurance_provider + policy_number" do
    tests "UpdateInsurance", on: "Patient"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  patient: 1, insurance_provider: "sample", policy_number: "sample"
    expect insurance_provider: "sample", policy_number: "sample"
  end

  test "DeactivatePatient runs" do
    tests "DeactivatePatient", on: "Patient"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  patient: 1
    expect status: "inactive"
  end


  # ── DentalProcedure aggregate ──────────────────────────────────────────

  test "PerformProcedure sets cdt_code + procedure_name + tooth_number + surface + notes" do
    tests "PerformProcedure", on: "DentalProcedure"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  patient: 1, cdt_code: "sample", procedure_name: "sample", tooth_number: "sample", surface: "sample", notes: "sample"
    expect cdt_code: "sample", procedure_name: "sample", tooth_number: "sample", surface: "sample", status: "completed"
  end

  test "PlanTreatment sets cdt_code + procedure_name + tooth_number" do
    tests "PlanTreatment", on: "DentalProcedure"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  patient: 1, cdt_code: "sample", procedure_name: "sample", tooth_number: "sample"
    expect cdt_code: "sample", procedure_name: "sample", status: "planned"
  end


  # ── Radiograph aggregate ──────────────────────────────────────────

  test "TakeRadiograph sets image_type + tooth_region" do
    tests "TakeRadiograph", on: "Radiograph"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  patient: 1, image_type: "sample", tooth_region: "sample"
    expect image_type: "sample", tooth_region: "sample"
  end

  test "InterpretRadiograph sets findings" do
    tests "InterpretRadiograph", on: "Radiograph"
    input  radiograph: 1, findings: "sample"
    expect findings: "sample"
  end


  # ── InsuranceClaim aggregate ──────────────────────────────────────────

  test "SubmitClaim sets billed_amount" do
    tests "SubmitClaim", on: "InsuranceClaim"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  dental_procedure: 1, patient: 1, billed_amount: 1.0
    expect billed_amount: 1.0, status: "submitted"
  end

  test "ProcessPayment sets allowed_amount + patient_responsibility" do
    tests "ProcessPayment", on: "InsuranceClaim"
    input  insurance_claim: 1, allowed_amount: 1.0, patient_responsibility: 1.0
    expect allowed_amount: 1.0, patient_responsibility: 1.0, status: "paid"
  end

  test "DenyClaim runs" do
    tests "DenyClaim", on: "InsuranceClaim"
    input  insurance_claim: 1
    expect status: "denied"
  end


  # ── DentalAppointment aggregate ──────────────────────────────────────────

  test "ScheduleVisit sets appointment_date + time_slot + visit_type" do
    tests "ScheduleVisit", on: "DentalAppointment"
    setup  "RegisterPatient", first_name: "sample", last_name: "sample", date_of_birth: "sample", phone: "sample", insurance_provider: "sample", policy_number: "sample"
    input  patient: 1, appointment_date: "sample", time_slot: "sample", visit_type: "sample"
    expect appointment_date: "sample", time_slot: "sample", visit_type: "sample", status: "scheduled"
  end

  test "ConfirmVisit runs" do
    tests "ConfirmVisit", on: "DentalAppointment"
    input  dental_appointment: 1
    expect status: "confirmed"
  end

  test "CancelVisit runs" do
    tests "CancelVisit", on: "DentalAppointment"
    input  dental_appointment: 1
    expect status: "cancelled"
  end

end
