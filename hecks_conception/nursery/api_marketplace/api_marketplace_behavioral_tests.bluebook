Hecks.behaviors "APIMarketplace" do
  vision "Behavioral tests for the APIMarketplace domain — exercises every command and query in memory"

  # ── APIProduct aggregate ──────────────────────────────────────────

  test "PublishAPI sets api_name + version + description + base_url + auth_method" do
    tests "PublishAPI", on: "APIProduct"
    input  api_name: "sample", version: "sample", description: "sample", base_url: "sample", auth_method: "sample"
    expect ok: "true"
  end

  test "DeprecateAPI sets sunset_date" do
    tests "DeprecateAPI", on: "APIProduct"
    setup  "PublishAPI", api_name: "sample", version: "sample", description: "sample", base_url: "sample", auth_method: "sample"
    input  a_p_i_product: 1, sunset_date: "sample"
    expect ok: "true"
  end

  test "RetireAPI runs" do
    tests "RetireAPI", on: "APIProduct"
    setup  "PublishAPI", api_name: "sample", version: "sample", description: "sample", base_url: "sample", auth_method: "sample"
    input  a_p_i_product: 1
    expect ok: "true"
  end


  # ── Consumer aggregate ──────────────────────────────────────────

  test "RegisterConsumer sets consumer_name + email + organization + plan" do
    tests "RegisterConsumer", on: "Consumer"
    input  consumer_name: "sample", email: "sample", organization: "sample", plan: "sample"
    expect consumer_name: "sample", email: "sample", organization: "sample", plan: "sample"
  end

  test "SubscribeToAPI sets api_name + tier" do
    tests "SubscribeToAPI", on: "Consumer"
    setup  "RegisterConsumer", consumer_name: "sample", email: "sample", organization: "sample", plan: "sample"
    input  consumer: 1, api_name: "sample", tier: "sample"
    expect ok: "true"
  end

  test "SuspendConsumer runs" do
    tests "SuspendConsumer", on: "Consumer"
    setup  "RegisterConsumer", consumer_name: "sample", email: "sample", organization: "sample", plan: "sample"
    input  consumer: 1
    expect ok: "true"
  end


  # ── APIKey aggregate ──────────────────────────────────────────

  test "IssueKey sets key_id + label + scope + expires_at" do
    tests "IssueKey", on: "APIKey"
    setup  "RegisterConsumer", consumer_name: "sample", email: "sample", organization: "sample", plan: "sample"
    input  consumer: 1, key_id: "sample", label: "sample", scope: "sample", expires_at: "sample"
    expect ok: "true"
  end

  test "RevokeKey runs" do
    tests "RevokeKey", on: "APIKey"
    input  a_p_i_key: 1
    expect ok: "true"
  end

  test "RotateKey runs" do
    tests "RotateKey", on: "APIKey"
    input  a_p_i_key: 1
    expect ok: "true"
  end


  # ── RateLimitPolicy aggregate ──────────────────────────────────────────

  test "DefineRateLimit sets policy_name + requests_per_minute + requests_per_day + burst_limit" do
    tests "DefineRateLimit", on: "RateLimitPolicy"
    setup  "PublishAPI", api_name: "sample", version: "sample", description: "sample", base_url: "sample", auth_method: "sample"
    input  a_p_i_product: 1, policy_name: "sample", requests_per_minute: 1, requests_per_day: 1, burst_limit: 1
    expect ok: "true"
  end

  test "AdjustLimit sets requests_per_minute + requests_per_day" do
    tests "AdjustLimit", on: "RateLimitPolicy"
    input  rate_limit_policy: 1, requests_per_minute: 1, requests_per_day: 1
    expect ok: "true"
  end

  test "EnforceThrottle sets consumer_id" do
    tests "EnforceThrottle", on: "RateLimitPolicy"
    input  rate_limit_policy: 1, consumer_id: "sample"
    expect ok: "true"
  end


  # ── UsageBill aggregate ──────────────────────────────────────────

  test "GenerateBill sets bill_id + amount + total_calls + billing_period" do
    tests "GenerateBill", on: "UsageBill"
    setup  "RegisterConsumer", consumer_name: "sample", email: "sample", organization: "sample", plan: "sample"
    input  consumer: 1, bill_id: "sample", amount: 1.0, total_calls: 1, billing_period: "sample"
    expect ok: "true"
  end

  test "CollectPayment runs" do
    tests "CollectPayment", on: "UsageBill"
    input  usage_bill: 1
    expect ok: "true"
  end

  test "WaiveBill sets waiver_reason" do
    tests "WaiveBill", on: "UsageBill"
    input  usage_bill: 1, waiver_reason: "sample"
    expect ok: "true"
  end

end
