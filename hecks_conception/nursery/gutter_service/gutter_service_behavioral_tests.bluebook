Hecks.behaviors "GutterService" do
  vision "Behavioral tests for the GutterService domain — exercises every command and query in memory"

  # ── GutterProperty aggregate ──────────────────────────────────────────

  test "SurveyProperty sets owner_name + address + roofline_feet + existing_gutter_condition" do
    tests "SurveyProperty", on: "GutterProperty"
    input  owner_name: "sample", address: "sample", roofline_feet: 1.0, existing_gutter_condition: "sample"
    expect ok: "true"
  end

  test "AssessDrainage sets drainage_notes" do
    tests "AssessDrainage", on: "GutterProperty"
    setup  "SurveyProperty", owner_name: "sample", address: "sample", roofline_feet: 1.0, existing_gutter_condition: "sample"
    input  gutter_property: 1, drainage_notes: "sample"
    expect ok: "true"
  end


  # ── GutterMeasurement aggregate ──────────────────────────────────────────

  test "TakeMeasurements sets run_length_feet + drop_per_foot + miter_count + gutter_profile" do
    tests "TakeMeasurements", on: "GutterMeasurement"
    setup  "SurveyProperty", owner_name: "sample", address: "sample", roofline_feet: 1.0, existing_gutter_condition: "sample"
    input  gutter_property: 1, run_length_feet: 1.0, drop_per_foot: 1.0, miter_count: 1, gutter_profile: "sample"
    expect ok: "true"
  end

  test "CalculateMaterials runs" do
    tests "CalculateMaterials", on: "GutterMeasurement"
    input  gutter_measurement: 1
    expect ok: "true"
  end


  # ── GutterMaterial aggregate ──────────────────────────────────────────

  test "OrderMaterial sets material_type + gauge + color + coil_footage" do
    tests "OrderMaterial", on: "GutterMaterial"
    input  gutter_measurement: 1, material_type: "sample", gauge: "sample", color: "sample", coil_footage: 1.0
    expect ok: "true"
  end

  test "FabricateGutter runs" do
    tests "FabricateGutter", on: "GutterMaterial"
    input  gutter_material: 1
    expect ok: "true"
  end


  # ── GutterInstallation aggregate ──────────────────────────────────────────

  test "ScheduleInstall sets installer_name + install_date" do
    tests "ScheduleInstall", on: "GutterInstallation"
    setup  "SurveyProperty", owner_name: "sample", address: "sample", roofline_feet: 1.0, existing_gutter_condition: "sample"
    input  gutter_property: 1, installer_name: "sample", install_date: "sample"
    expect ok: "true"
  end

  test "HangGutters sets hangers_used" do
    tests "HangGutters", on: "GutterInstallation"
    input  gutter_installation: 1, hangers_used: 1
    expect ok: "true"
  end

  test "ConnectDownspouts sets downspout_count" do
    tests "ConnectDownspouts", on: "GutterInstallation"
    input  gutter_installation: 1, downspout_count: 1
    expect ok: "true"
  end


  # ── GutterCleaning aggregate ──────────────────────────────────────────

  test "ScheduleCleaning sets service_date" do
    tests "ScheduleCleaning", on: "GutterCleaning"
    setup  "SurveyProperty", owner_name: "sample", address: "sample", roofline_feet: 1.0, existing_gutter_condition: "sample"
    input  gutter_property: 1, service_date: "sample"
    expect ok: "true"
  end

  test "PerformCleaning sets debris_type + condition_notes" do
    tests "PerformCleaning", on: "GutterCleaning"
    input  gutter_cleaning: 1, debris_type: "sample", condition_notes: "sample"
    expect ok: "true"
  end

end
