Hecks.behaviors "Cryptography" do
  vision "Behavioral tests for the Cryptography domain — exercises every command and query in memory"

  # ── KeyPair aggregate ──────────────────────────────────────────

  test "GenerateKeyPair sets algorithm + key_length_bits + owner" do
    tests "GenerateKeyPair", on: "KeyPair"
    input  algorithm: "sample", key_length_bits: 1, owner: "sample"
    expect ok: "true"
  end

  test "RotateKey runs" do
    tests "RotateKey", on: "KeyPair"
    setup  "GenerateKeyPair", algorithm: "sample", key_length_bits: 1, owner: "sample"
    expect ok: "true"
  end


  # ── Cipher aggregate ──────────────────────────────────────────

  test "RegisterCipher sets cipher_name + cipher_type + block_size_bits" do
    tests "RegisterCipher", on: "Cipher"
    input  cipher_name: "sample", cipher_type: "sample", block_size_bits: 1
    expect cipher_name: "sample", cipher_type: "sample", block_size_bits: 1
  end

  test "BenchmarkCipher runs" do
    tests "BenchmarkCipher", on: "Cipher"
    setup  "RegisterCipher", cipher_name: "sample", cipher_type: "sample", block_size_bits: 1
    expect ok: "true"
  end


  # ── EncryptedMessage aggregate ──────────────────────────────────────────

  test "EncryptMessage sets plaintext" do
    tests "EncryptMessage", on: "EncryptedMessage"
    setup  "RegisterCipher", cipher_name: "sample", cipher_type: "sample", block_size_bits: 1
    setup  "GenerateKeyPair", algorithm: "sample", key_length_bits: 1, owner: "sample"
    input  plaintext: "sample"
    expect ok: "true"
  end


  # ── DigitalSignature aggregate ──────────────────────────────────────────

  test "SignMessage sets message_hash + hash_algorithm" do
    tests "SignMessage", on: "DigitalSignature"
    setup  "GenerateKeyPair", algorithm: "sample", key_length_bits: 1, owner: "sample"
    input  message_hash: "sample", hash_algorithm: "sample"
    expect ok: "true"
  end


  # ── Certificate aggregate ──────────────────────────────────────────

  test "IssueCertificate sets subject + valid_from + valid_to" do
    tests "IssueCertificate", on: "Certificate"
    setup  "GenerateKeyPair", algorithm: "sample", key_length_bits: 1, owner: "sample"
    input  subject: "sample", valid_from: "sample", valid_to: "sample"
    expect ok: "true"
  end

  test "RevokeCertificate sets reason" do
    tests "RevokeCertificate", on: "Certificate"
    setup  "IssueCertificate", subject: "sample", valid_from: "sample", valid_to: "sample"
    input  reason: "sample"
    expect ok: "true"
  end

end
