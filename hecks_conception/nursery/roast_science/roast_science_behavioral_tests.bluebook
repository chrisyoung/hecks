Hecks.behaviors "RoastScience" do
  vision "Behavioral tests for the RoastScience domain — exercises every command and query in memory"

  # ── GreenBean aggregate ──────────────────────────────────────────

  test "SourceBeans sets origin + variety + altitude_m" do
    tests "SourceBeans", on: "GreenBean"
    input  origin: "sample", variety: "sample", altitude_m: 1.0
    expect ok: "true"
  end

  test "AnalyzeCompound sets compound_name + concentration_ppm + flavor_impact" do
    tests "AnalyzeCompound", on: "GreenBean"
    setup  "SourceBeans", origin: "sample", variety: "sample", altitude_m: 1.0
    input  compound_name: "sample", concentration_ppm: 1.0, flavor_impact: "sample"
    expect compounds_size: 1
  end


  # ── RoastProfile aggregate ──────────────────────────────────────────

  test "DesignProfile sets profile_name + roast_level" do
    tests "DesignProfile", on: "RoastProfile"
    setup  "SourceBeans", origin: "sample", variety: "sample", altitude_m: 1.0
    input  profile_name: "sample", roast_level: "sample"
    expect ok: "true"
  end

  test "AddCurvePoint sets time_seconds + temp_c + phase" do
    tests "AddCurvePoint", on: "RoastProfile"
    setup  "DesignProfile", profile_name: "sample", roast_level: "sample"
    input  time_seconds: 1, temp_c: 1.0, phase: "sample"
    expect curve_points_size: 1
  end

  test "ApproveProfile runs" do
    tests "ApproveProfile", on: "RoastProfile"
    setup  "DesignProfile", profile_name: "sample", roast_level: "sample"
    expect ok: "true"
  end


  # ── RoastBatch aggregate ──────────────────────────────────────────

  test "StartBatch sets batch_number + weight_kg" do
    tests "StartBatch", on: "RoastBatch"
    setup  "DesignProfile", profile_name: "sample", roast_level: "sample"
    input  batch_number: "sample", weight_kg: 1.0
    expect ok: "true"
  end

  test "RecordReaction sets reaction_type + onset_temp_c + intensity" do
    tests "RecordReaction", on: "RoastBatch"
    setup  "StartBatch", batch_number: "sample", weight_kg: 1.0
    input  reaction_type: "sample", onset_temp_c: 1.0, intensity: 1.0
    expect reactions_size: 1
  end

  test "CompleteBatch runs" do
    tests "CompleteBatch", on: "RoastBatch"
    setup  "StartBatch", batch_number: "sample", weight_kg: 1.0
    expect ok: "true"
  end


  # ── BrewRecipe aggregate ──────────────────────────────────────────

  test "Compose sets recipe_name + brew_method" do
    tests "Compose", on: "BrewRecipe"
    setup  "StartBatch", batch_number: "sample", weight_kg: 1.0
    input  recipe_name: "sample", brew_method: "sample"
    expect ok: "true"
  end

  test "SetParameter sets param_name + value + unit" do
    tests "SetParameter", on: "BrewRecipe"
    setup  "Compose", recipe_name: "sample", brew_method: "sample"
    input  param_name: "sample", value: 1.0, unit: "sample"
    expect parameters_size: 1
  end

  test "PublishRecipe runs" do
    tests "PublishRecipe", on: "BrewRecipe"
    setup  "Compose", recipe_name: "sample", brew_method: "sample"
    expect ok: "true"
  end

end
