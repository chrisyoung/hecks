Hecks.behaviors "FabricToRunway" do
  vision "Behavioral tests for the FabricToRunway domain — exercises every command and query in memory"

  # ── Fabric aggregate ──────────────────────────────────────────

  test "WeaveFabric sets name + fiber_type + weight_gsm" do
    tests "WeaveFabric", on: "Fabric"
    input  name: "sample", fiber_type: "sample", weight_gsm: 1.0
    expect ok: "true"
  end

  test "DyeFabric sets color + batch_number + yards" do
    tests "DyeFabric", on: "Fabric"
    setup  "WeaveFabric", name: "sample", fiber_type: "sample", weight_gsm: 1.0
    input  fabric: 1, color: "sample", batch_number: "sample", yards: 1.0
    expect dye_lots_size: 1
  end

  test "ApproveFabric runs" do
    tests "ApproveFabric", on: "Fabric"
    setup  "WeaveFabric", name: "sample", fiber_type: "sample", weight_gsm: 1.0
    input  fabric: 1
    expect ok: "true"
  end


  # ── Collection aggregate ──────────────────────────────────────────

  test "CreateCollection sets name + season" do
    tests "CreateCollection", on: "Collection"
    input  name: "sample", season: "sample"
    expect name: "sample", season: "sample"
  end

  test "AddGarment sets garment_name + garment_type + fabric_requirement" do
    tests "AddGarment", on: "Collection"
    setup  "CreateCollection", name: "sample", season: "sample"
    input  collection: 1, garment_name: "sample", garment_type: "sample", fabric_requirement: "sample"
    expect garments_size: 1
  end


  # ── Pattern aggregate ──────────────────────────────────────────

  test "DraftPattern sets garment_name + size_range" do
    tests "DraftPattern", on: "Pattern"
    setup  "WeaveFabric", name: "sample", fiber_type: "sample", weight_gsm: 1.0
    input  fabric: 1, garment_name: "sample", size_range: "sample"
    expect ok: "true"
  end

  test "AddPatternPiece sets piece_name + fabric_yards" do
    tests "AddPatternPiece", on: "Pattern"
    setup  "AddPatternPiece", piece_name: "sample", fabric_yards: 1.0
    input  pattern: 1, piece_name: "sample", fabric_yards: 1.0
    expect pieces_size: 1
  end

  test "FinalizePattern runs" do
    tests "FinalizePattern", on: "Pattern"
    setup  "AddPatternPiece", piece_name: "sample", fabric_yards: 1.0
    input  pattern: 1
    expect ok: "true"
  end


  # ── RunwayShow aggregate ──────────────────────────────────────────

  test "PlanShow sets venue + show_date" do
    tests "PlanShow", on: "RunwayShow"
    setup  "CreateCollection", name: "sample", season: "sample"
    input  collection: 1, venue: "sample", show_date: "sample"
    expect ok: "true"
  end

  test "AddLook sets look_number + garment_name + model_name" do
    tests "AddLook", on: "RunwayShow"
    setup  "AddLook", look_number: 1, garment_name: "sample", model_name: "sample"
    input  runway_show: 1, look_number: 1, garment_name: "sample", model_name: "sample"
    expect looks_size: 1
  end

  test "ExecuteShow runs" do
    tests "ExecuteShow", on: "RunwayShow"
    setup  "AddLook", look_number: 1, garment_name: "sample", model_name: "sample"
    input  runway_show: 1
    expect ok: "true"
  end

end
