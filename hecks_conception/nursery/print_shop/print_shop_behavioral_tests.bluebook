Hecks.behaviors "PrintShop" do
  vision "Behavioral tests for the PrintShop domain — exercises every command and query in memory"

  # ── PrintJob aggregate ──────────────────────────────────────────

  test "SubmitPrintJob sets job_name + customer_name + quantity + print_method + color_profile + due_date" do
    tests "SubmitPrintJob", on: "PrintJob"
    input  job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample"
    expect job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample", status: "submitted"
  end

  test "ApprovePrintJob runs" do
    tests "ApprovePrintJob", on: "PrintJob"
    setup  "SubmitPrintJob", job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample"
    input  print_job: 1
    expect status: "approved"
  end

  test "CompletePrintJob runs" do
    tests "CompletePrintJob", on: "PrintJob"
    setup  "SubmitPrintJob", job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample"
    input  print_job: 1
    expect status: "completed"
  end


  # ── Substrate aggregate ──────────────────────────────────────────

  test "StockSubstrate sets material_name + material_type + weight_gsm + width_inches + sheets_on_hand + reorder_level" do
    tests "StockSubstrate", on: "Substrate"
    input  material_name: "sample", material_type: "sample", weight_gsm: 1.0, width_inches: 1.0, sheets_on_hand: 1, reorder_level: 1
    expect material_name: "sample", material_type: "sample", weight_gsm: 1.0, width_inches: 1.0, sheets_on_hand: 1, reorder_level: 1, status: "in_stock"
  end

  test "ConsumeSubstrate sets sheets_used" do
    tests "ConsumeSubstrate", on: "Substrate"
    setup  "StockSubstrate", material_name: "sample", material_type: "sample", weight_gsm: 1.0, width_inches: 1.0, sheets_on_hand: 1, reorder_level: 1
    input  substrate: 1, sheets_used: 1
    expect ok: "true"
  end

  test "ReorderSubstrate sets order_quantity" do
    tests "ReorderSubstrate", on: "Substrate"
    setup  "StockSubstrate", material_name: "sample", material_type: "sample", weight_gsm: 1.0, width_inches: 1.0, sheets_on_hand: 1, reorder_level: 1
    input  substrate: 1, order_quantity: 1
    expect ok: "true"
  end


  # ── PressSchedule aggregate ──────────────────────────────────────────

  test "SchedulePress sets press_name + scheduled_date + start_time + end_time" do
    tests "SchedulePress", on: "PressSchedule"
    setup  "SubmitPrintJob", job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample"
    input  print_job: 1, press_name: "sample", scheduled_date: "sample", start_time: "sample", end_time: "sample"
    expect press_name: "sample", scheduled_date: "sample", start_time: "sample", end_time: "sample", status: "scheduled"
  end

  test "StartPressRun runs" do
    tests "StartPressRun", on: "PressSchedule"
    input  press_schedule: 1
    expect status: "running"
  end

  test "HaltPress sets halt_reason" do
    tests "HaltPress", on: "PressSchedule"
    input  press_schedule: 1, halt_reason: "sample"
    expect status: "halted"
  end


  # ── ProofCycle aggregate ──────────────────────────────────────────

  test "SendProof sets proof_file + revision_number" do
    tests "SendProof", on: "ProofCycle"
    setup  "SubmitPrintJob", job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample"
    input  print_job: 1, proof_file: "sample", revision_number: 1
    expect proof_file: "sample", revision_number: 1, status: "awaiting_approval"
  end

  test "ApproveProof runs" do
    tests "ApproveProof", on: "ProofCycle"
    input  proof_cycle: 1
    expect status: "approved"
  end

  test "RequestRevision sets customer_feedback" do
    tests "RequestRevision", on: "ProofCycle"
    input  proof_cycle: 1, customer_feedback: "sample"
    expect customer_feedback: "sample", status: "revision_needed"
  end


  # ── DeliveryOrder aggregate ──────────────────────────────────────────

  test "ScheduleDelivery sets delivery_address + delivery_date + box_count + carrier" do
    tests "ScheduleDelivery", on: "DeliveryOrder"
    setup  "SubmitPrintJob", job_name: "sample", customer_name: "sample", quantity: 1, print_method: "sample", color_profile: "sample", due_date: "sample"
    input  print_job: 1, delivery_address: "sample", delivery_date: "sample", box_count: 1, carrier: "sample"
    expect delivery_address: "sample", delivery_date: "sample", box_count: 1, carrier: "sample", status: "scheduled"
  end

  test "ShipOrder sets tracking_number" do
    tests "ShipOrder", on: "DeliveryOrder"
    input  delivery_order: 1, tracking_number: "sample"
    expect tracking_number: "sample", status: "shipped"
  end

  test "ConfirmDelivery runs" do
    tests "ConfirmDelivery", on: "DeliveryOrder"
    input  delivery_order: 1
    expect status: "delivered"
  end

end
