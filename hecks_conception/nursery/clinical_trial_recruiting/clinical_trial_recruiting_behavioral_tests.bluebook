Hecks.behaviors "ClinicalTrialRecruiting" do
  vision "Behavioral tests for the ClinicalTrialRecruiting domain — exercises every command and query in memory"

  # ── DrugCandidate aggregate ──────────────────────────────────────────

  test "RegisterCompound sets compound_name + indication + phase" do
    tests "RegisterCompound", on: "DrugCandidate"
    input  compound_name: "sample", indication: "sample", phase: "sample"
    expect compound_name: "sample", indication: "sample", phase: "sample"
  end

  test "AddContraindication sets condition + severity" do
    tests "AddContraindication", on: "DrugCandidate"
    setup  "RegisterCompound", compound_name: "sample", indication: "sample", phase: "sample"
    input  drug_candidate: 1, condition: "sample", severity: "sample"
    expect contraindications_size: 1
  end

  test "AdvancePhase runs" do
    tests "AdvancePhase", on: "DrugCandidate"
    setup  "RegisterCompound", compound_name: "sample", indication: "sample", phase: "sample"
    input  drug_candidate: 1
    expect ok: "true"
  end


  # ── TrialProtocol aggregate ──────────────────────────────────────────

  test "DraftProtocol sets protocol_name + target_enrollment" do
    tests "DraftProtocol", on: "TrialProtocol"
    setup  "RegisterCompound", compound_name: "sample", indication: "sample", phase: "sample"
    input  drug_candidate: 1, protocol_name: "sample", target_enrollment: 1
    expect ok: "true"
  end

  test "AddCriterion sets criterion_type + description" do
    tests "AddCriterion", on: "TrialProtocol"
    setup  "AddCriterion", criterion_type: "sample", description: "sample"
    input  trial_protocol: 1, criterion_type: "sample", description: "sample"
    expect criteria_size: 1
  end

  test "ApproveProtocol runs" do
    tests "ApproveProtocol", on: "TrialProtocol"
    setup  "AddCriterion", criterion_type: "sample", description: "sample"
    input  trial_protocol: 1
    expect ok: "true"
  end


  # ── FreelanceParticipant aggregate ──────────────────────────────────────────

  test "RegisterParticipant sets participant_name + age + availability" do
    tests "RegisterParticipant", on: "FreelanceParticipant"
    input  participant_name: "sample", age: 1, availability: "sample"
    expect participant_name: "sample", age: 1, availability: "sample"
  end

  test "AddMedicalHistory sets condition_name + diagnosed_year" do
    tests "AddMedicalHistory", on: "FreelanceParticipant"
    setup  "RegisterParticipant", participant_name: "sample", age: 1, availability: "sample"
    input  freelance_participant: 1, condition_name: "sample", diagnosed_year: 1
    expect medical_history_size: 1
  end


  # ── MatchResult aggregate ──────────────────────────────────────────

  test "MatchParticipant sets match_score" do
    tests "MatchParticipant", on: "MatchResult"
    setup  "RegisterParticipant", participant_name: "sample", age: 1, availability: "sample"
    setup  "AddCriterion", criterion_type: "sample", description: "sample"
    input  freelance_participant: 1, trial_protocol: 1, match_score: 1.0
    expect ok: "true"
  end

  test "ScreenParticipant sets criterion_type + passed + notes" do
    tests "ScreenParticipant", on: "MatchResult"
    input  match_result: 1, criterion_type: "sample", passed: "sample", notes: "sample"
    expect screening_results_size: 1
  end

  test "EnrollParticipant runs" do
    tests "EnrollParticipant", on: "MatchResult"
    input  match_result: 1
    expect ok: "true"
  end

end
