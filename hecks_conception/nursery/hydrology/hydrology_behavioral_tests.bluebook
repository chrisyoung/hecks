Hecks.behaviors "Hydrology" do
  vision "Behavioral tests for the Hydrology domain — exercises every command and query in memory"

  # ── Watershed aggregate ──────────────────────────────────────────

  test "DelineateWatershed sets watershed_id + name + area_km2" do
    tests "DelineateWatershed", on: "Watershed"
    input  watershed_id: "sample", name: "sample", area_km2: 1.0
    expect ok: "true"
  end

  test "ClassifyLandUse sets land_use_dominant" do
    tests "ClassifyLandUse", on: "Watershed"
    setup  "DelineateWatershed", watershed_id: "sample", name: "sample", area_km2: 1.0
    input  land_use_dominant: "sample"
    expect ok: "true"
  end

  test "UpdateBoundary runs" do
    tests "UpdateBoundary", on: "Watershed"
    setup  "DelineateWatershed", watershed_id: "sample", name: "sample", area_km2: 1.0
    expect ok: "true"
  end


  # ── StreamGauge aggregate ──────────────────────────────────────────

  test "InstallGauge sets gauge_id + stream_name" do
    tests "InstallGauge", on: "StreamGauge"
    setup  "DelineateWatershed", watershed_id: "sample", name: "sample", area_km2: 1.0
    input  gauge_id: "sample", stream_name: "sample"
    expect ok: "true"
  end

  test "CalibrateGauge runs" do
    tests "CalibrateGauge", on: "StreamGauge"
    setup  "InstallGauge", gauge_id: "sample", stream_name: "sample"
    expect ok: "true"
  end

  test "RemoveGauge runs" do
    tests "RemoveGauge", on: "StreamGauge"
    setup  "InstallGauge", gauge_id: "sample", stream_name: "sample"
    expect ok: "true"
  end


  # ── FlowMeasurement aggregate ──────────────────────────────────────────

  test "RecordDischarge sets measurement_date + stage_m + discharge_cms" do
    tests "RecordDischarge", on: "FlowMeasurement"
    setup  "InstallGauge", gauge_id: "sample", stream_name: "sample"
    input  measurement_date: "sample", stage_m: 1.0, discharge_cms: 1.0
    expect ok: "true"
  end

  test "ValidateMeasurement runs" do
    tests "ValidateMeasurement", on: "FlowMeasurement"
    setup  "RecordDischarge", measurement_date: "sample", stage_m: 1.0, discharge_cms: 1.0
    expect ok: "true"
  end


  # ── FloodModel aggregate ──────────────────────────────────────────

  test "BuildModel sets model_id + scenario_name" do
    tests "BuildModel", on: "FloodModel"
    setup  "DelineateWatershed", watershed_id: "sample", name: "sample", area_km2: 1.0
    input  model_id: "sample", scenario_name: "sample"
    expect ok: "true"
  end

  test "RunSimulation sets return_period_years" do
    tests "RunSimulation", on: "FloodModel"
    setup  "BuildModel", model_id: "sample", scenario_name: "sample"
    input  return_period_years: 1
    expect ok: "true"
  end

  test "PublishFloodMap runs" do
    tests "PublishFloodMap", on: "FloodModel"
    setup  "BuildModel", model_id: "sample", scenario_name: "sample"
    expect ok: "true"
  end


  # ── MonitoringWell aggregate ──────────────────────────────────────────

  test "DrillWell sets well_id + depth_m" do
    tests "DrillWell", on: "MonitoringWell"
    setup  "DelineateWatershed", watershed_id: "sample", name: "sample", area_km2: 1.0
    input  well_id: "sample", depth_m: 1.0
    expect ok: "true"
  end

  test "MeasureWaterLevel sets depth_to_water_m" do
    tests "MeasureWaterLevel", on: "MonitoringWell"
    setup  "DrillWell", well_id: "sample", depth_m: 1.0
    input  depth_to_water_m: 1.0
    expect ok: "true"
  end

  test "SampleGroundwater runs" do
    tests "SampleGroundwater", on: "MonitoringWell"
    setup  "DrillWell", well_id: "sample", depth_m: 1.0
    expect ok: "true"
  end

end
