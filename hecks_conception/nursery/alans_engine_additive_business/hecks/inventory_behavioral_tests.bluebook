Hecks.behaviors "Inventory" do
  vision "Behavioral tests for the Inventory domain — exercises every command and query in memory"

  # ── Inventory aggregate ──────────────────────────────────────────

  test "ReceiveStock sets sku + warehouse + quantity" do
    tests "ReceiveStock", on: "Inventory"
    input  sku: "sample", warehouse: "sample", quantity: 1
    expect sku: "sample", warehouse: "sample", quantity_on_hand: 1
  end

  test "ReserveStock sets quantity" do
    tests "ReserveStock", on: "Inventory"
    setup  "ReceiveStock", sku: "sample", warehouse: "sample", quantity: 1
    input  inventory: 1, quantity: 1
    expect quantity_reserved: 1
  end

  test "ShipStock sets quantity" do
    tests "ShipStock", on: "Inventory"
    setup  "ReceiveStock", sku: "sample", warehouse: "sample", quantity: 1
    input  inventory: 1, quantity: 1
    expect quantity_on_hand: 1, quantity_reserved: 1
  end

  test "AdjustInventory sets adjustment + reason" do
    tests "AdjustInventory", on: "Inventory"
    setup  "ReceiveStock", sku: "sample", warehouse: "sample", quantity: 1
    input  inventory: 1, adjustment: 1, reason: "sample"
    expect ok: "true"
  end

  test "TriggerReorder runs" do
    tests "TriggerReorder", on: "Inventory"
    setup  "ReceiveStock", sku: "sample", warehouse: "sample", quantity: 1
    input  inventory: 1
    expect ok: "true"
  end

end
