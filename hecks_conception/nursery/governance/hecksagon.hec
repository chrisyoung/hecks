Hecks.hecksagon "Governance" do
  concerns :webapp
  domain "law"
  domain "court" do
    listens_to "law"
  end
  domain "enforcement" do
    listens_to "law"
    listens_to "court"
  end
  domain "action_gate" do
    listens_to "enforcement"
    listens_to "law"
  end
  domain "task_runtime" do
    listens_to "action_gate"
    listens_to "enforcement"
  end
end
