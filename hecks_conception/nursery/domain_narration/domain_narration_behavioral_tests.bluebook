Hecks.behaviors "DomainNarration" do
  vision "Behavioral tests for the DomainNarration domain — exercises every command and query in memory"

  # ── Workflow aggregate ──────────────────────────────────────────

  test "InferWorkflow sets domain_name" do
    tests "InferWorkflow", on: "Workflow"
    input  domain_name: "sample"
    expect ok: "true"
  end


  # ── Narration aggregate ──────────────────────────────────────────

  test "TranslateEvent sets event_name" do
    tests "TranslateEvent", on: "Narration"
    input  event_name: "sample"
    expect ok: "true"
  end

  test "TranslateCommand sets command_name" do
    tests "TranslateCommand", on: "Narration"
    input  command_name: "sample"
    expect ok: "true"
  end


  # ── PolicyChain aggregate ──────────────────────────────────────────

  test "TraceChain sets command_name + domain_name" do
    tests "TraceChain", on: "PolicyChain"
    input  command_name: "sample", domain_name: "sample"
    expect ok: "true"
  end


  # ── Rule aggregate ──────────────────────────────────────────

  test "CollectRules sets domain_name" do
    tests "CollectRules", on: "Rule"
    input  domain_name: "sample"
    expect ok: "true"
  end

end
