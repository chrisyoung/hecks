Hecks.behaviors "RoofingCompany" do
  vision "Behavioral tests for the RoofingCompany domain — exercises every command and query in memory"

  # ── RoofEstimate aggregate ──────────────────────────────────────────

  test "MeasureRoof sets customer_name + address + square_footage + pitch" do
    tests "MeasureRoof", on: "RoofEstimate"
    input  customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    expect ok: "true"
  end

  test "QuoteJob sets material_cost_per_square + labor_cost_per_square" do
    tests "QuoteJob", on: "RoofEstimate"
    setup  "MeasureRoof", customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    input  roof_estimate: 1, material_cost_per_square: 1.0, labor_cost_per_square: 1.0
    expect ok: "true"
  end

  test "AcceptQuote runs" do
    tests "AcceptQuote", on: "RoofEstimate"
    setup  "MeasureRoof", customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    input  roof_estimate: 1
    expect ok: "true"
  end


  # ── MaterialOrder aggregate ──────────────────────────────────────────

  test "OrderMaterials sets supplier + material_type + quantity_bundles" do
    tests "OrderMaterials", on: "MaterialOrder"
    setup  "MeasureRoof", customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    input  roof_estimate: 1, supplier: "sample", material_type: "sample", quantity_bundles: 1
    expect ok: "true"
  end

  test "ReceiveDelivery runs" do
    tests "ReceiveDelivery", on: "MaterialOrder"
    input  material_order: 1
    expect ok: "true"
  end


  # ── Crew aggregate ──────────────────────────────────────────

  test "FormCrew sets foreman_name + crew_size" do
    tests "FormCrew", on: "Crew"
    input  foreman_name: "sample", crew_size: 1
    expect ok: "true"
  end

  test "AssignToJob runs" do
    tests "AssignToJob", on: "Crew"
    setup  "FormCrew", foreman_name: "sample", crew_size: 1
    setup  "MeasureRoof", customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    input  crew: 1, roof_estimate: 1
    expect ok: "true"
  end


  # ── WeatherHold aggregate ──────────────────────────────────────────

  test "PlaceHold sets reason" do
    tests "PlaceHold", on: "WeatherHold"
    setup  "MeasureRoof", customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    input  roof_estimate: 1, reason: "sample"
    expect reason: "sample"
  end

  test "LiftHold runs" do
    tests "LiftHold", on: "WeatherHold"
    setup  "PlaceHold", reason: "sample"
    input  weather_hold: 1
    expect ok: "true"
  end


  # ── RoofWarranty aggregate ──────────────────────────────────────────

  test "RegisterWarranty sets warranty_type + duration_years + coverage_details" do
    tests "RegisterWarranty", on: "RoofWarranty"
    setup  "MeasureRoof", customer_name: "sample", address: "sample", square_footage: 1.0, pitch: 1.0
    input  roof_estimate: 1, warranty_type: "sample", duration_years: 1, coverage_details: "sample"
    expect warranty_type: "sample", duration_years: 1, coverage_details: "sample"
  end

  test "FileLeakClaim sets leak_location" do
    tests "FileLeakClaim", on: "RoofWarranty"
    setup  "RegisterWarranty", warranty_type: "sample", duration_years: 1, coverage_details: "sample"
    input  roof_warranty: 1, leak_location: "sample"
    expect ok: "true"
  end

end
