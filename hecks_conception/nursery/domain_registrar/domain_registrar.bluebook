Hecks.bluebook "DomainRegistrar", version: "2026.04.13.1" do
  vision "Operating a domain registrar — registering domains, processing renewals, handling transfers, managing DNS records, and tracking WHOIS data"
  category "technology"

  aggregate "DomainName", "A registered internet domain under management" do
    String :domain
    String :tld
    String :registrant_email
    String :registered_at
    String :expires_at
    String :status
    list_of(NameServer) :name_servers

    value_object "NameServer" do
      String :hostname
      String :ip_address
      Integer :priority
    end

    RegisterDomain do
      role "Customer"
      description "Claim and register a new domain name"
      String :domain
      String :tld
      String :registrant_email
      Integer :registration_years
      then_set :status, to: "active"
      emits "DomainRegistered"
    end

    LockDomain do
      description "Enable transfer lock to prevent unauthorized transfers"
      reference_to(DomainName)
      emits "DomainLocked"
    end

    SuspendDomain do
      description "Place a domain on hold for policy violations"
      reference_to(DomainName)
      given("domain is active") { status == "active" }
      emits "DomainSuspended"
    end
  end

  aggregate "Renewal", "A renewal transaction extending a domain's registration" do
    String :renewal_id
    Integer :years
    Float :price
    String :renewed_at
    String :status
    reference_to DomainName

    value_object "RenewalReceipt" do
      String :transaction_id
      Float :amount_paid
      String :payment_method
    end

    RenewDomain do
      role "Customer"
      description "Extend a domain registration for additional years"
      String :renewal_id
      Integer :years
      Float :price
      reference_to(DomainName)
      then_set :status, to: "pending"
      emits "DomainRenewed"
    end

    AutoRenew do
      description "Automatically renew a domain before expiration"
      reference_to(Renewal)
      emits "DomainAutoRenewed"
    end

    CancelRenewal do
      description "Void a pending renewal before processing"
      reference_to(Renewal)
      given("renewal is pending") { status == "pending" }
      emits "RenewalCanceled"
    end
  end

  aggregate "Transfer", "A domain transfer between registrars" do
    String :transfer_id
    String :auth_code
    String :gaining_registrar
    String :losing_registrar
    String :status
    reference_to DomainName

    value_object "TransferTimeline" do
      String :event
      String :occurred_at
      String :actor
    end

    InitiateTransfer do
      role "Customer"
      description "Begin transferring a domain to another registrar"
      String :transfer_id
      String :auth_code
      String :gaining_registrar
      reference_to(DomainName)
      then_set :status, to: "pending_approval"
      emits "TransferInitiated"
    end

    ApproveTransfer do
      description "Authorize the transfer from the losing registrar side"
      reference_to(Transfer)
      given("transfer is pending approval") { status == "pending_approval" }
      emits "TransferApproved"
    end

    RejectTransfer do
      description "Deny a transfer request"
      reference_to(Transfer)
      String :rejection_reason
      emits "TransferRejected"
    end
  end

  aggregate "DNSRecord", "A DNS entry pointing a domain to an IP or service" do
    String :record_id
    String :record_type
    String :hostname
    String :value
    Integer :ttl
    String :status
    reference_to DomainName

    value_object "RecordHistory" do
      String :previous_value
      String :changed_at
      String :changed_by
    end

    PublishDNSRecord do
      role "Customer"
      description "Add a DNS record to a managed domain"
      String :record_id
      String :record_type
      String :hostname
      String :value
      Integer :ttl
      reference_to(DomainName)
      then_set :status, to: "active"
      emits "DNSRecordPublished"
    end

    ReviseDNSRecord do
      description "Modify the value or TTL of a DNS record"
      reference_to(DNSRecord)
      String :value
      Integer :ttl
      emits "DNSRecordRevised"
    end

    RetireDNSRecord do
      description "Remove a DNS record from the zone"
      reference_to(DNSRecord)
      given("record is active") { status == "active" }
      emits "DNSRecordRetired"
    end
  end

  aggregate "WHOISPrivacy", "A privacy shield hiding registrant contact details" do
    String :privacy_id
    String :proxy_email
    String :proxy_name
    String :enabled_at
    String :status
    reference_to DomainName

    value_object "PrivacySetting" do
      String :field_name
      String :masked
      String :proxy_value
    end

    ActivatePrivacy do
      role "Customer"
      description "Activate WHOIS privacy protection for a domain"
      String :privacy_id
      String :proxy_email
      String :proxy_name
      reference_to(DomainName)
      then_set :status, to: "active"
      emits "PrivacyActivated"
    end

    DeactivatePrivacy do
      description "Remove WHOIS privacy and reveal registrant data"
      reference_to(WHOISPrivacy)
      given("privacy is active") { status == "active" }
      emits "PrivacyDeactivated"
    end

    RefreshProxy do
      description "Rotate the proxy contact details"
      reference_to(WHOISPrivacy)
      String :proxy_email
      emits "ProxyRefreshed"
    end
  end

  lifecycle "DomainLifecycle" do
    state "available"
    state "registered"
    state "locked"
    state "transferring"
    state "expired"
    state "suspended"

    transition from: "available", to: "registered", on: "DomainRegistered"
    transition from: "registered", to: "locked", on: "DomainLocked"
    transition from: "locked", to: "transferring", on: "TransferInitiated"
    transition from: "transferring", to: "registered", on: "TransferApproved"
    transition from: "registered", to: "expired", on: "RenewalCanceled"
    transition from: "registered", to: "suspended", on: "DomainSuspended"
  end

  policy "RegisteredLockDomain" do
    on "DomainRegistered"
    trigger "LockDomain"
  end

  policy "RegisteredActivatePrivacy" do
    on "DomainRegistered"
    trigger "ActivatePrivacy"
  end

  policy "RegisteredPublishDNS" do
    on "DomainRegistered"
    trigger "PublishDNSRecord"
  end

  policy "LockedAutoRenew" do
    on "DomainLocked"
    trigger "AutoRenew"
  end

  policy "TransferApprovedRefreshProxy" do
    on "TransferApproved"
    trigger "RefreshProxy"
  end

  policy "RenewalCanceledSuspendDomain" do
    on "RenewalCanceled"
    trigger "SuspendDomain"
  end

  fixture "DomainName", domain: "example", tld: "com", registrant_email: "owner@example.com", registered_at: "2026-01-15", expires_at: "2027-01-15", status: "active"
  fixture "DomainName", domain: "mycompany", tld: "org", registrant_email: "admin@mycompany.org", registered_at: "2025-06-20", expires_at: "2026-06-20", status: "active"

  fixture "Renewal", renewal_id: "REN-001", years: 1, price: 12.99, renewed_at: "2026-03-10", status: "completed"
  fixture "Renewal", renewal_id: "REN-002", years: 2, price: 24.99, renewed_at: "2026-04-01", status: "pending"

  fixture "Transfer", transfer_id: "TRN-001", auth_code: "abc123xyz789", gaining_registrar: "NewRegistrar Inc", losing_registrar: "OldRegistrar LLC", status: "pending_approval"
  fixture "Transfer", transfer_id: "TRN-002", auth_code: "def456uvw012", gaining_registrar: "FastDNS Pro", losing_registrar: "ClassicDomains", status: "approved"

  fixture "DNSRecord", record_id: "DNS-001", record_type: "A", hostname: "example.com", value: "192.0.2.42", ttl: 3600, status: "active"
  fixture "DNSRecord", record_id: "DNS-002", record_type: "CNAME", hostname: "www.example.com", value: "example.com", ttl: 1800, status: "active"

  fixture "WHOISPrivacy", privacy_id: "PRIV-001", proxy_email: "privacy@example.com", proxy_name: "Privacy Proxy Service", enabled_at: "2026-02-01", status: "active"
  fixture "WHOISPrivacy", privacy_id: "PRIV-002", proxy_email: "shield@mycompany.org", proxy_name: "WHOIS Guard", enabled_at: "2026-01-20", status: "inactive"
end
