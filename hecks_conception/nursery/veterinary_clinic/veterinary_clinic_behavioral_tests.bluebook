Hecks.behaviors "VeterinaryClinic" do
  vision "Behavioral tests for the VeterinaryClinic domain — exercises every command and query in memory"

  # ── Pet aggregate ──────────────────────────────────────────

  test "RegisterPet sets name + species + breed + weight + date_of_birth" do
    tests "RegisterPet", on: "Pet"
    input  name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample"
    expect name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample", status: "active"
  end

  test "RecordWeight sets weight" do
    tests "RecordWeight", on: "Pet"
    setup  "RegisterPet", name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample"
    input  pet: 1, weight: 1.0
    expect weight: 1.0
  end

  test "MarkDeceased runs" do
    tests "MarkDeceased", on: "Pet"
    setup  "RegisterPet", name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample"
    input  pet: 1
    expect status: "deceased"
  end


  # ── Owner aggregate ──────────────────────────────────────────

  test "RegisterOwner sets first_name + last_name + phone + email" do
    tests "RegisterOwner", on: "Owner"
    input  first_name: "sample", last_name: "sample", phone: "sample", email: "sample"
    expect first_name: "sample", last_name: "sample", phone: "sample", email: "sample"
  end

  test "UpdateContactInfo sets phone + email" do
    tests "UpdateContactInfo", on: "Owner"
    setup  "RegisterOwner", first_name: "sample", last_name: "sample", phone: "sample", email: "sample"
    input  owner: 1, phone: "sample", email: "sample"
    expect phone: "sample", email: "sample"
  end


  # ── Appointment aggregate ──────────────────────────────────────────

  test "ScheduleAppointment sets appointment_date + time_slot + reason" do
    tests "ScheduleAppointment", on: "Appointment"
    setup  "RegisterPet", name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample"
    input  pet: 1, appointment_date: "sample", time_slot: "sample", reason: "sample"
    expect appointment_date: "sample", time_slot: "sample", reason: "sample", status: "scheduled"
  end

  test "CheckInPatient runs" do
    tests "CheckInPatient", on: "Appointment"
    input  appointment: 1
    expect status: "checked_in"
  end

  test "CompleteAppointment sets notes" do
    tests "CompleteAppointment", on: "Appointment"
    input  appointment: 1, notes: "sample"
    expect notes: "sample", status: "completed"
  end


  # ── Vaccination aggregate ──────────────────────────────────────────

  test "AdministerVaccine sets vaccine_name + lot_number + expiration_date" do
    tests "AdministerVaccine", on: "Vaccination"
    setup  "RegisterPet", name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample"
    input  pet: 1, vaccine_name: "sample", lot_number: "sample", expiration_date: "sample"
    expect vaccine_name: "sample", lot_number: "sample", expiration_date: "sample", status: "current"
  end

  test "ExpireVaccination runs" do
    tests "ExpireVaccination", on: "Vaccination"
    input  vaccination: 1
    expect status: "expired"
  end


  # ── Prescription aggregate ──────────────────────────────────────────

  test "PrescribeMedication sets medication_name + dosage + frequency + refills_remaining" do
    tests "PrescribeMedication", on: "Prescription"
    setup  "RegisterPet", name: "sample", species: "sample", breed: "sample", weight: 1.0, date_of_birth: "sample"
    input  pet: 1, medication_name: "sample", dosage: "sample", frequency: "sample", refills_remaining: 1
    expect medication_name: "sample", dosage: "sample", frequency: "sample", refills_remaining: 1, status: "active"
  end

  test "RefillPrescription runs" do
    tests "RefillPrescription", on: "Prescription"
    input  prescription: 1
    expect ok: "true"
  end

  test "DiscontinueMedication runs" do
    tests "DiscontinueMedication", on: "Prescription"
    input  prescription: 1
    expect status: "discontinued"
  end

end
