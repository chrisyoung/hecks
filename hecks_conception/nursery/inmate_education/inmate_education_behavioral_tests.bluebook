Hecks.behaviors "InmateEducation" do
  vision "Behavioral tests for the InmateEducation domain — exercises every command and query in memory"

  # ── Inmate aggregate ──────────────────────────────────────────

  test "EnrollInmate sets inmate_id + name + facility + education_level" do
    tests "EnrollInmate", on: "Inmate"
    input  inmate_id: "sample", name: "sample", facility: "sample", education_level: "sample"
    expect ok: "true"
  end

  test "AwardCertification sets cert_name + issued_date + issuing_body" do
    tests "AwardCertification", on: "Inmate"
    setup  "EnrollInmate", inmate_id: "sample", name: "sample", facility: "sample", education_level: "sample"
    input  inmate: 1, cert_name: "sample", issued_date: "sample", issuing_body: "sample"
    expect certifications_size: 1
  end


  # ── Course aggregate ──────────────────────────────────────────

  test "CreateCourse sets course_name + subject" do
    tests "CreateCourse", on: "Course"
    input  course_name: "sample", subject: "sample"
    expect course_name: "sample", subject: "sample"
  end

  test "AddModule sets module_name + content_type + duration_minutes" do
    tests "AddModule", on: "Course"
    setup  "CreateCourse", course_name: "sample", subject: "sample"
    input  course: 1, module_name: "sample", content_type: "sample", duration_minutes: 1
    expect modules_size: 1
  end

  test "PublishCourse runs" do
    tests "PublishCourse", on: "Course"
    setup  "CreateCourse", course_name: "sample", subject: "sample"
    input  course: 1
    expect ok: "true"
  end


  # ── Enrollment aggregate ──────────────────────────────────────────

  test "RegisterEnrollment runs" do
    tests "RegisterEnrollment", on: "Enrollment"
    setup  "CreateCourse", course_name: "sample", subject: "sample"
    setup  "EnrollInmate", inmate_id: "sample", name: "sample", facility: "sample", education_level: "sample"
    input  inmate: 1, course: 1
    expect ok: "true"
  end

  test "SubmitAssignment sets assignment_name + score" do
    tests "SubmitAssignment", on: "Enrollment"
    input  enrollment: 1, assignment_name: "sample", score: 1.0
    expect assignments_size: 1
  end

  test "CompleteEnrollment runs" do
    tests "CompleteEnrollment", on: "Enrollment"
    input  enrollment: 1
    expect ok: "true"
  end


  # ── BehaviorRecord aggregate ──────────────────────────────────────────

  test "RecordInfraction sets infraction_type + severity + date" do
    tests "RecordInfraction", on: "BehaviorRecord"
    input  behavior_record: 1, infraction_type: "sample", severity: "sample", date: "sample"
    expect infractions_size: 1
  end

  test "AwardMerit sets merit_type + description + date" do
    tests "AwardMerit", on: "BehaviorRecord"
    input  behavior_record: 1, merit_type: "sample", description: "sample", date: "sample"
    expect merits_size: 1
  end

end
