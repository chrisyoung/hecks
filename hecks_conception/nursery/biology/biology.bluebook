Hecks.bluebook "Biology", version: "2026.04.11.1" do
  vision "The language of life — cells, genes, proteins, organisms, ecosystems, and the processes that animate matter"
  category "science"

  # === Cell Biology ===

  aggregate "Cell", "The fundamental unit of life — membrane-bound, self-replicating, metabolizing" do
    String :cell_type
    String :name
    String :organism_type
    String :phase
    Float :energy_level
    list_of(Organelle) :organelles
    Float :membrane_integrity
    String :differentiation_state

    value_object "Organelle" do
      String :name
      String :function
      Integer :count
      String :membrane_bound
    end

    value_object "Cytoplasm" do
      Float :volume
      Float :ph
      Float :ion_concentration
    end

    value_object "Nucleus" do
      Integer :chromosome_count
      String :ploidy
      String :envelope_intact
    end

    CreateCell do
      role "Biologist"
      description "Instantiate a new cell with its type and organism origin"
      String :cell_type
      String :name
      String :organism_type
      emits "CellCreated"
      then_set :cell_type, to: :cell_type
      then_set :name, to: :name
      then_set :organism_type, to: :organism_type
      then_set :phase, to: "interphase"
      then_set :membrane_integrity, to: 1.0
      then_set :energy_level, to: 100.0
    end

    Divide do
      role "Biologist"
      description "Trigger cell division — mitosis for somatic, meiosis for gametes"
      reference_to(Cell)
      String :division_type
      given { phase == "interphase" }
      given { membrane_integrity > 0.5 }
      emits "CellDivided"
      then_set :phase, to: "dividing"
    end

    Differentiate do
      role "Biologist"
      description "Commit a stem cell to a specialized fate — neuron, muscle, epithelial"
      reference_to(Cell)
      String :target_type
      String :signals
      given { cell_type == "stem" }
      emits "CellDifferentiated"
      then_set :differentiation_state, to: :target_type
      then_set :cell_type, to: :target_type
    end

    Metabolize do
      role "System"
      description "Convert nutrients to energy — aerobic or anaerobic respiration"
      reference_to(Cell)
      String :pathway
      String :substrate
      emits "CellMetabolized"
    end

    TriggerApoptosis do
      role "System"
      description "Programmed cell death — clean, orderly self-destruction"
      reference_to(Cell)
      emits "ApoptosisTriggered"
      then_set :phase, to: "apoptotic"
      then_set :membrane_integrity, to: 0.0
    end

    EnterPhase do
      role "System"
      description "Advance the cell cycle — G1, S, G2, M"
      reference_to(Cell)
      String :phase
      emits "PhaseEntered"
      then_set :phase, to: :phase
    end

    RepairMembrane do
      role "System"
      description "Restore membrane integrity after damage"
      reference_to(Cell)
      Float :integrity
      emits "MembraneRepaired"
      then_set :membrane_integrity, to: :integrity
    end

    lifecycle :phase, default: "interphase" do
      transition "CreateCell" => "interphase", from: "none"
      transition "EnterPhase" => "G1", from: "interphase"
      transition "EnterPhase" => "S", from: "G1"
      transition "EnterPhase" => "G2", from: "S"
      transition "Divide" => "dividing", from: "interphase"
      transition "EnterPhase" => "interphase", from: "dividing"
      transition "TriggerApoptosis" => "apoptotic", from: "interphase"
    end
  end

  # === DNA & Genetics Molecular ===

  aggregate "DNA", "The molecule of heredity — nucleotide sequence encoding life's instructions" do
    String :sequence
    String :strand_type
    Integer :length
    String :organism
    list_of(Gene) :genes
    list_of(Codon) :codons
    Float :gc_content
    Float :integrity

    value_object "Gene" do
      String :name
      String :locus
      Integer :start_position
      Integer :end_position
      String :strand
      String :function
    end

    value_object "Codon" do
      String :triplet
      String :amino_acid
      Integer :position
    end

    value_object "Nucleotide" do
      String :base
      String :sugar
      String :phosphate
      Integer :position
    end

    SequenceDNA do
      role "Geneticist"
      description "Read and record a DNA sequence with its gene annotations"
      String :sequence
      String :organism
      String :strand_type
      emits "DNASequenced"
      then_set :sequence, to: :sequence
      then_set :organism, to: :organism
      then_set :strand_type, to: :strand_type
      then_set :integrity, to: 1.0
    end

    Replicate do
      role "System"
      description "Copy the DNA double helix — semiconservative replication"
      reference_to(DNA)
      String :origin_of_replication
      given { integrity > 0.8 }
      emits "DNAReplicated"
    end

    Transcribe do
      role "System"
      description "Synthesize mRNA from a gene — RNA polymerase reads template strand"
      reference_to(DNA)
      String :gene_name
      String :promoter
      emits "GeneTranscribed"
    end

    Mutate do
      role "System"
      description "Introduce a change — point mutation, insertion, deletion, frameshift"
      reference_to(DNA)
      String :mutation_type
      Integer :position
      String :original_base
      String :new_base
      emits "DNAMutated"
    end

    RepairDNA do
      role "System"
      description "Fix DNA damage — mismatch repair, excision repair, recombination"
      reference_to(DNA)
      String :repair_mechanism
      Integer :damage_site
      emits "DNARepaired"
      then_set :integrity, to: 1.0
    end

    Methylate do
      role "System"
      description "Add methyl groups to DNA — epigenetic silencing of gene expression"
      reference_to(DNA)
      String :gene_name
      String :methylation_pattern
      emits "DNAMethylated"
    end

    Splice do
      role "System"
      description "Remove introns and join exons from pre-mRNA — post-transcriptional processing"
      reference_to(DNA)
      String :gene_name
      String :exons_retained
      emits "RNASpliced"
    end
  end

  # === Protein ===

  aggregate "Protein", "A folded chain of amino acids — the workhorse molecule of the cell" do
    String :name
    String :sequence
    Integer :length
    String :primary_structure
    String :secondary_structure
    String :tertiary_structure
    String :quaternary_structure
    String :function
    String :folding_state
    String :active
    list_of(AminoAcid) :amino_acids

    value_object "AminoAcid" do
      String :name
      String :abbreviation
      Integer :position
      String :hydrophobic
      String :charge
    end

    value_object "ActiveSite" do
      String :residues
      String :substrate
      String :specificity
    end

    Synthesize do
      role "System"
      description "Build a protein on the ribosome — translate mRNA to amino acid chain"
      String :name
      String :sequence
      String :function
      emits "ProteinSynthesized"
      then_set :name, to: :name
      then_set :sequence, to: :sequence
      then_set :function, to: :function
      then_set :folding_state, to: "unfolded"
      then_set :active, to: "false"
    end

    Fold do
      role "System"
      description "Achieve native conformation — chaperone-assisted or spontaneous folding"
      reference_to(Protein)
      String :secondary_structure
      String :tertiary_structure
      given { folding_state == "unfolded" }
      emits "ProteinFolded"
      then_set :secondary_structure, to: :secondary_structure
      then_set :tertiary_structure, to: :tertiary_structure
      then_set :folding_state, to: "folded"
      then_set :active, to: "true"
    end

    Denature do
      role "System"
      description "Unfold due to heat, pH, or chemical stress — lose 3D structure"
      reference_to(Protein)
      String :cause
      given { folding_state == "folded" }
      emits "ProteinDenatured"
      then_set :folding_state, to: "denatured"
      then_set :active, to: "false"
    end

    Catalyze do
      role "System"
      description "Enzyme action — lower activation energy and convert substrate to product"
      reference_to(Protein)
      String :substrate
      String :product
      given { active == "true" }
      given { function == "enzyme" }
      emits "ReactionCatalyzed"
    end

    Phosphorylate do
      role "System"
      description "Add phosphate group — kinase-mediated activation or deactivation"
      reference_to(Protein)
      String :site
      String :kinase
      emits "ProteinPhosphorylated"
    end

    Bind do
      role "System"
      description "Attach to a ligand, receptor, or another protein — molecular recognition"
      reference_to(Protein)
      String :target
      Float :binding_affinity
      emits "ProteinBound"
    end

    lifecycle :folding_state, default: "unfolded" do
      transition "Synthesize" => "unfolded", from: "none"
      transition "Fold" => "folded", from: "unfolded"
      transition "Denature" => "denatured", from: "folded"
      transition "Fold" => "folded", from: "denatured"
    end
  end

  # === Organism ===

  aggregate "Organism", "A living being — classified by taxonomy, shaped by traits, driven by evolution" do
    String :species_name
    String :common_name
    String :domain
    String :kingdom
    String :phylum
    String :class_name
    String :order
    String :family
    String :genus
    list_of(Trait) :traits
    Float :fitness
    Integer :generation
    String :alive

    value_object "Trait" do
      String :name
      String :value
      String :heritable
      String :dominant
    end

    value_object "Taxonomy" do
      String :domain
      String :kingdom
      String :phylum
      String :class_name
      String :order
      String :family
      String :genus
      String :species
    end

    Classify do
      role "Biologist"
      description "Place an organism in the Linnaean hierarchy — domain through species"
      String :species_name
      String :common_name
      String :domain
      String :kingdom
      String :phylum
      emits "OrganismClassified"
      then_set :species_name, to: :species_name
      then_set :common_name, to: :common_name
      then_set :domain, to: :domain
      then_set :kingdom, to: :kingdom
      then_set :phylum, to: :phylum
      then_set :alive, to: "true"
      then_set :generation, to: 1
    end

    Evolve do
      role "System"
      description "Accumulate heritable changes across generations — driven by selection pressure"
      reference_to(Organism)
      String :trait_name
      String :new_value
      String :mechanism
      emits "OrganismEvolved"
    end

    Adapt do
      role "System"
      description "Express a beneficial trait in response to environmental pressure"
      reference_to(Organism)
      String :pressure
      String :adaptation
      emits "OrganismAdapted"
    end

    Reproduce do
      role "System"
      description "Produce offspring — sexual or asexual reproduction"
      reference_to(Organism)
      String :reproduction_type
      String :mate_id
      given { alive == "true" }
      emits "OrganismReproduced"
    end

    Kill do
      role "System"
      description "The organism dies — natural causes, predation, or disease"
      reference_to(Organism)
      String :cause
      emits "OrganismDied"
      then_set :alive, to: "false"
    end
  end

  # === Ecosystem ===

  aggregate "Ecosystem", "A community of organisms and their environment — energy flows, matter cycles" do
    String :name
    String :biome
    Float :area
    list_of(Population) :populations
    list_of(TrophicLevel) :trophic_levels
    Float :energy_input
    Float :biodiversity_index
    String :status

    value_object "Population" do
      String :species_name
      Integer :count
      Float :growth_rate
      Integer :carrying_capacity
      String :trophic_level
    end

    value_object "TrophicLevel" do
      Integer :level
      String :name
      Float :energy_available
      Integer :species_count
    end

    value_object "FoodWebLink" do
      String :predator
      String :prey
      Float :energy_transfer
    end

    EstablishEcosystem do
      role "Ecologist"
      description "Define a new ecosystem — biome, area, initial energy input"
      String :name
      String :biome
      Float :area
      Float :energy_input
      emits "EcosystemEstablished"
      then_set :name, to: :name
      then_set :biome, to: :biome
      then_set :area, to: :area
      then_set :energy_input, to: :energy_input
      then_set :status, to: "nascent"
    end

    AddSpecies do
      role "Ecologist"
      description "Introduce a species population to the ecosystem"
      reference_to(Ecosystem)
      String :species_name
      Integer :initial_count
      String :trophic_level
      emits "SpeciesAdded"
    end

    TrackPopulation do
      role "Ecologist"
      description "Record population size change — growth, decline, or stable"
      reference_to(Ecosystem)
      String :species_name
      Integer :new_count
      Float :growth_rate
      emits "PopulationTracked"
    end

    ModelFoodWeb do
      role "Ecologist"
      description "Map predator-prey relationships and energy transfer between trophic levels"
      reference_to(Ecosystem)
      emits "FoodWebModeled"
    end

    MeasureBiodiversity do
      role "Ecologist"
      description "Calculate species richness and evenness — Shannon or Simpson index"
      reference_to(Ecosystem)
      Float :biodiversity_index
      emits "BiodiversityMeasured"
      then_set :biodiversity_index, to: :biodiversity_index
    end

    RemoveSpecies do
      role "System"
      description "A species goes locally extinct — cascading effects on the food web"
      reference_to(Ecosystem)
      String :species_name
      String :cause
      emits "SpeciesRemoved"
    end

    lifecycle :status, default: "nascent" do
      transition "EstablishEcosystem" => "nascent", from: "pending"
      transition "AddSpecies" => "developing", from: "nascent"
      transition "ModelFoodWeb" => "stable", from: "developing"
      transition "RemoveSpecies" => "disturbed", from: "stable"
    end
  end

  # === Genetics (Inheritance) ===

  aggregate "Genetics", "Heredity and variation — how traits pass from parent to offspring" do
    String :organism_name
    String :genotype
    String :phenotype
    Integer :chromosome_count
    list_of(Allele) :alleles
    String :ploidy
    String :genome_mapped

    value_object "Allele" do
      String :gene_name
      String :variant
      String :dominant
      String :locus
      String :expression
    end

    value_object "PunnettResult" do
      String :cross_type
      String :parent_a_genotype
      String :parent_b_genotype
      String :offspring_ratios
    end

    DefineGenotype do
      role "Geneticist"
      description "Record the genetic makeup of an organism — alleles at each locus"
      String :organism_name
      String :genotype
      String :ploidy
      emits "GenotypeDefined"
      then_set :organism_name, to: :organism_name
      then_set :genotype, to: :genotype
      then_set :ploidy, to: :ploidy
      then_set :genome_mapped, to: "false"
    end

    CrossBreed do
      role "Geneticist"
      description "Mendelian cross — combine alleles from two parents to predict offspring"
      reference_to(Genetics)
      String :mate_genotype
      String :cross_type
      emits "CrossPerformed"
    end

    ExpressGene do
      role "System"
      description "Translate genotype to phenotype — dominance, codominance, epistasis"
      reference_to(Genetics)
      String :gene_name
      String :phenotype
      emits "GeneExpressed"
      then_set :phenotype, to: :phenotype
    end

    MapGenome do
      role "Geneticist"
      description "Determine locations of all genes on chromosomes — linkage analysis"
      reference_to(Genetics)
      Integer :chromosome_count
      emits "GenomeMapped"
      then_set :chromosome_count, to: :chromosome_count
      then_set :genome_mapped, to: "true"
    end

    IdentifyTrait do
      role "Geneticist"
      description "Link a phenotypic trait to its underlying allele combination"
      reference_to(Genetics)
      String :trait_name
      String :allele_combination
      emits "TraitIdentified"
    end

    DetectMutation do
      role "Geneticist"
      description "Find a genetic variant that differs from the reference — SNP, indel, CNV"
      reference_to(Genetics)
      String :gene_name
      String :mutation_type
      String :effect
      emits "MutationDetected"
    end
  end

  # === Evolution ===

  aggregate "Evolution", "Change in heritable traits over generations — the engine of biodiversity" do
    String :lineage_name
    Integer :generation_count
    String :selection_pressure
    String :fitness_landscape
    Integer :speciation_events
    list_of(Adaptation) :adaptation_history
    Float :divergence_time

    value_object "Adaptation" do
      String :trait
      String :pressure
      Integer :generation_acquired
      Float :fitness_delta
    end

    value_object "SelectionEvent" do
      String :type
      String :trait_favored
      Float :survivors_fraction
      Integer :generation
    end

    TrackLineage do
      role "Biologist"
      description "Begin tracking an evolutionary lineage through time"
      String :lineage_name
      String :selection_pressure
      emits "LineageTracked"
      then_set :lineage_name, to: :lineage_name
      then_set :selection_pressure, to: :selection_pressure
      then_set :generation_count, to: 1
      then_set :speciation_events, to: 0
    end

    SelectFittest do
      role "System"
      description "Natural selection — differential survival based on fitness"
      reference_to(Evolution)
      String :trait_favored
      Float :survivors_fraction
      emits "FittestSelected"
    end

    Speciate do
      role "System"
      description "One lineage splits into two — allopatric, sympatric, or parapatric"
      reference_to(Evolution)
      String :mechanism
      String :new_species_name
      String :barrier
      emits "SpeciationOccurred"
    end

    TrackAdaptation do
      role "Biologist"
      description "Record an adaptation event — trait, selection pressure, fitness change"
      reference_to(Evolution)
      String :trait
      String :pressure
      Float :fitness_delta
      emits "AdaptationTracked"
    end

    DateDivergence do
      role "Biologist"
      description "Estimate when two lineages split — molecular clock, fossil calibration"
      reference_to(Evolution)
      String :sister_lineage
      Float :divergence_time
      String :method
      emits "DivergenceDated"
      then_set :divergence_time, to: :divergence_time
    end

    MeasureDrift do
      role "System"
      description "Random changes in allele frequency — genetic drift in small populations"
      reference_to(Evolution)
      Integer :population_size
      String :allele
      Float :frequency_change
      emits "DriftMeasured"
    end
  end

  # === Neuroscience ===

  aggregate "Neuron", "The signaling cell of the nervous system — electrical impulse meets chemical message" do
    String :neuron_type
    String :name
    Float :resting_potential
    Float :threshold
    Float :current_potential
    String :state
    String :neurotransmitter
    list_of(Synapse) :synapses
    Integer :dendrite_count

    value_object "Synapse" do
      String :pre_neuron
      String :post_neuron
      String :neurotransmitter
      Float :strength
      String :type
    end

    value_object "Neurotransmitter" do
      String :name
      String :type
      String :receptor
      String :effect
    end

    CreateNeuron do
      role "Neuroscientist"
      description "Define a neuron with its type, threshold, and resting potential"
      String :neuron_type
      String :name
      Float :resting_potential
      Float :threshold
      String :neurotransmitter
      emits "NeuronCreated"
      then_set :neuron_type, to: :neuron_type
      then_set :name, to: :name
      then_set :resting_potential, to: :resting_potential
      then_set :threshold, to: :threshold
      then_set :neurotransmitter, to: :neurotransmitter
      then_set :state, to: "resting"
      then_set :current_potential, to: :resting_potential
    end

    FireNeuron do
      role "System"
      description "Generate an action potential — all-or-nothing depolarization"
      reference_to(Neuron)
      Float :stimulus_strength
      given { state == "resting" }
      emits "NeuronFired"
      then_set :state, to: "firing"
    end

    Depolarize do
      role "System"
      description "Na+ channels open — membrane potential rises toward threshold"
      reference_to(Neuron)
      Float :potential_change
      emits "NeuronDepolarized"
    end

    Repolarize do
      role "System"
      description "K+ channels open — membrane potential returns to resting"
      reference_to(Neuron)
      emits "NeuronRepolarized"
      then_set :state, to: "refractory"
    end

    ReleaseSynapse do
      role "System"
      description "Vesicles fuse with presynaptic membrane — neurotransmitter floods the cleft"
      reference_to(Neuron)
      String :target_neuron
      Float :amount
      given { state == "firing" }
      emits "SynapseReleased"
    end

    PropagateSignal do
      role "System"
      description "Action potential travels along axon — saltatory or continuous conduction"
      reference_to(Neuron)
      String :conduction_type
      Float :velocity
      emits "SignalPropagated"
    end

    FormMemory do
      role "System"
      description "Strengthen synaptic connection — long-term potentiation"
      reference_to(Neuron)
      String :synapse_target
      Float :strength_increase
      emits "MemoryFormed"
    end

    Inhibit do
      role "System"
      description "Hyperpolarize — inhibitory postsynaptic potential prevents firing"
      reference_to(Neuron)
      String :inhibitor
      emits "NeuronInhibited"
      then_set :state, to: "inhibited"
    end

    lifecycle :state, default: "resting" do
      transition "CreateNeuron" => "resting", from: "none"
      transition "FireNeuron" => "firing", from: "resting"
      transition "Repolarize" => "refractory", from: "firing"
      transition "Inhibit" => "inhibited", from: "resting"
      transition "Depolarize" => "resting", from: "refractory"
      transition "Depolarize" => "resting", from: "inhibited"
    end
  end

  # === Immunology ===

  aggregate "ImmuneResponse", "The body's defense — recognition, attack, memory" do
    String :pathogen_name
    String :pathogen_type
    String :response_type
    String :antibody_generated
    String :severity
    String :status
    list_of(ImmuneCell) :immune_cells
    String :memory_formed

    value_object "ImmuneCell" do
      String :cell_type
      Integer :count
      String :active
      String :target
    end

    value_object "Antibody" do
      String :name
      String :isotype
      String :target_antigen
      Float :affinity
    end

    value_object "Antigen" do
      String :name
      String :source
      String :epitope
      String :recognized
    end

    DetectPathogen do
      role "System"
      description "Innate immune system recognizes foreign material — pattern recognition receptors"
      String :pathogen_name
      String :pathogen_type
      String :severity
      emits "PathogenDetected"
      then_set :pathogen_name, to: :pathogen_name
      then_set :pathogen_type, to: :pathogen_type
      then_set :severity, to: :severity
      then_set :status, to: "detected"
      then_set :memory_formed, to: "false"
    end

    MountResponse do
      role "System"
      description "Activate immune cascade — innate first, adaptive if needed"
      reference_to(ImmuneResponse)
      String :response_type
      given { status == "detected" }
      emits "ResponseMounted"
      then_set :response_type, to: :response_type
      then_set :status, to: "active"
    end

    GenerateAntibody do
      role "System"
      description "B cells produce antibodies specific to the detected antigen"
      reference_to(ImmuneResponse)
      String :antibody_name
      String :isotype
      given { response_type == "adaptive" }
      emits "AntibodyGenerated"
      then_set :antibody_generated, to: :antibody_name
    end

    RememberPathogen do
      role "System"
      description "Form immunological memory — memory B and T cells for faster future response"
      reference_to(ImmuneResponse)
      given { status == "resolved" }
      emits "PathogenRemembered"
      then_set :memory_formed, to: "true"
    end

    Engulf do
      role "System"
      description "Phagocytosis — macrophage or neutrophil engulfs and destroys pathogen"
      reference_to(ImmuneResponse)
      String :cell_type
      String :target
      emits "PathogenEngulfed"
    end

    ResolveInfection do
      role "System"
      description "Pathogen cleared — inflammation subsides, tissue repair begins"
      reference_to(ImmuneResponse)
      given { status == "active" }
      emits "InfectionResolved"
      then_set :status, to: "resolved"
    end

    lifecycle :status, default: "clear" do
      transition "DetectPathogen" => "detected", from: "clear"
      transition "MountResponse" => "active", from: "detected"
      transition "ResolveInfection" => "resolved", from: "active"
      transition "RememberPathogen" => "immune", from: "resolved"
    end
  end

  # === Metabolism ===

  aggregate "Metabolism", "The sum of chemical reactions sustaining life — energy capture, conversion, use" do
    String :organism_name
    String :pathway_name
    String :pathway_type
    Float :atp_produced
    Float :atp_consumed
    Float :net_atp
    list_of(Enzyme) :enzymes
    list_of(Substrate) :substrates
    String :regulated
    String :status

    value_object "Enzyme" do
      String :name
      String :reaction
      Float :km
      Float :vmax
      String :inhibitor
    end

    value_object "Substrate" do
      String :name
      Float :concentration
      String :role
    end

    value_object "ATPBalance" do
      Float :produced
      Float :consumed
      Float :net
    end

    InitiatePathway do
      role "Biologist"
      description "Start a metabolic pathway — glycolysis, Krebs cycle, electron transport"
      String :organism_name
      String :pathway_name
      String :pathway_type
      emits "PathwayInitiated"
      then_set :organism_name, to: :organism_name
      then_set :pathway_name, to: :pathway_name
      then_set :pathway_type, to: :pathway_type
      then_set :atp_produced, to: 0.0
      then_set :atp_consumed, to: 0.0
      then_set :status, to: "active"
    end

    CatalyzeReaction do
      role "System"
      description "Enzyme converts substrate to product — one step in the pathway"
      reference_to(Metabolism)
      String :enzyme_name
      String :substrate
      String :product
      given { status == "active" }
      emits "ReactionCatalyzed"
    end

    ProduceATP do
      role "System"
      description "Generate ATP — oxidative phosphorylation or substrate-level phosphorylation"
      reference_to(Metabolism)
      Float :amount
      String :mechanism
      emits "ATPProduced"
    end

    RegulatePathway do
      role "System"
      description "Allosteric regulation, feedback inhibition, or hormonal control"
      reference_to(Metabolism)
      String :regulator
      String :effect
      String :target_enzyme
      emits "PathwayRegulated"
      then_set :regulated, to: "true"
    end

    FermentGlucose do
      role "System"
      description "Anaerobic respiration — glucose to ethanol or lactate without oxygen"
      reference_to(Metabolism)
      String :fermentation_type
      Float :atp_yield
      emits "GlucoseFermented"
    end

    Oxidize do
      role "System"
      description "Remove electrons from a substrate — NAD+ to NADH, FAD to FADH2"
      reference_to(Metabolism)
      String :substrate
      String :electron_carrier
      emits "SubstrateOxidized"
    end

    CompletePathway do
      role "System"
      description "All steps of the metabolic pathway have been executed"
      reference_to(Metabolism)
      given { status == "active" }
      emits "PathwayCompleted"
      then_set :status, to: "complete"
    end

    lifecycle :status, default: "inactive" do
      transition "InitiatePathway" => "active", from: "inactive"
      transition "RegulatePathway" => "regulated", from: "active"
      transition "CompletePathway" => "complete", from: "active"
    end
  end

  # === Policies ===

  policy "SynthesizeProteinOnTranscription" do
    on "GeneTranscribed"
    trigger "Synthesize"
  end

  policy "FoldOnSynthesis" do
    on "ProteinSynthesized"
    trigger "Fold"
  end

  policy "MountResponseOnDetection" do
    on "PathogenDetected"
    trigger "MountResponse"
  end

  policy "GenerateAntibodyOnAdaptive" do
    on "ResponseMounted"
    trigger "GenerateAntibody"
  end

  policy "RememberOnResolution" do
    on "InfectionResolved"
    trigger "RememberPathogen"
  end

  policy "RepairOnMutation" do
    on "DNAMutated"
    trigger "RepairDNA"
  end

  policy "ExpressGeneOnSplice" do
    on "RNASpliced"
    trigger "ExpressGene"
  end

  policy "ModelFoodWebOnSpeciesAdded" do
    on "SpeciesAdded"
    trigger "ModelFoodWeb"
  end

  policy "ReleaseSynapseOnFire" do
    on "NeuronFired"
    trigger "ReleaseSynapse"
  end

  policy "PropagateOnFire" do
    on "NeuronFired"
    trigger "PropagateSignal"
  end

  policy "RepolarizeAfterFire" do
    on "SignalPropagated"
    trigger "Repolarize"
  end

  policy "ProduceATPOnCatalyze" do
    on "ReactionCatalyzed"
    trigger "ProduceATP"
  end

  policy "MetabolizeOnDivide" do
    on "CellDivided"
    trigger "Metabolize"
  end

  policy "TrackAdaptationOnSelection" do
    on "FittestSelected"
    trigger "TrackAdaptation"
  end

  policy "MeasureBiodiversityOnRemoval" do
    on "SpeciesRemoved"
    trigger "MeasureBiodiversity"
  end

  # === Fixtures ===

  # Cells
  fixture "Cell", cell_type: "eukaryotic", name: "Human Epithelial Cell", organism_type: "Homo sapiens", phase: "interphase", energy_level: 100.0, membrane_integrity: 1.0
  fixture "Cell", cell_type: "prokaryotic", name: "E. coli", organism_type: "Escherichia coli", phase: "interphase", energy_level: 80.0, membrane_integrity: 1.0
  fixture "Cell", cell_type: "stem", name: "Hematopoietic Stem Cell", organism_type: "Homo sapiens", phase: "interphase", energy_level: 100.0, membrane_integrity: 1.0

  # DNA
  fixture "DNA", sequence: "ATGCGATCGATCG", strand_type: "double", organism: "Homo sapiens", integrity: 1.0
  fixture "DNA", sequence: "ATGAAAGGGCCC", strand_type: "double", organism: "Escherichia coli", integrity: 1.0

  # Proteins
  fixture "Protein", name: "Hemoglobin", sequence: "MVLSPADKTNVKAAWGKVGAHAGEYGAEALERMFLSFPTTKTYFPHFDLSH", function: "oxygen_transport", folding_state: "folded", active: "true"
  fixture "Protein", name: "Insulin", sequence: "MALWMRLLPLLALLALWGPDPAAAFVNQHLCGSHLVEALYLVCGERGFFYTPKT", function: "hormone", folding_state: "folded", active: "true"
  fixture "Protein", name: "Lysozyme", sequence: "MKALIVLGLVLLSVTVQGKVFGRCELAA", function: "enzyme", folding_state: "folded", active: "true"

  # Organisms
  fixture "Organism", species_name: "Homo sapiens", common_name: "Human", domain: "Eukarya", kingdom: "Animalia", phylum: "Chordata", alive: "true", generation: 1
  fixture "Organism", species_name: "Escherichia coli", common_name: "E. coli", domain: "Bacteria", kingdom: "Eubacteria", phylum: "Proteobacteria", alive: "true", generation: 1
  fixture "Organism", species_name: "Arabidopsis thaliana", common_name: "Thale cress", domain: "Eukarya", kingdom: "Plantae", phylum: "Magnoliophyta", alive: "true", generation: 1
  fixture "Organism", species_name: "Drosophila melanogaster", common_name: "Fruit fly", domain: "Eukarya", kingdom: "Animalia", phylum: "Arthropoda", alive: "true", generation: 1

  # Ecosystems
  fixture "Ecosystem", name: "Amazon Rainforest", biome: "tropical_rainforest", area: 5500000.0, energy_input: 2200.0, status: "stable"
  fixture "Ecosystem", name: "Great Barrier Reef", biome: "coral_reef", area: 344400.0, energy_input: 1800.0, status: "stable"

  # Neurons
  fixture "Neuron", neuron_type: "motor", name: "Alpha Motor Neuron", resting_potential: -70.0, threshold: -55.0, current_potential: -70.0, state: "resting", neurotransmitter: "acetylcholine"
  fixture "Neuron", neuron_type: "sensory", name: "Dorsal Root Ganglion", resting_potential: -65.0, threshold: -50.0, current_potential: -65.0, state: "resting", neurotransmitter: "glutamate"
  fixture "Neuron", neuron_type: "interneuron", name: "Purkinje Cell", resting_potential: -68.0, threshold: -52.0, current_potential: -68.0, state: "resting", neurotransmitter: "GABA"

  # Metabolism pathways
  fixture "Metabolism", organism_name: "Homo sapiens", pathway_name: "Glycolysis", pathway_type: "catabolic", atp_produced: 2.0, atp_consumed: 2.0, net_atp: 2.0, status: "active"
  fixture "Metabolism", organism_name: "Homo sapiens", pathway_name: "Krebs Cycle", pathway_type: "catabolic", atp_produced: 2.0, atp_consumed: 0.0, net_atp: 2.0, status: "active"
  fixture "Metabolism", organism_name: "Saccharomyces cerevisiae", pathway_name: "Alcoholic Fermentation", pathway_type: "catabolic", atp_produced: 2.0, atp_consumed: 2.0, net_atp: 2.0, status: "active"
end
