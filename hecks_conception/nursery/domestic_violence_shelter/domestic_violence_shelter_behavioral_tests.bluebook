Hecks.behaviors "DomesticViolenceShelter" do
  vision "Behavioral tests for the DomesticViolenceShelter domain — exercises every command and query in memory"

  # ── Resident aggregate ──────────────────────────────────────────

  test "AdmitResident sets alias_name + intake_date + dependents_count + risk_level" do
    tests "AdmitResident", on: "Resident"
    input  alias_name: "sample", intake_date: "sample", dependents_count: 1, risk_level: "sample"
    expect alias_name: "sample", intake_date: "sample", dependents_count: 1, risk_level: "sample", status: "sheltered"
  end

  test "ReassessRisk sets risk_level" do
    tests "ReassessRisk", on: "Resident"
    setup  "AdmitResident", alias_name: "sample", intake_date: "sample", dependents_count: 1, risk_level: "sample"
    input  resident: 1, risk_level: "sample"
    expect risk_level: "sample"
  end

  test "TransitionToHousing runs" do
    tests "TransitionToHousing", on: "Resident"
    setup  "AdmitResident", alias_name: "sample", intake_date: "sample", dependents_count: 1, risk_level: "sample"
    input  resident: 1
    expect status: "transitioned"
  end


  # ── SafetyPlan aggregate ──────────────────────────────────────────

  test "CreateSafetyPlan sets resident_alias + created_date + emergency_contacts + escape_route" do
    tests "CreateSafetyPlan", on: "SafetyPlan"
    setup  "AdmitResident", alias_name: "sample", intake_date: "sample", dependents_count: 1, risk_level: "sample"
    input  resident: 1, resident_alias: "sample", created_date: "sample", emergency_contacts: "sample", escape_route: "sample"
    expect resident_alias: "sample", created_date: "sample", emergency_contacts: "sample", escape_route: "sample", status: "active"
  end

  test "AddSafetyStep sets scenario + action + resources_needed + priority" do
    tests "AddSafetyStep", on: "SafetyPlan"
    input  safety_plan: 1, scenario: "sample", action: "sample", resources_needed: "sample", priority: 1
    expect ok: "true"
  end

  test "ReviewSafetyPlan runs" do
    tests "ReviewSafetyPlan", on: "SafetyPlan"
    input  safety_plan: 1
    expect ok: "true"
  end


  # ── SupportService aggregate ──────────────────────────────────────────

  test "RegisterService sets service_name + service_type + provider_name + availability" do
    tests "RegisterService", on: "SupportService"
    input  service_name: "sample", service_type: "sample", provider_name: "sample", availability: "sample"
    expect service_name: "sample", service_type: "sample", provider_name: "sample", availability: "sample", status: "active"
  end

  test "ReferToService runs" do
    tests "ReferToService", on: "SupportService"
    setup  "RegisterService", service_name: "sample", service_type: "sample", provider_name: "sample", availability: "sample"
    input  support_service: 1
    expect ok: "true"
  end

  test "SuspendService runs" do
    tests "SuspendService", on: "SupportService"
    setup  "RegisterService", service_name: "sample", service_type: "sample", provider_name: "sample", availability: "sample"
    input  support_service: 1
    expect status: "suspended"
  end


  # ── Advocate aggregate ──────────────────────────────────────────

  test "OnboardAdvocate sets name + role_type + certification" do
    tests "OnboardAdvocate", on: "Advocate"
    input  name: "sample", role_type: "sample", certification: "sample"
    expect name: "sample", role_type: "sample", certification: "sample", active_cases: 0, status: "active"
  end

  test "AssignResident runs" do
    tests "AssignResident", on: "Advocate"
    setup  "OnboardAdvocate", name: "sample", role_type: "sample", certification: "sample"
    input  advocate: 1
    expect ok: "true"
  end


  # ── ExitPlan aggregate ──────────────────────────────────────────

  test "CreateExitPlan sets resident_alias + target_exit_date + housing_arrangement + employment_status" do
    tests "CreateExitPlan", on: "ExitPlan"
    setup  "AdmitResident", alias_name: "sample", intake_date: "sample", dependents_count: 1, risk_level: "sample"
    input  resident: 1, resident_alias: "sample", target_exit_date: "sample", housing_arrangement: "sample", employment_status: "sample"
    expect resident_alias: "sample", target_exit_date: "sample", housing_arrangement: "sample", employment_status: "sample", status: "in_progress"
  end

  test "CompleteExitTask sets task_description" do
    tests "CompleteExitTask", on: "ExitPlan"
    input  exit_plan: 1, task_description: "sample"
    expect ok: "true"
  end

  test "FinalizeExit runs" do
    tests "FinalizeExit", on: "ExitPlan"
    setup  "CreateExitPlan", resident: 1, resident_alias: "sample", target_exit_date: "sample", housing_arrangement: "sample", employment_status: "sample"
    input  exit_plan: 1
    expect status: "finalized"
  end

end
