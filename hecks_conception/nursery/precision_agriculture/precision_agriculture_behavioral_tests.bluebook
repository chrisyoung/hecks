Hecks.behaviors "PrecisionAgriculture" do
  vision "Behavioral tests for the PrecisionAgriculture domain — exercises every command and query in memory"

  # ── WeatherStation aggregate ──────────────────────────────────────────

  test "DeployStation sets station_id + latitude + longitude" do
    tests "DeployStation", on: "WeatherStation"
    input  station_id: "sample", latitude: 1.0, longitude: 1.0
    expect ok: "true"
  end

  test "RecordReading sets metric + value + recorded_at" do
    tests "RecordReading", on: "WeatherStation"
    setup  "DeployStation", station_id: "sample", latitude: 1.0, longitude: 1.0
    input  weather_station: 1, metric: "sample", value: 1.0, recorded_at: "sample"
    expect readings_size: 1
  end


  # ── Forecast aggregate ──────────────────────────────────────────

  test "GenerateForecast sets forecast_date" do
    tests "GenerateForecast", on: "Forecast"
    setup  "DeployStation", station_id: "sample", latitude: 1.0, longitude: 1.0
    input  weather_station: 1, forecast_date: "sample"
    expect ok: "true"
  end

  test "AddPrediction sets hour + temp_c + precip_mm + wind_kph" do
    tests "AddPrediction", on: "Forecast"
    setup  "AddPrediction", hour: "sample", temp_c: 1.0, precip_mm: 1.0, wind_kph: 1.0
    input  forecast: 1, hour: "sample", temp_c: 1.0, precip_mm: 1.0, wind_kph: 1.0
    expect predictions_size: 1
  end

  test "PublishForecast runs" do
    tests "PublishForecast", on: "Forecast"
    setup  "AddPrediction", hour: "sample", temp_c: 1.0, precip_mm: 1.0, wind_kph: 1.0
    input  forecast: 1
    expect ok: "true"
  end


  # ── CropField aggregate ──────────────────────────────────────────

  test "PlantField sets field_name + crop + acres" do
    tests "PlantField", on: "CropField"
    input  field_name: "sample", crop: "sample", acres: 1.0
    expect ok: "true"
  end

  test "SampleSoil sets ph + nitrogen_ppm + phosphorus_ppm" do
    tests "SampleSoil", on: "CropField"
    setup  "PlantField", field_name: "sample", crop: "sample", acres: 1.0
    input  crop_field: 1, ph: 1.0, nitrogen_ppm: 1.0, phosphorus_ppm: 1.0
    expect soil_samples_size: 1
  end


  # ── IrrigationPlan aggregate ──────────────────────────────────────────

  test "DraftPlan sets water_gallons" do
    tests "DraftPlan", on: "IrrigationPlan"
    setup  "PlantField", field_name: "sample", crop: "sample", acres: 1.0
    setup  "AddPrediction", hour: "sample", temp_c: 1.0, precip_mm: 1.0, wind_kph: 1.0
    input  crop_field: 1, forecast: 1, water_gallons: 1.0
    expect ok: "true"
  end

  test "AddZone sets zone_name + gallons_per_day" do
    tests "AddZone", on: "IrrigationPlan"
    setup  "AddZone", zone_name: "sample", gallons_per_day: 1.0
    input  irrigation_plan: 1, zone_name: "sample", gallons_per_day: 1.0
    expect zones_size: 1
  end

  test "ActivatePlan runs" do
    tests "ActivatePlan", on: "IrrigationPlan"
    setup  "AddZone", zone_name: "sample", gallons_per_day: 1.0
    input  irrigation_plan: 1
    expect ok: "true"
  end


  # ── HarvestSchedule aggregate ──────────────────────────────────────────

  test "PlanHarvest sets target_date + crew_size" do
    tests "PlanHarvest", on: "HarvestSchedule"
    setup  "PlantField", field_name: "sample", crop: "sample", acres: 1.0
    setup  "AddPrediction", hour: "sample", temp_c: 1.0, precip_mm: 1.0, wind_kph: 1.0
    input  crop_field: 1, forecast: 1, target_date: "sample", crew_size: 1
    expect ok: "true"
  end

  test "ExecuteHarvest runs" do
    tests "ExecuteHarvest", on: "HarvestSchedule"
    input  harvest_schedule: 1
    expect ok: "true"
  end

end
