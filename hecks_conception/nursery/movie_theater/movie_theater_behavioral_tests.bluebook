Hecks.behaviors "MovieTheater" do
  vision "Behavioral tests for the MovieTheater domain — exercises every command and query in memory"

  # ── Screen aggregate ──────────────────────────────────────────

  test "SetupScreen sets screen_number + seat_count + sound_format" do
    tests "SetupScreen", on: "Screen"
    input  screen_number: "sample", seat_count: 1, sound_format: "sample"
    expect status: "active"
  end

  test "CloseScreen sets reason" do
    tests "CloseScreen", on: "Screen"
    setup  "SetupScreen", screen_number: "sample", seat_count: 1, sound_format: "sample"
    input  screen: 1, reason: "sample"
    expect status: "closed"
  end


  # ── Showing aggregate ──────────────────────────────────────────

  test "ScheduleShowing sets film_title + showtime + rating" do
    tests "ScheduleShowing", on: "Showing"
    setup  "SetupScreen", screen_number: "sample", seat_count: 1, sound_format: "sample"
    input  screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    expect status: "scheduled"
  end

  test "OpenSales runs" do
    tests "OpenSales", on: "Showing"
    setup  "ScheduleShowing", screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    input  showing: 1
    expect status: "on_sale"
  end

  test "SellTicket sets patron_name + seat_number" do
    tests "SellTicket", on: "Showing"
    input  showing: 1, patron_name: "sample", seat_number: "sample"
    expect ok: "true"
  end

  test "OpenDoors runs" do
    tests "OpenDoors", on: "Showing"
    setup  "ScheduleShowing", screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    setup  "OpenSales", showing: 1
    input  showing: 1
    expect status: "seating"
  end

  test "StartProjection runs" do
    tests "StartProjection", on: "Showing"
    setup  "ScheduleShowing", screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    setup  "OpenSales", showing: 1
    setup  "OpenDoors", showing: 1
    input  showing: 1
    expect status: "in_progress"
  end

  test "EndShowing runs" do
    tests "EndShowing", on: "Showing"
    setup  "ScheduleShowing", screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    setup  "OpenSales", showing: 1
    setup  "OpenDoors", showing: 1
    setup  "StartProjection", showing: 1
    input  showing: 1
    expect status: "ended"
  end

  test "ClearAuditorium runs" do
    tests "ClearAuditorium", on: "Showing"
    setup  "ScheduleShowing", screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    setup  "OpenSales", showing: 1
    setup  "OpenDoors", showing: 1
    setup  "StartProjection", showing: 1
    setup  "EndShowing", showing: 1
    input  showing: 1
    expect status: "cleared"
  end

  test "CancelShowing sets reason" do
    tests "CancelShowing", on: "Showing"
    setup  "ScheduleShowing", screen: 1, film_title: "sample", showtime: "sample", rating: "sample"
    input  showing: 1, reason: "sample"
    expect status: "cancelled"
  end


  # ── Concession aggregate ──────────────────────────────────────────

  test "StockConcession sets item_name + price_cents + stock_count + category" do
    tests "StockConcession", on: "Concession"
    input  item_name: "sample", price_cents: 1, stock_count: 1, category: "sample"
    expect ok: "true"
  end

  test "SellConcession sets quantity" do
    tests "SellConcession", on: "Concession"
    setup  "StockConcession", item_name: "sample", price_cents: 1, stock_count: 1, category: "sample"
    input  concession: 1, quantity: 1
    expect ok: "true"
  end


  # ── Projector aggregate ──────────────────────────────────────────

  test "InstallProjector sets projector_id + technology" do
    tests "InstallProjector", on: "Projector"
    input  projector_id: "sample", technology: "sample"
    expect status: "operational", lamp_hours: 0
  end

  test "CalibrateProjector runs" do
    tests "CalibrateProjector", on: "Projector"
    setup  "InstallProjector", projector_id: "sample", technology: "sample"
    input  projector: 1
    expect ok: "true"
  end

  test "ReportLampFailure runs" do
    tests "ReportLampFailure", on: "Projector"
    setup  "InstallProjector", projector_id: "sample", technology: "sample"
    input  projector: 1
    expect status: "faulty"
  end

end
