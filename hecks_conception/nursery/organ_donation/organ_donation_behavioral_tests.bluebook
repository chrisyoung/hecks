Hecks.behaviors "OrganDonation" do
  vision "Behavioral tests for the OrganDonation domain — exercises every command and query in memory"

  # ── Donor aggregate ──────────────────────────────────────────

  test "RegisterDonor sets name + blood_type + tissue_type + hospital + cause_of_death + consent_status" do
    tests "RegisterDonor", on: "Donor"
    input  name: "sample", blood_type: "sample", tissue_type: "sample", hospital: "sample", cause_of_death: "sample", consent_status: "sample"
    expect name: "sample", blood_type: "sample", tissue_type: "sample", hospital: "sample", cause_of_death: "sample", consent_status: "sample"
  end

  test "ConfirmConsent runs" do
    tests "ConfirmConsent", on: "Donor"
    setup  "RegisterDonor", name: "sample", blood_type: "sample", tissue_type: "sample", hospital: "sample", cause_of_death: "sample", consent_status: "sample"
    input  donor: 1
    expect consent_status: "confirmed"
  end

  test "AssessOrganViability runs" do
    tests "AssessOrganViability", on: "Donor"
    setup  "RegisterDonor", name: "sample", blood_type: "sample", tissue_type: "sample", hospital: "sample", cause_of_death: "sample", consent_status: "sample"
    input  donor: 1
    expect ok: "true"
  end


  # ── Recipient aggregate ──────────────────────────────────────────

  test "ListRecipient sets name + blood_type + tissue_type + organ_needed + urgency_level + listing_date" do
    tests "ListRecipient", on: "Recipient"
    input  name: "sample", blood_type: "sample", tissue_type: "sample", organ_needed: "sample", urgency_level: "sample", listing_date: "sample"
    expect name: "sample", blood_type: "sample", tissue_type: "sample", organ_needed: "sample", urgency_level: "sample", listing_date: "sample", status: "waiting"
  end

  test "UpdateUrgency sets urgency_level" do
    tests "UpdateUrgency", on: "Recipient"
    setup  "ListRecipient", name: "sample", blood_type: "sample", tissue_type: "sample", organ_needed: "sample", urgency_level: "sample", listing_date: "sample"
    input  recipient: 1, urgency_level: "sample"
    expect urgency_level: "sample"
  end

  test "RemoveFromList runs" do
    tests "RemoveFromList", on: "Recipient"
    setup  "ListRecipient", name: "sample", blood_type: "sample", tissue_type: "sample", organ_needed: "sample", urgency_level: "sample", listing_date: "sample"
    input  recipient: 1
    expect status: "removed"
  end


  # ── OrganMatch aggregate ──────────────────────────────────────────

  test "PerformMatch sets donor_name + recipient_name + organ_name + compatibility_score" do
    tests "PerformMatch", on: "OrganMatch"
    setup  "RegisterDonor", name: "sample", blood_type: "sample", tissue_type: "sample", hospital: "sample", cause_of_death: "sample", consent_status: "sample"
    setup  "ListRecipient", name: "sample", blood_type: "sample", tissue_type: "sample", organ_needed: "sample", urgency_level: "sample", listing_date: "sample"
    input  donor: 1, recipient: 1, donor_name: "sample", recipient_name: "sample", organ_name: "sample", compatibility_score: "sample"
    expect donor_name: "sample", recipient_name: "sample", organ_name: "sample", compatibility_score: "sample", status: "pending_crossmatch"
  end

  test "RecordCrossmatch sets crossmatch_result" do
    tests "RecordCrossmatch", on: "OrganMatch"
    input  organ_match: 1, crossmatch_result: "sample"
    expect crossmatch_result: "sample", status: "crossmatched"
  end

  test "AcceptMatch runs" do
    tests "AcceptMatch", on: "OrganMatch"
    input  organ_match: 1
    expect status: "accepted"
  end


  # ── OrganTransport aggregate ──────────────────────────────────────────

  test "DispatchOrgan sets organ_name + origin_hospital + destination_hospital + transport_method + departure_time + estimated_arrival" do
    tests "DispatchOrgan", on: "OrganTransport"
    input  organ_match: 1, organ_name: "sample", origin_hospital: "sample", destination_hospital: "sample", transport_method: "sample", departure_time: "sample", estimated_arrival: "sample"
    expect organ_name: "sample", origin_hospital: "sample", destination_hospital: "sample", transport_method: "sample", departure_time: "sample", estimated_arrival: "sample", status: "in_transit"
  end

  test "ConfirmDelivery runs" do
    tests "ConfirmDelivery", on: "OrganTransport"
    input  organ_transport: 1
    expect status: "delivered"
  end


  # ── TransplantOutcome aggregate ──────────────────────────────────────────

  test "RecordOutcome sets recipient_name + organ_name + surgery_date + surgeon_name + graft_function + complications" do
    tests "RecordOutcome", on: "TransplantOutcome"
    setup  "ListRecipient", name: "sample", blood_type: "sample", tissue_type: "sample", organ_needed: "sample", urgency_level: "sample", listing_date: "sample"
    input  recipient: 1, recipient_name: "sample", organ_name: "sample", surgery_date: "sample", surgeon_name: "sample", graft_function: "sample", complications: "sample"
    expect recipient_name: "sample", organ_name: "sample", surgery_date: "sample", surgeon_name: "sample", graft_function: "sample", complications: "sample", status: "initial"
  end

  test "UpdateGraftStatus sets graft_function" do
    tests "UpdateGraftStatus", on: "TransplantOutcome"
    input  transplant_outcome: 1, graft_function: "sample"
    expect graft_function: "sample"
  end

end
