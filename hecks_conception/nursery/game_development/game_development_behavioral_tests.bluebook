Hecks.behaviors "GameDevelopment" do
  vision "Behavioral tests for the GameDevelopment domain — exercises every command and query in memory"

  # ── GameProject aggregate ──────────────────────────────────────────

  test "KickOffProject sets title + engine + genre + target_platform" do
    tests "KickOffProject", on: "GameProject"
    input  title: "sample", engine: "sample", genre: "sample", target_platform: "sample"
    expect status: "pre_production"
  end

  test "EnterProduction runs" do
    tests "EnterProduction", on: "GameProject"
    setup  "KickOffProject", title: "sample", engine: "sample", genre: "sample", target_platform: "sample"
    expect status: "production"
  end

  test "ShipGold runs" do
    tests "ShipGold", on: "GameProject"
    setup  "KickOffProject", title: "sample", engine: "sample", genre: "sample", target_platform: "sample"
    setup  "EnterProduction"
    expect status: "gold"
  end


  # ── Sprint aggregate ──────────────────────────────────────────

  test "PlanSprint sets name + duration_days + story_points" do
    tests "PlanSprint", on: "Sprint"
    setup  "KickOffProject", title: "sample", engine: "sample", genre: "sample", target_platform: "sample"
    input  name: "sample", duration_days: 1, story_points: 1
    expect status: "planning"
  end

  test "StartSprint runs" do
    tests "StartSprint", on: "Sprint"
    setup  "PlanSprint", name: "sample", duration_days: 1, story_points: 1
    expect status: "active"
  end

  test "CloseSprint sets completed_points" do
    tests "CloseSprint", on: "Sprint"
    setup  "PlanSprint", name: "sample", duration_days: 1, story_points: 1
    setup  "StartSprint"
    input  completed_points: 1
    expect status: "closed"
  end


  # ── Build aggregate ──────────────────────────────────────────

  test "TriggerBuild sets version + platform + build_config" do
    tests "TriggerBuild", on: "Build"
    setup  "KickOffProject", title: "sample", engine: "sample", genre: "sample", target_platform: "sample"
    input  version: "sample", platform: "sample", build_config: "sample"
    expect status: "building"
  end

  test "CertifyBuild runs" do
    tests "CertifyBuild", on: "Build"
    setup  "TriggerBuild", version: "sample", platform: "sample", build_config: "sample"
    expect status: "certified"
  end


  # ── Playtest aggregate ──────────────────────────────────────────

  test "SchedulePlaytest sets session_name + tester_count" do
    tests "SchedulePlaytest", on: "Playtest"
    setup  "TriggerBuild", version: "sample", platform: "sample", build_config: "sample"
    input  session_name: "sample", tester_count: 1
    expect status: "scheduled"
  end

  test "ConductPlaytest runs" do
    tests "ConductPlaytest", on: "Playtest"
    setup  "SchedulePlaytest", session_name: "sample", tester_count: 1
    expect status: "completed"
  end


  # ── BugReport aggregate ──────────────────────────────────────────

  test "FileBug sets title + severity + repro_steps" do
    tests "FileBug", on: "BugReport"
    setup  "TriggerBuild", version: "sample", platform: "sample", build_config: "sample"
    input  title: "sample", severity: "sample", repro_steps: "sample"
    expect status: "open"
  end

  test "ResolveBug sets resolution" do
    tests "ResolveBug", on: "BugReport"
    setup  "FileBug", title: "sample", severity: "sample", repro_steps: "sample"
    input  resolution: "sample"
    expect status: "resolved"
  end

end
