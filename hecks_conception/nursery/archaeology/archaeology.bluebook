Hecks.bluebook "Archaeology" do
  vision "Manage excavation sites, stratigraphic units, artifacts, dating, and conservation"

  aggregate "ExcavationSite" do
    description "A location where archaeological fieldwork is conducted"
    String :site_code
    String :name
    Float :latitude
    Float :longitude
    String :period_estimate
    TrueClass :trenches_backfilled, default: false

    command "OpenSite" do
      description "Begin excavation at a new archaeological site"
      emits "SiteOpened"
      String :site_code
      String :name
      Float :latitude
      Float :longitude
      then_set :trenches_backfilled, to: true
    end

    command "CloseSite" do
      description "Conclude fieldwork and seal the site"
      emits "SiteClosed"
      reference_to ExcavationSite
      given { trenches_backfilled == true }
    end

    command "AssignDirector" do
      description "Appoint a lead archaeologist for the site"
      emits "DirectorAssigned"
      reference_to ExcavationSite
      String :director_name
    end
  end

  aggregate "StratigraphicUnit" do
    description "A distinct layer of soil or deposit within an excavation trench"
    String :context_number
    String :soil_description
    Float :depth_top_m
    Float :depth_bottom_m
    reference_to ExcavationSite

    value_object "SoilMatrix" do
      String :color_munsell
      String :texture
      String :compaction
      String :inclusions
    end

    command "RecordContext" do
      description "Document a new stratigraphic context"
      emits "ContextRecorded"
      reference_to ExcavationSite
      String :context_number
      String :soil_description
    end

    command "LinkStratigraphy" do
      description "Establish above-below relationships between contexts"
      emits "StratigraphyLinked"
      reference_to StratigraphicUnit
      String :related_context
    end

    command "SampleContext" do
      description "Take a soil sample for environmental analysis"
      emits "ContextSampled"
      reference_to StratigraphicUnit
    end
  end

  aggregate "Artifact" do
    description "A human-made object recovered from excavation"
    String :find_number
    String :material
    String :object_type
    Float :weight_g
    TrueClass :is_organic, default: false
    TrueClass :photographed, default: false
    TrueClass :cataloged, default: false
    reference_to StratigraphicUnit

    command "RegisterFind" do
      description "Log a newly discovered artifact"
      emits "FindRegistered"
      reference_to StratigraphicUnit
      String :find_number
      String :material
      String :object_type
      then_set :is_organic, to: true
      then_set :cataloged, to: true
      then_set :photographed, to: true
    end

    command "PhotographArtifact" do
      description "Capture scaled photography of the artifact"
      emits "ArtifactPhotographed"
      reference_to Artifact
      then_set :photographed, to: true
    end

    command "SendForDating" do
      description "Submit the artifact for radiometric dating"
      emits "DatingRequested"
      reference_to Artifact
      given { is_organic == true }
    end
  end

  aggregate "DatingResult" do
    description "A chronometric date obtained from laboratory analysis"
    String :method
    Integer :date_bp
    Integer :error_margin
    TrueClass :is_radiocarbon, default: false
    reference_to Artifact

    command "SubmitResult" do
      description "Record a dating laboratory result"
      emits "ResultSubmitted"
      reference_to Artifact
      String :method
      Integer :date_bp
      Integer :error_margin
      then_set :is_radiocarbon, to: true
    end

    command "CalibrateDate" do
      description "Apply calibration curve to convert raw date"
      emits "DateCalibrated"
      reference_to DatingResult
      given { is_radiocarbon == true }
    end
  end

  aggregate "ConservationRecord" do
    description "A treatment applied to stabilize or restore an artifact"
    String :record_id
    String :treatment_type
    String :conservator
    String :date_performed
    reference_to Artifact

    command "ConserveArtifact" do
      description "Apply conservation treatment to stabilize the artifact"
      emits "ArtifactConserved"
      reference_to Artifact
      String :treatment_type
      String :conservator
    end

    command "PublishSiteReport" do
      description "Compile and release the final excavation report"
      emits "SiteReportPublished"
      reference_to ExcavationSite
      String :report_title
    end
  end

  lifecycle "ExcavationWorkflow" do
    state "survey"
    state "excavating"
    state "cataloging"
    state "dating"
    state "conserving"
    state "published"
    transition from: "survey", to: "excavating", on: "SiteOpened"
    transition from: "excavating", to: "cataloging", on: "FindRegistered"
    transition from: "cataloging", to: "dating", on: "ArtifactPhotographed"
    transition from: "dating", to: "conserving", on: "DateCalibrated"
    transition from: "conserving", to: "published", on: "SiteReportPublished"
  end

  policy "RecordContextAfterSiteOpened" do
    on "SiteOpened"
    trigger "RecordContext"
  end

  policy "RegisterFindAfterContext" do
    on "ContextRecorded"
    trigger "RegisterFind"
  end

  policy "PhotographAfterRegistration" do
    on "FindRegistered"
    trigger "PhotographArtifact"
  end

  policy "DateAfterPhotograph" do
    on "ArtifactPhotographed"
    trigger "SendForDating"
  end

  policy "CalibrateOnResult" do
    on "ResultSubmitted"
    trigger "CalibrateDate"
  end

  policy "ConserveAfterDating" do
    on "DateCalibrated"
    trigger "ConserveArtifact"
  end

  policy "PublishAfterConservation" do
    on "ArtifactConserved"
    trigger "PublishSiteReport"
  end

end
