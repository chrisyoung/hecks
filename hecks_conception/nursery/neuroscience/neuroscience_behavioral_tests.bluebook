Hecks.behaviors "Neuroscience" do
  vision "Behavioral tests for the Neuroscience domain — exercises every command and query in memory"

  # ── Subject aggregate ──────────────────────────────────────────

  test "EnrollSubject sets subject_id + age + handedness" do
    tests "EnrollSubject", on: "Subject"
    input  subject_id: "sample", age: 1, handedness: "sample"
    expect ok: "true"
  end

  test "WithdrawSubject sets reason" do
    tests "WithdrawSubject", on: "Subject"
    setup  "EnrollSubject", subject_id: "sample", age: 1, handedness: "sample"
    input  subject: 1, reason: "sample"
    expect ok: "true"
  end

  test "ScreenSubject runs" do
    tests "ScreenSubject", on: "Subject"
    setup  "EnrollSubject", subject_id: "sample", age: 1, handedness: "sample"
    input  subject: 1
    expect ok: "true"
  end


  # ── ImagingSession aggregate ──────────────────────────────────────────

  test "StartSession sets modality" do
    tests "StartSession", on: "ImagingSession"
    setup  "EnrollSubject", subject_id: "sample", age: 1, handedness: "sample"
    input  subject: 1, modality: "sample"
    expect ok: "true"
  end

  test "CompleteSession runs" do
    tests "CompleteSession", on: "ImagingSession"
    input  imaging_session: 1
    expect ok: "true"
  end

  test "RejectSession sets rejection_reason" do
    tests "RejectSession", on: "ImagingSession"
    input  imaging_session: 1, rejection_reason: "sample"
    expect ok: "true"
  end


  # ── NeuralSignal aggregate ──────────────────────────────────────────

  test "ExtractSignal sets signal_type + brain_region" do
    tests "ExtractSignal", on: "NeuralSignal"
    input  imaging_session: 1, signal_type: "sample", brain_region: "sample"
    expect ok: "true"
  end

  test "FilterNoise runs" do
    tests "FilterNoise", on: "NeuralSignal"
    input  neural_signal: 1
    expect ok: "true"
  end

  test "ComputeConnectivity runs" do
    tests "ComputeConnectivity", on: "NeuralSignal"
    input  neural_signal: 1
    expect ok: "true"
  end


  # ── StimulusProtocol aggregate ──────────────────────────────────────────

  test "DesignProtocol sets protocol_name + stimulus_type + trial_count" do
    tests "DesignProtocol", on: "StimulusProtocol"
    input  protocol_name: "sample", stimulus_type: "sample", trial_count: 1
    expect ok: "true"
  end

  test "RandomizeTrials runs" do
    tests "RandomizeTrials", on: "StimulusProtocol"
    setup  "DesignProtocol", protocol_name: "sample", stimulus_type: "sample", trial_count: 1
    input  stimulus_protocol: 1
    expect ok: "true"
  end

  test "ValidateTimings runs" do
    tests "ValidateTimings", on: "StimulusProtocol"
    setup  "DesignProtocol", protocol_name: "sample", stimulus_type: "sample", trial_count: 1
    input  stimulus_protocol: 1
    expect ok: "true"
  end


  # ── ResearchPaper aggregate ──────────────────────────────────────────

  test "DraftPaper sets title + target_journal" do
    tests "DraftPaper", on: "ResearchPaper"
    input  neural_signal: 1, title: "sample", target_journal: "sample"
    expect ok: "true"
  end

end
