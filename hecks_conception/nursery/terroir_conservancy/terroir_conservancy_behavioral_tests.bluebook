Hecks.behaviors "TerroirConservancy" do
  vision "Behavioral tests for the TerroirConservancy domain — exercises every command and query in memory"

  # ── ProtectedTerroir aggregate ──────────────────────────────────────────

  test "DesignateTerroir sets terroir_id + name + region + designation_type + total_hectares" do
    tests "DesignateTerroir", on: "ProtectedTerroir"
    input  terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    expect terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1, status: "protected"
  end

  test "AmendProtection runs" do
    tests "AmendProtection", on: "ProtectedTerroir"
    setup  "DesignateTerroir", terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    input  protected_terroir: 1
    expect ok: "true"
  end


  # ── SoilProfile aggregate ──────────────────────────────────────────

  test "CharacterizeSoil sets profile_id + soil_type + ph_level + mineral_composition" do
    tests "CharacterizeSoil", on: "SoilProfile"
    setup  "DesignateTerroir", terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    input  protected_terroir: 1, profile_id: "sample", soil_type: "sample", ph_level: 1.0, mineral_composition: "sample"
    expect profile_id: "sample", terroir: :terroir, soil_type: "sample", ph_level: 1.0, mineral_composition: "sample", microbiome_diversity: "pending"
  end

  test "AssessMicrobiome sets microbiome_diversity" do
    tests "AssessMicrobiome", on: "SoilProfile"
    input  soil_profile: 1, microbiome_diversity: "sample"
    expect microbiome_diversity: "sample"
  end


  # ── CraftProducer aggregate ──────────────────────────────────────────

  test "RegisterProducer sets producer_id + name + craft_type" do
    tests "RegisterProducer", on: "CraftProducer"
    setup  "DesignateTerroir", terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    input  protected_terroir: 1, producer_id: "sample", name: "sample", craft_type: "sample"
    expect producer_id: "sample", name: "sample", craft_type: "sample", terroir: :terroir, certification_status: "pending", status: "active"
  end

  test "CertifyProducer runs" do
    tests "CertifyProducer", on: "CraftProducer"
    setup  "RegisterProducer", producer_id: "sample", name: "sample", craft_type: "sample"
    input  craft_producer: 1
    expect certification_status: "certified"
  end

  test "SuspendProducer runs" do
    tests "SuspendProducer", on: "CraftProducer"
    setup  "RegisterProducer", producer_id: "sample", name: "sample", craft_type: "sample"
    input  craft_producer: 1
    expect certification_status: "suspended"
  end


  # ── SpeciesSurvey aggregate ──────────────────────────────────────────

  test "ConductSurvey sets survey_id + survey_date + season" do
    tests "ConductSurvey", on: "SpeciesSurvey"
    setup  "DesignateTerroir", terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    input  protected_terroir: 1, survey_id: "sample", survey_date: "sample", season: "sample"
    expect survey_id: "sample", terroir: :terroir, survey_date: "sample", season: "sample", overall_diversity: "pending"
  end

  test "AssessDiversity sets overall_diversity" do
    tests "AssessDiversity", on: "SpeciesSurvey"
    input  species_survey: 1, overall_diversity: "sample"
    expect overall_diversity: "sample"
  end


  # ── VisitorExperience aggregate ──────────────────────────────────────────

  test "DesignExperience sets experience_id + experience_type + capacity" do
    tests "DesignExperience", on: "VisitorExperience"
    setup  "DesignateTerroir", terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    setup  "RegisterProducer", producer_id: "sample", name: "sample", craft_type: "sample"
    input  protected_terroir: 1, craft_producer: 1, experience_id: "sample", experience_type: "sample", capacity: 1
    expect experience_id: "sample", terroir: :terroir, host_producer: :host_producer, experience_type: "sample", capacity: 1, status: "available"
  end

  test "BookExperience runs" do
    tests "BookExperience", on: "VisitorExperience"
    input  visitor_experience: 1
    expect ok: "true"
  end

  test "CompleteExperience runs" do
    tests "CompleteExperience", on: "VisitorExperience"
    input  visitor_experience: 1
    expect status: "completed"
  end


  # ── FlavorProfile aggregate ──────────────────────────────────────────

  test "CreateProfile sets profile_id + vintage_season" do
    tests "CreateProfile", on: "FlavorProfile"
    setup  "DesignateTerroir", terroir_id: "sample", name: "sample", region: "sample", designation_type: "sample", total_hectares: 1
    setup  "RegisterProducer", producer_id: "sample", name: "sample", craft_type: "sample"
    input  protected_terroir: 1, soil_profile: 1, craft_producer: 1, profile_id: "sample", vintage_season: "sample"
    expect profile_id: "sample", vintage_season: "sample", terroir: :terroir, soil: :soil, producer: :producer, overall_character: "pending"
  end

  test "AssessCharacter sets overall_character" do
    tests "AssessCharacter", on: "FlavorProfile"
    setup  "CreateProfile", profile_id: "sample", vintage_season: "sample"
    input  flavor_profile: 1, overall_character: "sample"
    expect overall_character: "sample"
  end

end
