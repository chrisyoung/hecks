Hecks.behaviors "Cartography" do
  vision "Behavioral tests for the Cartography domain — exercises every command and query in memory"

  # ── MapSheet aggregate ──────────────────────────────────────────

  test "Plate sets sheet_id + title + scale" do
    tests "Plate", on: "MapSheet"
    input  sheet_id: "sample", title: "sample", scale: "sample"
    expect ok: "true"
  end

  test "RetireSheet runs" do
    tests "RetireSheet", on: "MapSheet"
    setup  "Plate", sheet_id: "sample", title: "sample", scale: "sample"
    expect ok: "true"
  end


  # ── Projection aggregate ──────────────────────────────────────────

  test "DefineProjection sets name + projection_type + central_meridian" do
    tests "DefineProjection", on: "Projection"
    input  name: "sample", projection_type: "sample", central_meridian: 1.0
    expect ok: "true"
  end

  test "ComputeDistortion sets latitude + longitude" do
    tests "ComputeDistortion", on: "Projection"
    setup  "DefineProjection", name: "sample", projection_type: "sample", central_meridian: 1.0
    input  latitude: 1.0, longitude: 1.0
    expect ok: "true"
  end


  # ── GeographicFeature aggregate ──────────────────────────────────────────

  test "DigitizeFeature sets feature_type + name + geometry_wkt" do
    tests "DigitizeFeature", on: "GeographicFeature"
    setup  "Plate", sheet_id: "sample", title: "sample", scale: "sample"
    input  feature_type: "sample", name: "sample", geometry_wkt: "sample"
    expect ok: "true"
  end

  test "AttributeFeature sets attribute_name + attribute_value" do
    tests "AttributeFeature", on: "GeographicFeature"
    setup  "DigitizeFeature", feature_type: "sample", name: "sample", geometry_wkt: "sample"
    input  attribute_name: "sample", attribute_value: "sample"
    expect ok: "true"
  end


  # ── Datum aggregate ──────────────────────────────────────────

  test "RegisterDatum sets name + ellipsoid + semi_major_axis_m" do
    tests "RegisterDatum", on: "Datum"
    input  name: "sample", ellipsoid: "sample", semi_major_axis_m: 1.0
    expect name: "sample", ellipsoid: "sample", semi_major_axis_m: 1.0
  end


  # ── MapRevision aggregate ──────────────────────────────────────────

  test "SubmitRevision sets change_description" do
    tests "SubmitRevision", on: "MapRevision"
    setup  "Plate", sheet_id: "sample", title: "sample", scale: "sample"
    input  change_description: "sample"
    expect ok: "true"
  end

end
