Hecks.behaviors "PotteryStudio" do
  vision "Behavioral tests for the PotteryStudio domain — exercises every command and query in memory"

  # ── Piece aggregate ──────────────────────────────────────────

  test "ThrowPiece sets name + form + clay_body + weight_kg" do
    tests "ThrowPiece", on: "Piece"
    input  name: "sample", form: "sample", clay_body: "sample", weight_kg: 1.0
    expect status: "thrown"
  end

  test "TrimPiece runs" do
    tests "TrimPiece", on: "Piece"
    setup  "ThrowPiece", name: "sample", form: "sample", clay_body: "sample", weight_kg: 1.0
    expect status: "bisqued"
  end


  # ── Firing aggregate ──────────────────────────────────────────

  test "LoadKiln sets firing_type + target_cone + atmosphere + piece_count" do
    tests "LoadKiln", on: "Firing"
    setup  "SetUpKiln", name: "sample", fuel_type: "sample", cubic_feet: 1.0
    input  firing_type: "sample", target_cone: 1, atmosphere: "sample", piece_count: 1
    expect status: "loading"
  end

  test "StartFiring runs" do
    tests "StartFiring", on: "Firing"
    setup  "LoadKiln", firing_type: "sample", target_cone: 1, atmosphere: "sample", piece_count: 1
    expect status: "completed"
  end


  # ── Glaze aggregate ──────────────────────────────────────────

  test "FormulateGlaze sets name + surface_type + cone_low + cone_high" do
    tests "FormulateGlaze", on: "Glaze"
    input  name: "sample", surface_type: "sample", cone_low: 1, cone_high: 1
    expect ok: "true"
  end

  test "TestGlaze sets test_cone" do
    tests "TestGlaze", on: "Glaze"
    setup  "FormulateGlaze", name: "sample", surface_type: "sample", cone_low: 1, cone_high: 1
    input  test_cone: 1
    expect ok: "true"
  end


  # ── Kiln aggregate ──────────────────────────────────────────

  test "SetUpKiln sets name + fuel_type + cubic_feet" do
    tests "SetUpKiln", on: "Kiln"
    input  name: "sample", fuel_type: "sample", cubic_feet: 1.0
    expect ok: "true"
  end

  test "ServiceKiln sets service_type" do
    tests "ServiceKiln", on: "Kiln"
    setup  "SetUpKiln", name: "sample", fuel_type: "sample", cubic_feet: 1.0
    input  service_type: "sample"
    expect ok: "true"
  end


  # ── Exhibition aggregate ──────────────────────────────────────────

  test "CurateExhibition sets title + venue + opening_date + piece_count" do
    tests "CurateExhibition", on: "Exhibition"
    input  title: "sample", venue: "sample", opening_date: "sample", piece_count: 1
    expect status: "open"
  end

end
