Hecks.behaviors "CrowdfundingPlatform" do
  vision "Behavioral tests for the CrowdfundingPlatform domain — exercises every command and query in memory"

  # ── Campaign aggregate ──────────────────────────────────────────

  test "LaunchCampaign sets campaign_title + creator_name + description + funding_goal + deadline" do
    tests "LaunchCampaign", on: "Campaign"
    input  campaign_title: "sample", creator_name: "sample", description: "sample", funding_goal: 1.0, deadline: "sample"
    expect ok: "true"
  end

  test "FundCampaign runs" do
    tests "FundCampaign", on: "Campaign"
    setup  "LaunchCampaign", campaign_title: "sample", creator_name: "sample", description: "sample", funding_goal: 1.0, deadline: "sample"
    input  campaign: 1
    expect ok: "true"
  end

  test "CancelCampaign runs" do
    tests "CancelCampaign", on: "Campaign"
    setup  "LaunchCampaign", campaign_title: "sample", creator_name: "sample", description: "sample", funding_goal: 1.0, deadline: "sample"
    input  campaign: 1
    expect ok: "true"
  end


  # ── Backer aggregate ──────────────────────────────────────────

  test "RegisterBacker sets backer_id + name + email + payment_method" do
    tests "RegisterBacker", on: "Backer"
    input  backer_id: "sample", name: "sample", email: "sample", payment_method: "sample"
    expect backer_id: "sample", name: "sample", email: "sample", payment_method: "sample"
  end

  test "UpdatePaymentMethod sets payment_method" do
    tests "UpdatePaymentMethod", on: "Backer"
    setup  "RegisterBacker", backer_id: "sample", name: "sample", email: "sample", payment_method: "sample"
    input  backer: 1, payment_method: "sample"
    expect ok: "true"
  end

  test "DeactivateBacker runs" do
    tests "DeactivateBacker", on: "Backer"
    setup  "RegisterBacker", backer_id: "sample", name: "sample", email: "sample", payment_method: "sample"
    input  backer: 1
    expect ok: "true"
  end


  # ── Pledge aggregate ──────────────────────────────────────────

  test "MakePledge sets pledge_id + amount + reward_tier" do
    tests "MakePledge", on: "Pledge"
    setup  "RegisterBacker", backer_id: "sample", name: "sample", email: "sample", payment_method: "sample"
    setup  "LaunchCampaign", campaign_title: "sample", creator_name: "sample", description: "sample", funding_goal: 1.0, deadline: "sample"
    input  campaign: 1, backer: 1, pledge_id: "sample", amount: 1.0, reward_tier: "sample"
    expect ok: "true"
  end

  test "IncreasePledge sets additional_amount" do
    tests "IncreasePledge", on: "Pledge"
    input  pledge: 1, additional_amount: 1.0
    expect ok: "true"
  end

  test "WithdrawPledge runs" do
    tests "WithdrawPledge", on: "Pledge"
    input  pledge: 1
    expect ok: "true"
  end


  # ── Reward aggregate ──────────────────────────────────────────

  test "FulfillReward sets reward_id + tier_name + description + shipping_address" do
    tests "FulfillReward", on: "Reward"
    input  pledge: 1, reward_id: "sample", tier_name: "sample", description: "sample", shipping_address: "sample"
    expect ok: "true"
  end

  test "MarkShipped sets carrier + tracking_number" do
    tests "MarkShipped", on: "Reward"
    input  reward: 1, carrier: "sample", tracking_number: "sample"
    expect ok: "true"
  end

  test "ReportDamaged runs" do
    tests "ReportDamaged", on: "Reward"
    input  reward: 1
    expect ok: "true"
  end


  # ── Milestone aggregate ──────────────────────────────────────────

  test "SetMilestone sets milestone_id + title + description + target_date" do
    tests "SetMilestone", on: "Milestone"
    setup  "LaunchCampaign", campaign_title: "sample", creator_name: "sample", description: "sample", funding_goal: 1.0, deadline: "sample"
    input  campaign: 1, milestone_id: "sample", title: "sample", description: "sample", target_date: "sample"
    expect ok: "true"
  end

  test "CompleteMilestone runs" do
    tests "CompleteMilestone", on: "Milestone"
    input  milestone: 1
    expect ok: "true"
  end

  test "DelayMilestone sets new_target_date + delay_reason" do
    tests "DelayMilestone", on: "Milestone"
    input  milestone: 1, new_target_date: "sample", delay_reason: "sample"
    expect ok: "true"
  end

end
