Hecks.behaviors "JewelryWorkshop" do
  vision "Behavioral tests for the JewelryWorkshop domain — exercises every command and query in memory"

  # ── JewelryPiece aggregate ──────────────────────────────────────────

  test "DesignPiece sets name + piece_type + metal" do
    tests "DesignPiece", on: "JewelryPiece"
    input  name: "sample", piece_type: "sample", metal: "sample"
    expect ok: "true"
  end

  test "CastPiece sets casting_method" do
    tests "CastPiece", on: "JewelryPiece"
    setup  "DesignPiece", name: "sample", piece_type: "sample", metal: "sample"
    input  jewelry_piece: 1, casting_method: "sample"
    expect status: "cast"
  end

  test "PolishPiece runs" do
    tests "PolishPiece", on: "JewelryPiece"
    setup  "DesignPiece", name: "sample", piece_type: "sample", metal: "sample"
    input  jewelry_piece: 1
    expect status: "finished"
  end


  # ── Gemstone aggregate ──────────────────────────────────────────

  test "AcquireStone sets stone_type + carat_weight + cut + clarity + color_grade" do
    tests "AcquireStone", on: "Gemstone"
    input  stone_type: "sample", carat_weight: 1.0, cut: "sample", clarity: "sample", color_grade: "sample"
    expect ok: "true"
  end

  test "GradeStone sets lab_name" do
    tests "GradeStone", on: "Gemstone"
    setup  "AcquireStone", stone_type: "sample", carat_weight: 1.0, cut: "sample", clarity: "sample", color_grade: "sample"
    input  gemstone: 1, lab_name: "sample"
    expect ok: "true"
  end


  # ── Setting aggregate ──────────────────────────────────────────

  test "PrepareSetting sets setting_type + metal" do
    tests "PrepareSetting", on: "Setting"
    setup  "DesignPiece", name: "sample", piece_type: "sample", metal: "sample"
    input  jewelry_piece: 1, setting_type: "sample", metal: "sample"
    expect ok: "true"
  end

  test "SetStone runs" do
    tests "SetStone", on: "Setting"
    setup  "AcquireStone", stone_type: "sample", carat_weight: 1.0, cut: "sample", clarity: "sample", color_grade: "sample"
    input  setting: 1, gemstone: 1
    expect status: "set"
  end


  # ── Appraisal aggregate ──────────────────────────────────────────

  test "AppraisePiece sets appraiser_name + purpose + appraised_value" do
    tests "AppraisePiece", on: "Appraisal"
    setup  "DesignPiece", name: "sample", piece_type: "sample", metal: "sample"
    input  jewelry_piece: 1, appraiser_name: "sample", purpose: "sample", appraised_value: 1.0
    expect ok: "true"
  end

  test "UpdateAppraisal sets new_value" do
    tests "UpdateAppraisal", on: "Appraisal"
    input  appraisal: 1, new_value: 1.0
    expect appraised_value: 1.0
  end


  # ── Commission aggregate ──────────────────────────────────────────

  test "QuoteCommission sets client_name + description + quoted_price + deadline" do
    tests "QuoteCommission", on: "Commission"
    input  client_name: "sample", description: "sample", quoted_price: 1.0, deadline: "sample"
    expect ok: "true"
  end

  test "AcceptCommission runs" do
    tests "AcceptCommission", on: "Commission"
    setup  "QuoteCommission", client_name: "sample", description: "sample", quoted_price: 1.0, deadline: "sample"
    input  commission: 1
    expect status: "in_progress"
  end

  test "DeliverCommission runs" do
    tests "DeliverCommission", on: "Commission"
    setup  "QuoteCommission", client_name: "sample", description: "sample", quoted_price: 1.0, deadline: "sample"
    input  commission: 1
    expect status: "delivered"
  end

end
