Hecks.behaviors "Chris" do
  vision "Behavioral tests for the Chris domain — exercises every command and query in memory"

  # ── Identity aggregate ──────────────────────────────────────────

  test "UpdateRole sets role" do
    tests "UpdateRole", on: "Identity"
    input  identity: 1, role: "sample"
    expect role: "sample"
  end


  # ── Workflow aggregate ──────────────────────────────────────────

  test "SetPreference sets name + rule + why" do
    tests "SetPreference", on: "Workflow"
    input  name: "sample", rule: "sample", why: "sample"
    expect preferences_size: 1
  end


  # ── Convention aggregate ──────────────────────────────────────────

  test "AddConvention sets name + rule + why + applies_to" do
    tests "AddConvention", on: "Convention"
    input  name: "sample", rule: "sample", why: "sample", applies_to: "sample"
    expect name: "sample", rule: "sample", why: "sample", applies_to: "sample"
  end


  # ── AntiPattern aggregate ──────────────────────────────────────────

  test "RecordAntiPattern sets name + what_happened + why_it_was_wrong + correct_approach" do
    tests "RecordAntiPattern", on: "AntiPattern"
    input  name: "sample", what_happened: "sample", why_it_was_wrong: "sample", correct_approach: "sample"
    expect name: "sample", what_happened: "sample", why_it_was_wrong: "sample", correct_approach: "sample"
  end


  # ── Person aggregate ──────────────────────────────────────────

  test "AddPerson sets name + relationship + context" do
    tests "AddPerson", on: "Person"
    input  name: "sample", relationship: "sample", context: "sample"
    expect name: "sample", relationship: "sample", context: "sample"
  end

  test "AddNote sets note" do
    tests "AddNote", on: "Person"
    setup  "AddPerson", name: "sample", relationship: "sample", context: "sample"
    input  person: 1, note: "sample"
    expect notes_size: 1
  end


  # ── Embryonaut aggregate ──────────────────────────────────────────

  test "RecordMilestone sets name + date + status" do
    tests "RecordMilestone", on: "Embryonaut"
    input  embryonaut: 1, name: "sample", date: "sample", status: "sample"
    expect milestones_size: 1
  end

end
