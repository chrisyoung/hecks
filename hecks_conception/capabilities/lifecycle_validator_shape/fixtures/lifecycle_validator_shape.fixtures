Hecks.fixtures "LifecycleValidatorShape" do
  # Single-line fixtures per i57 parser limitation.

  aggregate "DiagnosticValidator" do
    fixture "Lifecycle", module: "lifecycle_validator", doc_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/doc.rs.frag", imports: "crate::ir::{Aggregate, Command, Domain, Lifecycle, MutationOp}\nstd::collections::BTreeSet", report_kind: "flat_with_strict", rule_fn_name: "check", rule_signature: "pub fn check(domain: &Domain) -> Report", check_body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/check_body.rs.frag", helpers_after_rule: true
  end

  aggregate "DiagnosticHelper" do
    fixture "CheckMutationReferences", validator: "lifecycle_validator", name: "check_mutation_references", doc_comment: "/// `then_set :field, to: :symbol` references the command's `:symbol`\n/// attribute or reference at runtime. If neither exists, the mutation\n/// is broken — at runtime the field stays null because there's nothing\n/// to copy from. Flag it.\n///\n/// Also flags two clock-touching anti-patterns the runtime synthesizes:\n///   • `to: :now` — current ISO timestamp\n///   • `to: seconds_since(:field)` — elapsed seconds\n/// Both reach into infrastructure (the system clock) from inside the\n/// domain. DDD: time is a Clock port — inject it as a command attribute\n/// instead of having the runtime supply it.", signature: "fn check_mutation_references(agg: &Aggregate, out: &mut Vec<Finding>)", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/check_mutation_references_body.rs.frag", order: 1
    fixture "CheckGivenCoverage", validator: "lifecycle_validator", name: "check_given_coverage", doc_comment: "/// Givens of the form `<field> == \"<value>\"` need a producer in the\n/// same aggregate — some command's `then_set <field>, to: \"<value>\"`,\n/// or a lifecycle transition with `<field>` as its lifecycle field\n/// and `<value>` as its to_state. Otherwise the gate is unreachable\n/// and the command can never fire.", signature: "fn check_given_coverage(agg: &Aggregate, out: &mut Vec<Finding>)", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/check_given_coverage_body.rs.frag", order: 2
    fixture "CollectProducibleStates", validator: "lifecycle_validator", name: "collect_producible_states", doc_comment: "", signature: "fn collect_producible_states(agg: &Aggregate) -> BTreeSet<(String, String)>", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/collect_producible_states_body.rs.frag", order: 3
    fixture "ParseEquality", validator: "lifecycle_validator", name: "parse_equality", doc_comment: "/// Parse `<field> == \"<value>\"`. Returns None for non-equality or\n/// non-quoted-string-RHS forms — the validator can't reason about\n/// expressions like \"size > 10\" or \"must have elapsed\".", signature: "fn parse_equality(expr: &str) -> Option<(String, String)>", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/parse_equality_body.rs.frag", order: 4
    fixture "ForceCommandUse", validator: "lifecycle_validator", name: "_force_command_use", doc_comment: "// (`Command` will be unused if no future check needs it; suppress\n// the warning preemptively.)\n#[allow(dead_code)]", signature: "fn _force_command_use(_c: &Command)", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/force_command_use_body.rs.frag", order: 5
    fixture "CheckAggregate", validator: "lifecycle_validator", name: "check_aggregate", doc_comment: "", signature: "fn check_aggregate(agg: &Aggregate, lc: &Lifecycle, out: &mut Vec<Finding>)", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/check_aggregate_body.rs.frag", order: 6
    fixture "FormatSet", validator: "lifecycle_validator", name: "format_set", doc_comment: "", signature: "fn format_set(set: &BTreeSet<String>) -> String", body_snippet: "hecks_conception/capabilities/lifecycle_validator_shape/snippets/format_set_body.rs.frag", order: 7
  end
end
