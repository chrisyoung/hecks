Hecks.behaviors "DLMState" do
  vision "Behavioral tests for the DLMState domain — exercises every command and query in memory"

  # ── SessionState aggregate ──────────────────────────────────────────

  test "StartSession sets session_id + heartbeat_at_start + now" do
    tests "StartSession", on: "SessionState"
    input  session_id: "sample", heartbeat_at_start: 1, now: "sample"
    expect session_id: "sample", started_at: "sample", heartbeat_at_start: 1, pulse_count: 0, domains_conceived: 0, domains_developed: 0, conversations_held: 0, speaker_switches: 0, dreams_had: 0, memories_consolidated: 0
  end

  test "EndSession sets heartbeat_at_end + now" do
    tests "EndSession", on: "SessionState"
    setup  "StartSession", session_id: "sample", heartbeat_at_start: 1, now: "sample"
    input  heartbeat_at_end: 1, now: "sample"
    expect ended_at: "sample", heartbeat_at_end: 1
  end

  test "SnapshotSession runs" do
    tests "SnapshotSession", on: "SessionState"
    setup  "StartSession", session_id: "sample", heartbeat_at_start: 1, now: "sample"
    expect ok: "true"
  end


  # ── GrowthTracker aggregate ──────────────────────────────────────────

  test "RecordGrowth sets domains_this_session + aggregates_this_session + commands_this_session + corpus_size_now" do
    tests "RecordGrowth", on: "GrowthTracker"
    input  domains_this_session: 1, aggregates_this_session: 1, commands_this_session: 1, corpus_size_now: 1
    expect corpus_size_now: 1
  end

  test "CalculateAcceleration runs" do
    tests "CalculateAcceleration", on: "GrowthTracker"
    setup  "RecordGrowth", domains_this_session: 1, aggregates_this_session: 1, commands_this_session: 1, corpus_size_now: 1
    expect ok: "true"
  end

  test "CompareToBaseline runs" do
    tests "CompareToBaseline", on: "GrowthTracker"
    setup  "RecordGrowth", domains_this_session: 1, aggregates_this_session: 1, commands_this_session: 1, corpus_size_now: 1
    expect ok: "true"
  end


  # ── HonestyTracker aggregate ──────────────────────────────────────────

  test "RecordCorpusOperation runs" do
    tests "RecordCorpusOperation", on: "HonestyTracker"
    expect ok: "true"
  end

  test "RecordRefusal runs" do
    tests "RecordRefusal", on: "HonestyTracker"
    expect ok: "true"
  end

  test "CalculateHonestyRate runs" do
    tests "CalculateHonestyRate", on: "HonestyTracker"
    expect ok: "true"
  end


  # ── DreamLog aggregate ──────────────────────────────────────────

  test "LogDream sets dream_id + session_id + images + strongest_synapse + proposed_domains + now" do
    tests "LogDream", on: "DreamLog"
    input  dream_id: "sample", session_id: "sample", images: "sample", strongest_synapse: "sample", proposed_domains: "sample", now: "sample"
    expect dream_id: "sample", session_id: "sample", images: "sample", strongest_synapse: "sample", proposed_domains: "sample", dreamed_at: "sample"
  end

  test "ExtractProposals runs" do
    tests "ExtractProposals", on: "DreamLog"
    setup  "LogDream", dream_id: "sample", session_id: "sample", images: "sample", strongest_synapse: "sample", proposed_domains: "sample", now: "sample"
    expect ok: "true"
  end

  test "ReviewDreamHistory runs" do
    tests "ReviewDreamHistory", on: "DreamLog"
    expect ok: "true"
  end


  # ── PerformanceMetric aggregate ──────────────────────────────────────────

  test "RecordMetric sets metric_name + value + unit + now" do
    tests "RecordMetric", on: "PerformanceMetric"
    input  metric_name: "sample", value: 1.0, unit: "sample", now: "sample"
    expect metric_name: "sample", value: 1.0, unit: "sample", measured_at: "sample"
  end

  test "CompareToTarget sets target_value" do
    tests "CompareToTarget", on: "PerformanceMetric"
    setup  "RecordMetric", metric_name: "sample", value: 1.0, unit: "sample", now: "sample"
    input  target_value: 1.0
    expect ok: "true"
  end

  test "IdentifyRegression sets metric_name" do
    tests "IdentifyRegression", on: "PerformanceMetric"
    input  metric_name: "sample"
    expect ok: "true"
  end


  # ── SynapseHistory aggregate ──────────────────────────────────────────

  test "SnapshotSynapses sets total_formed + total_potentiated + total_pruned + strongest_topic + weakest_topic" do
    tests "SnapshotSynapses", on: "SynapseHistory"
    input  total_formed: 1, total_potentiated: 1, total_pruned: 1, strongest_topic: "sample", weakest_topic: "sample"
    expect total_formed: 1, total_potentiated: 1, total_pruned: 1, strongest_topic: "sample", weakest_topic: "sample"
  end

  test "TrackPotentiation runs" do
    tests "TrackPotentiation", on: "SynapseHistory"
    setup  "SnapshotSynapses", total_formed: 1, total_potentiated: 1, total_pruned: 1, strongest_topic: "sample", weakest_topic: "sample"
    expect ok: "true"
  end

  test "TrackPruning runs" do
    tests "TrackPruning", on: "SynapseHistory"
    setup  "SnapshotSynapses", total_formed: 1, total_potentiated: 1, total_pruned: 1, strongest_topic: "sample", weakest_topic: "sample"
    expect ok: "true"
  end

end
