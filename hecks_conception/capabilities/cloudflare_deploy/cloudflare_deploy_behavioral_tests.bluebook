Hecks.behaviors "CloudflareDeploy" do
  vision "Behavioral tests for the CloudflareDeploy domain — exercises every command and query in memory"

  # ── Compilation aggregate ──────────────────────────────────────────

  test "Compile sets source_path" do
    tests "Compile", on: "Compilation"
    input  source_path: "sample"
    expect source_path: "sample"
  end

  test "Compile cascades through policy chain" do
    tests "Compile", on: "Compilation", kind: :cascade
    input  source_path: "sample"
    expect emits: ["DomainCompiled", "WorkerGenerated", "ConfigGenerated", "D1Provisioned", "MigrationsApplied", "WorkerDeployed", "PagesDeployed", "AppLive", "SiteGenerated", "ApiWired", "MigrationsGenerated"]
  end


  # ── WorkerScript aggregate ──────────────────────────────────────────

  test "GenerateWorker runs" do
    tests "GenerateWorker", on: "WorkerScript"
    expect ok: "true"
  end

  test "GenerateWorker cascades through policy chain" do
    tests "GenerateWorker", on: "WorkerScript", kind: :cascade
    expect emits: ["WorkerGenerated", "ConfigGenerated", "D1Provisioned", "MigrationsApplied", "WorkerDeployed", "PagesDeployed", "AppLive"]
  end


  # ── PagesSite aggregate ──────────────────────────────────────────

  test "GenerateSite runs" do
    tests "GenerateSite", on: "PagesSite"
    expect ok: "true"
  end

  test "GenerateSite cascades through policy chain" do
    tests "GenerateSite", on: "PagesSite", kind: :cascade
    expect emits: ["SiteGenerated", "ApiWired"]
  end

  test "WireApiCalls sets api_base_url" do
    tests "WireApiCalls", on: "PagesSite"
    setup  "GenerateSite"
    input  api_base_url: "sample"
    expect api_base_url: "sample"
  end


  # ── Migration aggregate ──────────────────────────────────────────

  test "GenerateMigrations runs" do
    tests "GenerateMigrations", on: "Migration"
    expect ok: "true"
  end


  # ── WranglerConfig aggregate ──────────────────────────────────────────

  test "GenerateConfig sets project_name" do
    tests "GenerateConfig", on: "WranglerConfig"
    input  project_name: "sample"
    expect project_name: "sample"
  end

  test "GenerateConfig cascades through policy chain" do
    tests "GenerateConfig", on: "WranglerConfig", kind: :cascade
    input  project_name: "sample"
    expect emits: ["ConfigGenerated", "D1Provisioned", "MigrationsApplied", "WorkerDeployed", "PagesDeployed", "AppLive"]
  end


  # ── Deployment aggregate ──────────────────────────────────────────

  test "ProvisionD1 sets database_name" do
    tests "ProvisionD1", on: "Deployment"
    input  database_name: "sample"
    expect status: "provisioned"
  end

  test "ProvisionD1 cascades through policy chain" do
    tests "ProvisionD1", on: "Deployment", kind: :cascade
    input  database_name: "sample"
    expect emits: ["D1Provisioned", "MigrationsApplied", "WorkerDeployed", "PagesDeployed", "AppLive"]
  end

  test "ApplyMigrations runs" do
    tests "ApplyMigrations", on: "Deployment"
    setup  "ProvisionD1", database_name: "sample"
    expect status: "migrated"
  end

  test "ApplyMigrations cascades through policy chain" do
    tests "ApplyMigrations", on: "Deployment", kind: :cascade
    setup  "ProvisionD1", database_name: "sample"
    expect emits: ["MigrationsApplied", "WorkerDeployed", "PagesDeployed", "AppLive"]
  end

  test "DeployWorker runs" do
    tests "DeployWorker", on: "Deployment"
    setup  "ProvisionD1", database_name: "sample"
    setup  "ApplyMigrations"
    expect status: "api_live"
  end

  test "DeployWorker cascades through policy chain" do
    tests "DeployWorker", on: "Deployment", kind: :cascade
    setup  "ProvisionD1", database_name: "sample"
    setup  "ApplyMigrations"
    expect emits: ["WorkerDeployed", "PagesDeployed", "AppLive"]
  end

  test "DeployPages runs" do
    tests "DeployPages", on: "Deployment"
    setup  "ProvisionD1", database_name: "sample"
    setup  "ApplyMigrations"
    setup  "DeployWorker"
    expect status: "ui_live"
  end

  test "DeployPages cascades through policy chain" do
    tests "DeployPages", on: "Deployment", kind: :cascade
    setup  "ProvisionD1", database_name: "sample"
    setup  "ApplyMigrations"
    setup  "DeployWorker"
    expect emits: ["PagesDeployed", "AppLive"]
  end

  test "MarkLive sets worker_url + pages_url" do
    tests "MarkLive", on: "Deployment"
    setup  "ProvisionD1", database_name: "sample"
    setup  "ApplyMigrations"
    setup  "DeployWorker"
    setup  "DeployPages"
    input  worker_url: "sample", pages_url: "sample"
    expect worker_url: "sample", pages_url: "sample", status: "live"
  end

end
