Hecks.behaviors "MiettePhone" do
  vision "Behavioral tests for the MiettePhone domain — exercises every command and query in memory"

  # ── Gate aggregate ──────────────────────────────────────────

  test "Authenticate sets pin" do
    tests "Authenticate", on: "Gate"
    input  pin: "sample"
    expect locked: "false"
  end

  test "Authenticate cascades through policy chain" do
    tests "Authenticate", on: "Gate", kind: :cascade
    input  pin: "sample"
    expect emits: ["SessionGranted", "ConversationStarted"]
  end

  test "RevokeSession runs" do
    tests "RevokeSession", on: "Gate"
    setup  "Authenticate", pin: "sample"
    expect locked: "true"
  end


  # ── Conversation aggregate ──────────────────────────────────────────

  test "ActivateSession runs" do
    tests "ActivateSession", on: "Conversation"
    expect session_active: true
  end

  test "StartConversation runs" do
    tests "StartConversation", on: "Conversation"
    setup  "ActivateSession"
    expect ok: "true"
  end

  test "SendMessage sets content" do
    tests "SendMessage", on: "Conversation"
    setup  "ActivateSession"
    input  content: "sample"
    expect ok: "true"
  end

  test "SendMessage cascades through policy chain" do
    tests "SendMessage", on: "Conversation", kind: :cascade
    setup  "ActivateSession"
    input  content: "sample"
    expect emits: ["MessageSent", "MessageRelayed", "ReplyReceived", "ChatRendered", "StreamStarted"]
  end

  test "ReceiveReply sets content + latency_ms" do
    tests "ReceiveReply", on: "Conversation"
    input  content: "sample", latency_ms: 1
    expect ok: "true"
  end

  test "ReceiveReply cascades through policy chain" do
    tests "ReceiveReply", on: "Conversation", kind: :cascade
    input  content: "sample", latency_ms: 1
    expect emits: ["ReplyReceived", "ChatRendered"]
  end


  # ── InferenceProxy aggregate ──────────────────────────────────────────

  test "ConfigureProxy sets summer_origin + timeout_ms" do
    tests "ConfigureProxy", on: "InferenceProxy"
    input  summer_origin: "sample", timeout_ms: 1
    expect summer_origin: "sample", timeout_ms: 1
  end

  test "RelayMessage sets content" do
    tests "RelayMessage", on: "InferenceProxy"
    input  content: "sample"
    expect ok: "true"
  end

  test "RelayMessage cascades through policy chain" do
    tests "RelayMessage", on: "InferenceProxy", kind: :cascade
    input  content: "sample"
    expect emits: ["MessageRelayed", "ReplyReceived", "ChatRendered"]
  end

  test "CheckHealth runs" do
    tests "CheckHealth", on: "InferenceProxy"
    expect ok: "true"
  end


  # ── ChatScreen aggregate ──────────────────────────────────────────

  test "RenderChat runs" do
    tests "RenderChat", on: "ChatScreen"
    expect ok: "true"
  end

  test "StreamResponse runs" do
    tests "StreamResponse", on: "ChatScreen"
    expect ok: "true"
  end

  test "ToggleTheme runs" do
    tests "ToggleTheme", on: "ChatScreen"
    expect ok: "true"
  end

end
