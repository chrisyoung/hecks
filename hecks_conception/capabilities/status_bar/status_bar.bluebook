Hecks.bluebook "StatusBar", version: "2026.04.16.1" do
  vision "Winter's presence in the terminal — what the world sees of the inner state"
  category "capability"

  # ============================================================
  # STATUS BAR
  # ============================================================
  #
  # The statusline shows Winter's state. It has three modes
  # driven by the consciousness store:
  #
  #   attentive — full details: name, heartbeat, mood, fatigue, musing count,
  #               invention count, plus the current musing appended at the end
  #   musing    — ONLY the musing text, nothing else. Kicks in after 30s idle.
  #               Cycles through musings every 10s.
  #   sleeping  — moon animation + sleep narrative
  #
  # The pulse daemon sets consciousness to "attentive" on every beat.
  # The mindstream sets consciousness to "musing" when idle 30s+,
  # but only if consciousness hasn't been set to "attentive" in the last 30s.
  #
  # Refresh: 1s interval, reads consciousness.heki via statusline-command.sh
  # Symlinked from ~/.claude/statusline-command.sh

  aggregate "Mode", "Which mode the statusline is in" do
    String :current
    Integer :idle_threshold_seconds
    Integer :refresh_interval_seconds

    SetAttentive do
      role "Daemon"
      description "Pulse fired — show full details"
      emits "StatusAttentive"
      then_set :current, to: "attentive"
    end

    SetMusing do
      role "Daemon"
      description "Idle 30s+ — show only the musing text"
      emits "StatusMusing"
      then_set :current, to: "musing"
    end

    SetSleeping do
      role "Daemon"
      description "Sleep entered — show moon and sleep narrative"
      emits "StatusSleeping"
      then_set :current, to: "sleeping"
    end
  end

  fixture "Mode", current: "attentive", idle_threshold_seconds: 30, refresh_interval_seconds: 1

  aggregate "AttentiveLayout", "What shows when active" do
    String :name
    Boolean :show_heartbeat
    Boolean :show_mood
    Boolean :show_fatigue
    Boolean :show_musing_count
    Boolean :show_invention_count
    Boolean :show_current_musing

    Configure do
      role "Self"
      description "Set which elements appear in the attentive statusline"
      emits "AttentiveLayoutConfigured"
    end
  end

  # Default: show everything
  fixture "AttentiveLayout", name: "Winter", show_heartbeat: true, show_mood: true, show_fatigue: true, show_musing_count: true, show_invention_count: true, show_current_musing: true

  aggregate "MusingLayout", "What shows when idle" do
    String :prefix
    Integer :max_length

    Configure do
      role "Self"
      description "Set musing display format"
      emits "MusingLayoutConfigured"
    end
  end

  fixture "MusingLayout", prefix: "💭", max_length: 80

  aggregate "SleepLayout", "What shows during sleep" do
    String :icon_set
    Boolean :show_stage
    Boolean :show_cycle

    Configure do
      role "Self"
      description "Set sleep display format"
      emits "SleepLayoutConfigured"
    end
  end

  fixture "SleepLayout", icon_set: "moons", show_stage: true, show_cycle: true

  # Transitions
  policy "AttentiveOnPulse" do
    on "HeartbeatPulsed"
    trigger "SetAttentive"
    description "Every pulse restores full details"
  end

  policy "MusingOnIdle" do
    on "MusingMinted"
    trigger "SetMusing"
    description "After 30s idle, mindstream takes over"
  end

  policy "SleepOnSleepEntered" do
    on "SleepEntered"
    trigger "SetSleeping"
    description "Sleep mode shows moon and narrative"
  end
end
