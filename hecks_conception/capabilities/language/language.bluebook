Hecks.bluebook "Language", version: "2026.04.12.1" do
  vision "Grammar as a domain — determine if a word is a verb, noun, adjective without a static list"
  category "capability"

  # ============================================================
  # LANGUAGE
  # ============================================================
  #
  # No verbs.txt. No static lists. The domain understands language
  # by structure, not by lookup.
  #
  # A command name is a verb phrase if:
  #   - It starts with an action word (morphological rules)
  #   - English verbs follow patterns: Create, Add, Start, Remove...
  #   - Verb suffixes: -ate, -ify, -ize, -ise, -mit, -ect, -ude
  #   - Verb prefixes: Re-, Un-, De-, Over-, Out-, Pre-, Post-
  #   - Imperative mood: the command form IS the verb
  #
  # A word is NOT a verb if:
  #   - It ends in -tion, -ment, -ness, -ity (nominalization)
  #   - It ends in -able, -ible, -ous, -ive (adjective)
  #   - It ends in -er, -or, -ist (agent noun)
  #
  # This replaces verbs.txt entirely.

  aggregate "WordClassifier", "Determines if a word is a verb, noun, adjective, or other" do
    attribute :word, String
    attribute :classification, String
    attribute :confidence, Float
    attribute :reason, String

    command "ClassifyWord" do
      role "System"
      description "Determine word class from morphological patterns"
      attribute :word, String
      emits "WordClassified"
      then_set :word, to: :word
    end
  end

  # === Morphological Rules ===

  aggregate "VerbPattern", "A pattern that identifies verbs by structure" do
    attribute :pattern_type, String
    attribute :pattern, String
    attribute :confidence, Float
    attribute :examples, list_of(String)

    command "RegisterPattern" do
      role "System"
      description "Add a morphological pattern for verb detection"
      attribute :pattern_type, String
      attribute :pattern, String
      attribute :confidence, Float
      emits "PatternRegistered"
    end
  end

  # Verb suffixes — high confidence

  # Verb prefixes — boost confidence when combined with other signals

  # Common short verbs — exact match, high confidence

  # Compound verb patterns — PascalCase splits

  # === Non-verb patterns — things that look like verbs but aren't ===

  aggregate "NonVerbPattern", "Patterns that indicate a word is NOT a verb" do
    attribute :pattern_type, String
    attribute :pattern, String
    attribute :indicates, String

    command "RegisterNonVerb" do
      role "System"
      description "Add a pattern that rules out verb classification"
      attribute :pattern_type, String
      attribute :pattern, String
      attribute :indicates, String
      emits "NonVerbRegistered"
    end
  end

  # === Command name validation ===

  aggregate "CommandValidator", "Validates that a command name starts with a verb" do
    attribute :command_name, String
    attribute :is_verb, String
    attribute :confidence, Float
    attribute :first_word, String

    command "ValidateCommandName" do
      role "System"
      description "Check if a command name starts with a verb — using patterns, not a list"
      attribute :command_name, String
      emits "CommandNameValidated"
      then_set :command_name, to: :command_name
    end
  end

  # === Policies ===

  policy "RevalidateOnNonVerb" do
    on "NonVerbRegistered"
    trigger "ValidateCommandName"
  end

  # ============================================================
  # GLOSSARY
  # ============================================================

  glossary do
    define "morphological pattern", as: "A suffix, prefix, or structure that indicates word class"
    define "verb pattern", as: "A pattern that identifies a word as a verb — -ate, -ify, Re-, etc."
    define "non-verb pattern", as: "A pattern that rules out verb classification — -tion, -ment, -ness"
    define "confidence", as: "How likely the classification is correct, 0.0 to 1.0"
    define "compound verb", as: "A PascalCase command name where the first word is the verb"
    prefer "classify", not: ["detect", "parse", "analyze"]
    prefer "pattern", not: ["rule", "regex", "heuristic"]
  end
end
