Hecks.behaviors "DomainHygiene" do
  vision "Behavioral tests for the DomainHygiene domain — exercises every command and query in memory"

  # ── HealthCheck aggregate ──────────────────────────────────────────

  test "ScanCorpus sets root_path" do
    tests "ScanCorpus", on: "HealthCheck"
    input  root_path: "sample"
    expect ok: "true"
  end


  # ── QualityReport aggregate ──────────────────────────────────────────

  test "AssessQuality sets jsonl_path" do
    tests "AssessQuality", on: "QualityReport"
    input  jsonl_path: "sample"
    expect ok: "true"
  end

  test "IdentifyGaps runs" do
    tests "IdentifyGaps", on: "QualityReport"
    setup  "AssessQuality", jsonl_path: "sample"
    expect ok: "true"
  end


  # ── Enrichment aggregate ──────────────────────────────────────────

  test "ConfirmBoots sets domain_name" do
    tests "ConfirmBoots", on: "Enrichment"
    input  domain_name: "sample"
    expect boots: true
  end

  test "EnrichDomain sets domain_name + enrichment_type" do
    tests "EnrichDomain", on: "Enrichment"
    setup  "ConfirmBoots", domain_name: "sample"
    input  domain_name: "sample", enrichment_type: "sample"
    expect ok: "true"
  end

  test "Revalidate runs" do
    tests "Revalidate", on: "Enrichment"
    setup  "ConfirmBoots", domain_name: "sample"
    expect ok: "true"
  end


  # ── TrainingHarvest aggregate ──────────────────────────────────────────

  test "HarvestTrainingData sets root_path + output_path" do
    tests "HarvestTrainingData", on: "TrainingHarvest"
    input  root_path: "sample", output_path: "sample"
    expect ok: "true"
  end

  test "CompareVersions sets previous_path" do
    tests "CompareVersions", on: "TrainingHarvest"
    setup  "HarvestTrainingData", root_path: "sample", output_path: "sample"
    input  previous_path: "sample"
    expect ok: "true"
  end


  # ── CorpusGrowth aggregate ──────────────────────────────────────────

  test "GrowCorpus sets target_count" do
    tests "GrowCorpus", on: "CorpusGrowth"
    input  target_count: 1
    expect ok: "true"
  end

end
