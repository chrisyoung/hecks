Hecks.bluebook "CloudTraining", version: "2026.04.13.1" do
  vision "Train Summer on cloud GPUs when the laptop isn't enough — upload data, rent compute, download adapter, run locally"
  category "capability"

  aggregate "TrainingJob", "A remote fine-tuning run on a cloud GPU" do
    attribute :provider, String
    attribute :gpu_type, String
    attribute :base_model, String
    attribute :adapter_name, String
    attribute :iterations, Integer
    attribute :learning_rate, Float
    attribute :cost_estimate, Float
    attribute :final_loss, Float
    attribute :status, String
    attribute :checkpoints, list_of(Checkpoint)
    # Booleans the planner can chain on. data_ready is set by an upstream
    # DataUpload event-handler (LinkUploadedData). running flips on submit
    # and off on completion/cancel. remote_complete flips when MonitorJob
    # observes the remote side finished.
    attribute :data_ready, Boolean, default: false
    attribute :running, Boolean, default: false
    attribute :remote_complete, Boolean, default: false

    value_object "Checkpoint" do
      attribute :iteration, Integer
      attribute :train_loss, Float
      attribute :val_loss, Float
      attribute :saved_at, String
    end

    command "LinkUploadedData" do
      description "Record that DataUpload has finished staging — gates SubmitJob"
      emits "UploadedDataLinked"
      then_set :data_ready, to: true
    end

    command "SubmitJob" do
      description "Upload training data and launch a fine-tuning job on cloud GPU"
      attribute :provider, String
      attribute :gpu_type, String
      attribute :base_model, String
      attribute :iterations, Integer
      attribute :learning_rate, Float
      given { data_ready == true }
      emits "JobSubmitted"
      then_set :running, to: true
    end

    command "MonitorJob" do
      description "Poll the remote job for progress — loss, checkpoints, completion"
      reference_to(TrainingJob)
      emits "JobMonitored"
      then_set :remote_complete, to: true
    end

    command "CompleteJob" do
      description "Job finished — download the adapter weights"
      reference_to(TrainingJob)
      given { remote_complete == true }
      emits "JobCompleted"
      then_set :running, to: false
    end

    command "CancelJob" do
      description "Stop a running job to save cost"
      reference_to(TrainingJob)
      given { running == true }
      emits "JobCancelled"
      then_set :running, to: false
    end
  end

  aggregate "DataUpload", "Training data staged for cloud transfer" do
    attribute :local_path, String
    attribute :remote_path, String
    attribute :pair_count, Integer
    attribute :size_mb, Float
    attribute :checksum, String
    # Set true when ValidateJsonl confirms train.jsonl + valid.jsonl exist.
    # StageData gates on it; planner picks ValidateJsonl as the producer.
    attribute :jsonl_valid, Boolean, default: false

    command "ValidateJsonl" do
      description "Confirm train.jsonl and valid.jsonl exist and parse — required before staging"
      attribute :local_path, String
      emits "JsonlValidated"
      then_set :jsonl_valid, to: true
    end

    command "StageData" do
      description "Prepare and validate training data for upload"
      attribute :local_path, String
      given { jsonl_valid == true }
      emits "DataStaged"
    end

    command "UploadData" do
      description "Transfer training data to cloud storage"
      reference_to(DataUpload)
      attribute :remote_path, String
      emits "DataUploaded"
    end
  end

  aggregate "AdapterDownload", "Trained adapter weights pulled back to the laptop" do
    attribute :remote_path, String
    attribute :local_path, String
    attribute :size_mb, Float
    attribute :format, String
    attribute :converted, TrueClass
    # Boolean the planner uses for DeploySummer's precondition. Flipped by
    # ConvertToOllama.
    attribute :adapter_converted, Boolean, default: false

    command "DownloadAdapter" do
      description "Pull the trained LoRA adapter from cloud to local"
      attribute :remote_path, String
      attribute :local_path, String
      emits "AdapterDownloaded"
    end

    command "ConvertToOllama" do
      description "Convert the adapter to GGUF and create an Ollama model"
      reference_to(AdapterDownload)
      attribute :ollama_model_name, String
      emits "AdapterConverted"
      then_set :adapter_converted, to: true
    end

    command "DeploySummer" do
      description "Replace Summer's current adapter with the new one and restart"
      reference_to(AdapterDownload)
      given { adapter_converted == true }
      emits "SummerDeployed"
    end
  end

  aggregate "CostTracker", "Track GPU spend across training jobs" do
    attribute :total_spent, Float
    attribute :budget_limit, Float
    attribute :history, list_of(JobCost)

    value_object "JobCost" do
      attribute :job_id, String
      attribute :provider, String
      attribute :gpu_type, String
      attribute :duration_minutes, Float
      attribute :cost, Float
    end

    command "RecordCost" do
      description "Log the cost of a completed training job"
      reference_to(TrainingJob)
      emits "CostRecorded"
    end

    command "CheckBudget" do
      description "Verify spending is within budget before submitting a new job"
      given { total_spent < budget_limit }
      emits "BudgetChecked"
    end
  end

  # Pipeline: stage → upload → submit → monitor → complete → download → convert → deploy
  policy "UploadOnStage" do
    on "DataStaged"
    trigger "UploadData"
  end

  policy "SubmitOnUpload" do
    on "DataUploaded"
    trigger "SubmitJob"
  end

  policy "MonitorOnSubmit" do
    on "JobSubmitted"
    trigger "MonitorJob"
  end

  policy "DownloadOnComplete" do
    on "JobCompleted"
    trigger "DownloadAdapter"
  end

  policy "ConvertOnDownload" do
    on "AdapterDownloaded"
    trigger "ConvertToOllama"
  end

  policy "DeployOnConvert" do
    on "AdapterConverted"
    trigger "DeploySummer"
  end

  policy "TrackCostOnComplete" do
    on "JobCompleted"
    trigger "RecordCost"
  end

  policy "CheckBudgetOnStage" do
    on "DataStaged"
    trigger "CheckBudget"
  end
end
