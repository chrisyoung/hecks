Hecks.bluebook "DomainCrossover", version: "2026.04.13.1" do
  vision "Breed new domains from existing ones — take aggregates from two parents, cross-wire policies, validate the child"
  category "capability"

  aggregate "ParentPair", "Two domains selected for crossover based on vector compatibility" do
    attribute :parent_a, String
    attribute :parent_b, String
    attribute :similarity, Float
    attribute :complementarity, Float
    attribute :shared_concepts, list_of(String)

    command "SelectPair" do
      description "Find two domains whose vectors are similar enough to combine but different enough to be interesting"
      attribute :min_similarity, Float
      attribute :max_similarity, Float
      given { min_similarity >= 0.3 }
      given { max_similarity <= 0.8 }
      given { min_similarity < max_similarity }
      emits "PairSelected"
    end
  end

  aggregate "Offspring", "A new domain bred from two parents — inherits aggregates and policies from both" do
    attribute :name, String
    attribute :vision, String
    attribute :parent_a, String
    attribute :parent_b, String
    attribute :aggregates_from_a, list_of(String)
    attribute :aggregates_from_b, list_of(String)
    attribute :cross_policies, list_of(String)
    attribute :valid, TrueClass
    # Flipped true by ValidateOffspring; EnrichOffspring gates on it.
    attribute :validated, Boolean, default: false

    command "BreedDomain" do
      description "Combine aggregates from two parents and wire cross-domain policies between them"
      reference_to(ParentPair)
      attribute :name, String
      attribute :vision, String
      attribute :aggregates_from_each, Integer
      emits "DomainBred"
    end

    command "ValidateOffspring" do
      description "Parse and validate the bred domain — does it boot?"
      reference_to(Offspring)
      emits "OffspringValidated"
      then_set :validated, to: true
    end

    command "EnrichOffspring" do
      description "Add givens, references, and value objects the crossover missed"
      reference_to(Offspring)
      given { validated == true }
      emits "OffspringEnriched"
    end
  end

  aggregate "Generation", "One batch of crossover breeding — track yield rate and quality" do
    attribute :generation_number, Integer
    attribute :pairs_attempted, Integer
    attribute :offspring_valid, Integer
    attribute :offspring_strong, Integer
    attribute :yield_rate, Float

    command "RunGeneration" do
      description "Select N parent pairs, breed each one, validate and assess"
      attribute :pair_count, Integer
      emits "GenerationComplete"
    end

    command "AssessGeneration" do
      description "Compare this generation's quality to the previous one"
      reference_to(Generation)
      emits "GenerationAssessed"
    end
  end

  policy "BreedOnSelect" do
    on "PairSelected"
    trigger "BreedDomain"
  end

  policy "ValidateOnBreed" do
    on "DomainBred"
    trigger "ValidateOffspring"
  end

  policy "EnrichOnValidate" do
    on "OffspringValidated"
    trigger "EnrichOffspring"
  end

  policy "AssessOnGeneration" do
    on "GenerationComplete"
    trigger "AssessGeneration"
  end
end
