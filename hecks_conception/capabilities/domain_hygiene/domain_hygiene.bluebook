Hecks.bluebook "DomainHygiene", version: "2026.04.13.1" do
  vision "Miette keeps her domains healthy — finds gaps, enriches weak domains, tracks training data quality"
  category "capability"

  aggregate "HealthCheck", "A scan of the full corpus — what boots, what fails, what's missing" do
    attribute :total_domains, Integer
    attribute :valid_count, Integer
    attribute :invalid_count, Integer
    attribute :failures, list_of(ValidationFailure)
    attribute :scanned_at, String

    value_object "ValidationFailure" do
      attribute :domain_name, String
      attribute :file_path, String
      attribute :error_message, String
    end

    command "ScanCorpus" do
      description "Parse and validate every bluebook — report what boots and what breaks"
      attribute :root_path, String
      emits "CorpusScanned"
    end
  end

  aggregate "QualityReport", "Training data quality metrics — bias, gaps, coverage" do
    attribute :total_pairs, Integer
    attribute :unique_domains, Integer
    attribute :with_policies, Integer
    attribute :with_references, Integer
    attribute :duplicates, Integer
    attribute :distribution, list_of(CategoryCount)
    attribute :gaps, list_of(String)

    value_object "CategoryCount" do
      attribute :category, String
      attribute :count, Integer
      attribute :percentage, Float
    end

    command "AssessQuality" do
      description "Analyze the training JSONL for bias, missing features, and category balance"
      attribute :jsonl_path, String
      emits "QualityAssessed"
    end

    command "IdentifyGaps" do
      description "Find underrepresented categories and missing structural features"
      reference_to(QualityReport)
      emits "GapsIdentified"
    end
  end

  aggregate "Enrichment", "A targeted fix to a weak domain — add policies, events, descriptions, or givens" do
    attribute :domain_name, String
    attribute :enrichment_type, String
    attribute :before_state, String
    attribute :after_state, String
    attribute :revalidated, TrueClass
    # Flipped true by ConfirmBoots; EnrichDomain gates on it. Planner picks
    # ConfirmBoots as the producer.
    attribute :boots, TrueClass, default: false

    command "ConfirmBoots" do
      description "Parse the target domain and confirm it boots — required before enrichment"
      attribute :domain_name, String
      emits "BootConfirmed"
      then_set :boots, to: true
    end

    command "EnrichDomain" do
      description "Add missing policies, events, or descriptions to a domain that lacks them"
      attribute :domain_name, String
      attribute :enrichment_type, String
      given { boots == true }
      emits "DomainEnriched"
    end

    command "Revalidate" do
      description "Re-parse and validate after enrichment to confirm the domain still boots"
      reference_to(Enrichment)
      emits "EnrichmentValidated"
    end
  end

  aggregate "TrainingHarvest", "Extract training pairs from the corpus and track dataset evolution" do
    attribute :output_path, String
    attribute :pair_count, Integer
    attribute :strong_pairs, Integer
    attribute :harvested_at, String

    command "HarvestTrainingData" do
      description "Walk all valid bluebooks, extract prompt/completion pairs as JSONL"
      attribute :root_path, String
      attribute :output_path, String
      emits "DataHarvested"
    end

    command "CompareVersions" do
      description "Diff two training JSONL files to see what improved"
      reference_to(TrainingHarvest)
      attribute :previous_path, String
      emits "VersionsCompared"
    end
  end

  aggregate "CorpusGrowth", "The loop — conceive domains, validate, repair failures, enrich shallow ones, harvest" do
    attribute :target_count, Integer
    attribute :conceived, Integer
    attribute :valid, Integer
    attribute :repaired, Integer
    attribute :enriched, Integer
    attribute :harvested, Integer
    attribute :waves, list_of(GrowthWave)
    # Flipped true once RepairFailures finishes — at that point the wave's
    # remaining domains are valid and ready for enrichment.
    attribute :wave_valid, Boolean, default: false

    value_object "GrowthWave" do
      attribute :wave_number, Integer
      attribute :attempted, Integer
      attribute :survived, Integer
      attribute :repaired, Integer
      attribute :phase, String
    end

    command "GrowCorpus" do
      description "Launch a growth cycle — conceive N domains across diverse topics"
      attribute :target_count, Integer
      emits "GrowthStarted"
    end

    command "ConceiveBatch" do
      description "Conceive a batch of domains from visions — fan out to parallel agents"
      reference_to(CorpusGrowth)
      attribute :batch_size, Integer
      attribute :topics, list_of(String)
      emits "BatchConceived"
    end

    command "RepairFailures" do
      description "Read validation errors, fix the bluebooks, revalidate"
      reference_to(CorpusGrowth)
      emits "FailuresRepaired"
      then_set :wave_valid, to: true
    end

    command "EnrichShallow" do
      description "Add policies, references, and givens to valid but thin domains"
      reference_to(CorpusGrowth)
      given { wave_valid == true }
      emits "ShallowEnriched"
    end

    command "ReportGrowth" do
      description "Summarize what survived — count, depth, category distribution"
      reference_to(CorpusGrowth)
      emits "GrowthReported"
    end
  end

  policy "ConceiveOnGrowth" do
    on "GrowthStarted"
    trigger "ConceiveBatch"
  end

  policy "RepairOnConceive" do
    on "BatchConceived"
    trigger "RepairFailures"
  end

  policy "EnrichOnRepair" do
    on "FailuresRepaired"
    trigger "EnrichShallow"
  end

  policy "HarvestOnEnrich" do
    on "ShallowEnriched"
    trigger "HarvestTrainingData"
  end

  policy "ReportOnHarvest" do
    on "DataHarvested"
    trigger "ReportGrowth"
  end

  policy "AssessAfterHarvest" do
    on "DataHarvested"
    trigger "AssessQuality"
  end

  policy "FindGapsAfterAssessment" do
    on "QualityAssessed"
    trigger "IdentifyGaps"
  end

  policy "RevalidateAfterEnrichment" do
    on "DomainEnriched"
    trigger "Revalidate"
  end

  policy "ReharvesAfterEnrichment" do
    on "EnrichmentValidated"
    trigger "HarvestTrainingData"
  end
end
