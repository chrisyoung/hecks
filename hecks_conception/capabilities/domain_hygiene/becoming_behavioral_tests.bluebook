  test "RunFineTune sets base_model + iterations + learning_rate" do
    tests "RunFineTune", on: "Train"
    setup  "PrepareSplit"
    input  base_model: "sample", iterations: 1, learning_rate: 1.0
    expect ok: "true"
  end

  test "RunFineTune cascades through policy chain" do
    tests "RunFineTune", on: "Train", kind: :cascade
