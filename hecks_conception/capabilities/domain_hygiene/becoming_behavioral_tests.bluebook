Hecks.behaviors "Becoming" do
  vision "Behavioral tests for the Becoming domain — exercises every command and query in memory"

  # ── Harvest aggregate ──────────────────────────────────────────

  test "ScanNursery sets nursery_path" do
    tests "ScanNursery", on: "Harvest"
    input  nursery_path: "sample"
    expect nursery_ready: true
  end

  test "HarvestDomains sets nursery_path" do
    tests "HarvestDomains", on: "Harvest"
    setup  "ScanNursery", nursery_path: "sample"
    input  nursery_path: "sample"
    expect ok: "true"
  end

  test "HarvestDomains cascades through policy chain" do
    tests "HarvestDomains", on: "Harvest", kind: :cascade
    setup  "VaryPrompts"
    setup  "AddCrossAggregateFlows"
    setup  "ConceiveNewDomains", topics: "sample", target_count: 1
    setup  "PrepareSplit"
    setup  "RunEvaluation"
    setup  "ScanNursery", nursery_path: "sample"
    input  nursery_path: "sample"
    expect emits: ["DomainsHarvested", "PromptsVaried", "NegativesGenerated", "ChainOfThoughtAdded", "CategoriesBalanced", "CrossAggregateFlowsAdded", "WorkflowsDeepened", "NewDomainsConceived", "CrossoversBred", "SplitPrepared", "FineTuneComplete", "EvaluationComplete", "BaselineCompared", "NextRoundDecided"]
  end

  test "HarvestConversations runs" do
    tests "HarvestConversations", on: "Harvest"
    expect ok: "true"
  end

  test "HarvestDreams runs" do
    tests "HarvestDreams", on: "Harvest"
    expect ok: "true"
  end

  test "HarvestIdentity runs" do
    tests "HarvestIdentity", on: "Harvest"
    expect ok: "true"
  end


