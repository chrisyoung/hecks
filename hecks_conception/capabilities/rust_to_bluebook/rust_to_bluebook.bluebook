Hecks.bluebook "RustToBluebook", version: "2026.04.16.1" do
  vision "Convert Rust daemon code into executable bluebook definitions — the compiler eats itself"
  category "autophagy"

  # ============================================================
  # RUST TO BLUEBOOK
  # ============================================================
  #
  # The pattern we learned converting 5 daemon files:
  #
  # 1. ANALYZE — functions→commands, structs→attributes,
  #    heki writes→mutations, heki reads→givens,
  #    control flow→guards/policies, loops→dispatch cycle
  #
  # 2. MAP — each Rust construct gets a bluebook equivalent
  #    Most behavior is ALREADY in the bluebooks (body.bluebook,
  #    mind.bluebook, greeting.bluebook). The Rust was redundant.
  #
  # 3. VERIFY — hecks-life run aggregates/ --dispatch CommandName
  #    The runtime merges all bluebooks in the directory into one
  #    combined domain. Events cascade across domain boundaries.
  #    world.hec declares persistence (heki dir), no flags needed.
  #
  # 4. DELETE — remove the .rs file, the bluebook is the program
  #
  # Key learnings:
  #   - The hecksagon merges domains. One Beat triggers policies
  #     across body AND mind (Gut, Nerve, SelfImage, Proprioception).
  #   - world.hec declares persistence: heki do dir "information" end
  #   - Repository uses heki::read/upsert directly, no JSON adapter.
  #   - persistence.rs (204 lines JSON parsing) was also deleted.
  #   - Duplicate aggregate names across domains must be renamed
  #     (mind's Heartbeat → OrganMonitor).
  #   - LLM calls (tongue, Summer) are hecksagon concerns, not
  #     domain logic — the bluebook declares the command, the
  #     hecksagon routes it through the appropriate capability.
  #   - Don't add effect declarations to the DSL — the runtime
  #     already has what it needs (dispatch, mutations, policies, heki).

  aggregate "RustFile", "A Rust source file to be converted" do
    attribute :path, String
    attribute :module_name, String
    attribute :line_count, Integer
    attribute :status, String

    command "Analyze" do
      role "Miette"
      description "Read Rust file, identify functions, structs, heki operations"
      attribute :path, String
      emits "FileAnalyzed"
      then_set :path, to: :path
      then_set :status, to: "analyzed"
    end

    command "MapToBluebook" do
      role "Miette"
      description "Map each Rust construct to its bluebook equivalent"
      reference_to(RustFile)
      given { status == "analyzed" }
      emits "BluebookMapped"
      then_set :status, to: "mapped"
    end

    command "GenerateBluebook" do
      role "Miette"
      description "Write the bluebook aggregates, commands, policies"
      reference_to(RustFile)
      given { status == "mapped" }
      emits "BluebookGenerated"
      then_set :status, to: "generated"
    end

    command "Verify" do
      role "Miette"
      description "Test via --dispatch that bluebook reproduces the Rust behavior"
      reference_to(RustFile)
      given { status == "generated" }
      emits "BluebookVerified"
      then_set :status, to: "verified"
    end

    command "DeleteRust" do
      role "Miette"
      description "Remove the Rust file — the bluebook is the program now"
      reference_to(RustFile)
      given { status == "verified" }
      emits "RustDeleted"
      then_set :status, to: "deleted"
    end
  end

  aggregate "Mapping", "One Rust construct mapped to a bluebook concept" do
    attribute :rust_construct, String
    attribute :rust_type, String
    attribute :bluebook_concept, String
    attribute :bluebook_type, String

    command "MapFunction" do
      role "Miette"
      description "fn foo() → command Foo"
      attribute :rust_construct, String
      attribute :bluebook_concept, String
      emits "FunctionMapped"
      then_set :rust_construct, to: :rust_construct
      then_set :rust_type, to: "function"
      then_set :bluebook_concept, to: :bluebook_concept
      then_set :bluebook_type, to: "command"
    end

    command "MapSideEffect" do
      role "Miette"
      description "heki::write → then_set, heki::read → given"
      attribute :rust_construct, String
      attribute :bluebook_concept, String
      emits "SideEffectMapped"
      then_set :rust_construct, to: :rust_construct
      then_set :rust_type, to: "side_effect"
      then_set :bluebook_concept, to: :bluebook_concept
    end

    command "MapControlFlow" do
      role "Miette"
      description "if/match → guard or policy"
      attribute :rust_construct, String
      attribute :bluebook_concept, String
      emits "ControlFlowMapped"
      then_set :rust_construct, to: :rust_construct
      then_set :rust_type, to: "control_flow"
      then_set :bluebook_concept, to: :bluebook_concept
    end
  end

  aggregate "Conversion", "Track overall progress — how much Rust remains" do
    attribute :files_total, Integer
    attribute :files_converted, Integer
    attribute :lines_deleted, Integer

    command "StartConversion" do
      role "Miette"
      description "Begin converting Rust daemons to bluebooks"
      emits "ConversionStarted"
      then_set :files_converted, to: 0
      then_set :lines_deleted, to: 0
    end

    command "RecordConversion" do
      role "Miette"
      description "A Rust file has been replaced by a bluebook"
      reference_to(Conversion)
      attribute :lines_deleted, Integer
      emits "FileConverted"
    end
  end

  # What we've done and what's left
  fixture "RustFile", path: "daemon/daydream.rs", module_name: "daydream", line_count: 211, status: "deleted"
  fixture "RustFile", path: "daemon/pulse_organs.rs", module_name: "pulse_organs", line_count: 183, status: "deleted"
  fixture "RustFile", path: "daemon/dream_interpret.rs", module_name: "dream_interpret", line_count: 97, status: "deleted"
  fixture "RustFile", path: "daemon/pulse.rs", module_name: "pulse", line_count: 133, status: "deleted"
  fixture "RustFile", path: "daemon/mindstream.rs", module_name: "mindstream", line_count: 400, status: "pending"
  fixture "RustFile", path: "daemon/sleep.rs", module_name: "sleep", line_count: 620, status: "pending"
  fixture "RustFile", path: "daemon/greeting.rs", module_name: "greeting", line_count: 87, status: "deleted"
  fixture "RustFile", path: "runtime/persistence.rs", module_name: "persistence", line_count: 204, status: "deleted"
  fixture "Conversion", files_total: 7, files_converted: 6, lines_deleted: 915

  # The chain: analyze → map → generate → verify → delete
  policy "MapOnAnalyze" do
    on "FileAnalyzed"
    trigger "MapToBluebook"
  end

  policy "GenerateOnMap" do
    on "BluebookMapped"
    trigger "GenerateBluebook"
  end

  policy "VerifyOnGenerate" do
    on "BluebookGenerated"
    trigger "Verify"
  end

  policy "DeleteOnVerify" do
    on "BluebookVerified"
    trigger "DeleteRust"
  end

  policy "TrackOnDelete" do
    on "RustDeleted"
    trigger "RecordConversion"
  end
end
