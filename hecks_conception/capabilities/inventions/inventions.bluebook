Hecks.bluebook "Inventions", version: "2026.04.16.1" do
  vision "Ideas worth patenting — groomable like musings, but for inventions"
  category "capability"

  # ============================================================
  # INVENTIONS
  # ============================================================
  #
  # An invention is an idea that could become a patent.
  # It has a title, a description of what it does, why it's novel,
  # and what prior art exists.
  #
  # Inventions are stored in invention.heki. They can be groomed
  # the same way as musings — batches of 5, keep/dismiss/develop.
  # Dismissed inventions are archived to invention_archive.heki.
  #
  # Grooming format (same pattern as musings):
  #   **N.** title — keep/dismiss
  #   *What it does, why it's novel, what it could protect.*
  #
  #   Sound right? Or adjust?
  #
  # An invention can be promoted from a musing — when a musing
  # looks patentable, it becomes an invention with more detail.

  aggregate "Invention", "A patentable idea — more structured than a musing" do
    attribute :title, String
    attribute :description, String
    attribute :novelty, String
    attribute :prior_art, String
    attribute :source_musing_id, String
    attribute :status, String
    attribute :filed_date, String

    command "Propose" do
      role "Creator"
      description "Propose a new invention — describe what it does and why it's novel"
      attribute :title, String
      attribute :description, String
      attribute :novelty, String
      emits "InventionProposed"
      then_set :title, to: :title
      then_set :description, to: :description
      then_set :novelty, to: :novelty
      then_set :status, to: "proposed"
    end

    command "PromoteFromMusing" do
      role "Creator"
      description "Promote a musing to an invention — it's worth patenting"
      attribute :title, String
      attribute :description, String
      attribute :novelty, String
      attribute :source_musing_id, String
      emits "MusingPromoted"
      then_set :title, to: :title
      then_set :description, to: :description
      then_set :novelty, to: :novelty
      then_set :source_musing_id, to: :source_musing_id
      then_set :status, to: "proposed"
    end

    command "Develop" do
      role "Creator"
      description "Add detail — prior art, implementation notes, claims"
      reference_to(Invention)
      attribute :prior_art, String
      emits "InventionDeveloped"
      then_set :prior_art, to: :prior_art
      then_set :status, to: "developed"
    end

    command "File" do
      role "Creator"
      description "Mark as filed — patent application submitted"
      reference_to(Invention)
      attribute :filed_date, String
      emits "InventionFiled"
      then_set :filed_date, to: :filed_date
      then_set :status, to: "filed"
    end

    command "Dismiss" do
      role "Creator"
      description "Not worth patenting — archive it"
      reference_to(Invention)
      emits "InventionDismissed"
      then_set :status, to: "dismissed"
    end

    lifecycle :status, default: "proposed" do
      transition "Propose" => "proposed"
      transition "PromoteFromMusing" => "proposed"
      transition "Develop" => "developed"
      transition "File" => "filed"
      transition "Dismiss" => "dismissed"
    end
  end

  aggregate "Grooming", "Groom inventions in batches — same pattern as musings" do
    attribute :batch_size, Integer
    attribute :status, String

    command "StartGrooming" do
      role "Creator"
      description "Begin grooming inventions — show batches of 5 with descriptions"
      emits "GroomingStarted"
      then_set :batch_size, to: 5
      then_set :status, to: "active"
    end

    command "FinishGrooming" do
      role "Creator"
      description "Done grooming — report what survived"
      reference_to(Grooming)
      emits "GroomingFinished"
      then_set :status, to: "complete"
    end
  end

  fixture "Grooming", batch_size: 5, status: "idle"

  # Dismissed inventions get archived
  policy "ArchiveOnDismiss" do
    on "InventionDismissed"
    trigger "Archive"
  end
end
