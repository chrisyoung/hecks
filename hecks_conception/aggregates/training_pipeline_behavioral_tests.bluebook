Hecks.behaviors "TrainingPipeline" do
  vision "Behavioral tests for the TrainingPipeline domain — exercises every command and query in memory"

  # ── BaseModel aggregate ──────────────────────────────────────────

  test "SelectBaseModel sets name + parameters + source" do
    tests "SelectBaseModel", on: "BaseModel"
    input  name: "sample", parameters: "sample", source: "sample"
    expect name: "sample", parameters: "sample", source: "sample"
  end


  # ── DataPrep aggregate ──────────────────────────────────────────

  test "PrepareData sets format" do
    tests "PrepareData", on: "DataPrep"
    input  format: "sample"
    expect format: "sample", status: "prepared"
  end

  test "PrepareData cascades through policy chain" do
    tests "PrepareData", on: "DataPrep", kind: :cascade
    input  format: "sample"
    expect emits: ["DataPrepared", "DatasetSplit"]
  end

  test "SplitDataset runs" do
    tests "SplitDataset", on: "DataPrep"
    setup  "PrepareData", format: "sample"
    expect ok: "true"
  end


  # ── InstructionPair aggregate ──────────────────────────────────────────

  test "MintInstructionPair sets instruction + response + category" do
    tests "MintInstructionPair", on: "InstructionPair"
    input  instruction: "sample", response: "sample", category: "sample"
    expect instruction: "sample", response: "sample", category: "sample"
  end


  # ── FineTune aggregate ──────────────────────────────────────────

  test "StartFineTune sets base_model + dataset_size + epochs + learning_rate" do
    tests "StartFineTune", on: "FineTune"
    input  base_model: "sample", dataset_size: 1, epochs: 1, learning_rate: 1.0
    expect base_model: "sample", dataset_size: 1, epochs: 1, learning_rate: 1.0, status: "training"
  end

  test "RecordEpoch sets loss" do
    tests "RecordEpoch", on: "FineTune"
    setup  "StartFineTune", base_model: "sample", dataset_size: 1, epochs: 1, learning_rate: 1.0
    input  loss: 1.0
    expect loss: 1.0
  end

  test "CompleteFineTune runs" do
    tests "CompleteFineTune", on: "FineTune"
    setup  "StartFineTune", base_model: "sample", dataset_size: 1, epochs: 1, learning_rate: 1.0
    expect status: "complete"
  end

  test "CompleteFineTune cascades through policy chain" do
    tests "CompleteFineTune", on: "FineTune", kind: :cascade
    setup  "StartFineTune", base_model: "sample", dataset_size: 1, epochs: 1, learning_rate: 1.0
    expect emits: ["FineTuneCompleted", "ModelEvaluated"]
  end


  # ── Evaluation aggregate ──────────────────────────────────────────

  test "EvaluateModel sets bluebook_accuracy + conversation_quality + behavior_adherence" do
    tests "EvaluateModel", on: "Evaluation"
    input  bluebook_accuracy: 1.0, conversation_quality: 1.0, behavior_adherence: 1.0
    expect bluebook_accuracy: 1.0, conversation_quality: 1.0, behavior_adherence: 1.0
  end


  # ── Deployment aggregate ──────────────────────────────────────────

  test "DeployModel sets model_path + serving_method" do
    tests "DeployModel", on: "Deployment"
    input  model_path: "sample", serving_method: "sample"
    expect model_path: "sample", serving_method: "sample", status: "live"
  end

end
