Hecks.behaviors "Corpus" do
  vision "Behavioral tests for the Corpus domain — exercises every command and query in memory"

  # ── Search aggregate ──────────────────────────────────────────

  test "IndexPhrase sets input + matched_phrase + domain + aggregate + command" do
    tests "IndexPhrase", on: "Search"
    input  input: "sample", matched_phrase: "sample", domain: "sample", aggregate: "sample", command: "sample"
    expect input: "sample", matched_phrase: "sample", domain: "sample", aggregate: "sample", command: "sample"
  end

  test "MatchInput returns matching records" do
    tests "MatchInput", on: "Search", kind: :query
    setup  "IndexPhrase", input: "sample", matched_phrase: "sample", domain: "sample", aggregate: "sample", command: "sample"
    expect count: 1
  end

  test "ListAll returns matching records" do
    tests "ListAll", on: "Search", kind: :query
    setup  "IndexPhrase", input: "sample", matched_phrase: "sample", domain: "sample", aggregate: "sample", command: "sample"
    expect count: 1
  end

end
