Hecks.behaviors "Mindstream" do
  vision "Behavioral tests for the Mindstream domain — exercises every command and query in memory"

  # ── Tick aggregate ──────────────────────────────────────────

  test "MindstreamTick runs" do
    tests "MindstreamTick", on: "Tick"
    expect ok: "true"
  end

  test "MindstreamTick cascades through policy chain" do
    tests "MindstreamTick", on: "Tick", kind: :cascade
    # After PR #261 (BodyPulse rewiring): EmitPulseOnTick triggers
    # `Pulse.Emit` via `across "Pulse"` — Pulse lives in its own
    # bluebook. The single-bluebook behaviors runner can't cross
    # that boundary, so the cascade terminates at `Ticked`. The
    # downstream fanout (BodyPulse → Consolidate/Prune/Display/
    # PruneMusings) is now asserted in the respective subscriber
    # bluebooks' cascade tests.
    expect emits: ["Ticked"]
  end


  # ── Display aggregate ──────────────────────────────────────────

  test "RefreshDisplay sets current_thought + ideas_available" do
    tests "RefreshDisplay", on: "Display"
    input  current_thought: "sample", ideas_available: 1
    expect current_thought: "sample", ideas_available: 1
  end


  # ── MusingMint aggregate ──────────────────────────────────────────

  test "MintMusing sets idea" do
    tests "MintMusing", on: "MusingMint"
    input  idea: "sample"
    expect last_minted: "sample"
  end

  test "MintMusing records source" do
    tests "MintMusing", on: "MusingMint"
    input  idea: "sample", source: "dream"
    expect last_minted: "sample", last_source: "dream"
  end

  test "PruneMusings runs" do
    tests "PruneMusings", on: "MusingMint"
    expect ok: "true"
  end


  # ── ClaudeAssist aggregate ──────────────────────────────────────────

  test "UseClaudeProvider runs" do
    tests "UseClaudeProvider", on: "ClaudeAssist"
    expect provider: "claude"
  end

  test "UseLocalProvider runs" do
    tests "UseLocalProvider", on: "ClaudeAssist"
    expect provider: "local"
  end

  test "DisableMinting runs" do
    tests "DisableMinting", on: "ClaudeAssist"
    expect provider: "off"
  end


  # ── SignalConsolidation aggregate ──────────────────────────────────────────

  test "ConsolidateSignals runs" do
    tests "ConsolidateSignals", on: "SignalConsolidation"
    expect ok: "true"
  end

  test "PruneSynapses runs" do
    tests "PruneSynapses", on: "SignalConsolidation"
    expect ok: "true"
  end

end
