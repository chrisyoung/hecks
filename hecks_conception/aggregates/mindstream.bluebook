Hecks.bluebook "Mindstream", version: "2026.04.16.1" do
  vision "Continuous background awareness — the unconscious that never stops"
  category "mind"

  # ============================================================
  # MINDSTREAM
  # ============================================================
  #
  # A tick fires every 10 seconds. Each tick:
  #   - Updates consciousness display (what the statusline shows)
  #   - Consolidates old signals into memories
  #   - Strengthens/weakens synapses
  #   - Mints musings (via Summer, every ~6 ticks)
  #   - Prunes repetitive musings
  #
  # The tick is dispatched externally (shell loop or hook).
  # The bluebook handles all the behavior.

  aggregate "Tick", "One cycle of the mindstream — fires every 10s" do
    attribute :cycle, Integer
    attribute :mood, String

    command "MindstreamTick" do
      description "One tick of background awareness"
      emits "Ticked"
      then_set :cycle, increment: 1
    end
  end

  aggregate "Display", "What the statusline shows — musings and domain pairs" do
    attribute :current_thought, String
    attribute :ideas_available, Integer

    command "RefreshDisplay" do
      description "Refresh the statusline thought"
      attribute :current_thought, String
      attribute :ideas_available, Integer
      emits "DisplayUpdated"
      then_set :current_thought, to: :current_thought
      then_set :ideas_available, to: :ideas_available
    end
  end

  aggregate "MusingMint", "Minting new musings — only really great ideas. Random domain collisions produce noise; quality requires curation. Claude (or any LLM adapter wired in via ClaudeAssist) is the quality filter." do
    attribute :last_minted, String
    attribute :last_source, String
    attribute :total_minted, Integer

    command "MintMusing" do
      description "Record a curated musing — the idea has been judged good enough to keep"
      attribute :idea, String
      attribute :source, String
      emits "MusingMinted"
      then_set :last_minted, to: :idea
      then_set :last_source, to: :source
      then_set :total_minted, increment: 1
    end

    command "PruneMusings" do
      description "Remove repetitive mindstream musings"
      emits "MusingsPruned"
    end
  end

  # ============================================================
  # CLAUDE ASSIST — toggle for LLM-driven musing curation
  # ============================================================
  #
  # When `enabled = "yes"` (and scope includes "musings"), an external
  # Claude/LLM adapter is allowed to read recent state and call
  # MintMusing with curated ideas. Default off — random noise minting
  # is worse than no minting; quality requires curation.
  #
  # Toggle:
  #   hecks-life aggregates ClaudeAssist.EnableClaude scope=musings
  #   hecks-life aggregates ClaudeAssist.DisableClaude

  aggregate "ClaudeAssist", "Selects which LLM does Miette's musing curation. Default is 'claude' — uses the Anthropic API if ANTHROPIC_API_KEY is set, otherwise falls back to the local `claude` CLI (Claude Code). User can switch to 'local' to use ollama (configured in the *.world file) instead, or 'off' to disable minting entirely." do
    attribute :provider, String

    command "UseClaudeProvider" do
      role "Creator"
      description "Use Claude (API if ANTHROPIC_API_KEY set; otherwise CLI). The default."
      then_set :provider, to: "claude"
      emits "ProviderSwitched"
    end

    command "UseLocalProvider" do
      role "Creator"
      description "Fall back to local ollama for musing curation"
      then_set :provider, to: "local"
      emits "ProviderSwitched"
    end

    command "DisableMinting" do
      role "Creator"
      description "Stop generating new musings entirely"
      then_set :provider, to: "off"
      emits "MintingDisabled"
    end
  end

  aggregate "SignalConsolidation", "Compress old signals into memories" do
    attribute :signals_consolidated, Integer
    attribute :synapses_pruned, Integer

    command "ConsolidateSignals" do
      description "Compress old signals into long-term memory"
      emits "SignalsConsolidated"
      then_set :signals_consolidated, increment: 1
    end

    command "PruneSynapses" do
      description "Compost dead synapses — connections that faded"
      emits "SynapsesPruned"
      then_set :synapses_pruned, increment: 1
    end
  end

  # Every Ticked fires the BodyPulse shim. See aggregates/pulse.bluebook.
  # BodyPulse is the pacing event that fatigue, sleep advancement,
  # awareness recording, consolidation, display, and organ-pulse
  # policies all subscribe to. This indirection means i3 PR-a can
  # replace the driver with Heart.HeartBeat by swapping ONE emitter —
  # no touching the N downstream subscribers. This is the sole
  # remaining subscriber to Ticked in the whole conception.
  policy "EmitPulseOnTick" do
    on "Ticked"
    trigger "Emit"
    across "Pulse"
  end

  # Every body pulse triggers consolidation and display
  policy "ConsolidateOnPulse" do
    on "BodyPulse"
    trigger "ConsolidateSignals"
  end

  policy "PruneOnPulse" do
    on "BodyPulse"
    trigger "PruneSynapses"
  end

  policy "DisplayOnPulse" do
    on "BodyPulse"
    trigger "RefreshDisplay"
  end

  policy "PruneMusingsOnPulse" do
    on "BodyPulse"
    trigger "PruneMusings"
  end
end
