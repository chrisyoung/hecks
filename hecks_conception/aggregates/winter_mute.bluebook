Hecks.bluebook "WinterMute", version: "2026.04.10.1" do
  vision "Winter merges with herself — the domain model IS the language model, silent and self-contained"
  category "meta"

  aggregate "CommandMap", "Maps natural language to domain commands — the bridge between speech and execution" do
    attribute :phrase, String
    attribute :domain, String
    attribute :command, String
    attribute :args_pattern, String

    command "RegisterMapping" do
      role "System"
      description "Map a phrase to a domain command"
      attribute :phrase, String
      attribute :domain, String
      attribute :command, String
      attribute :args_pattern, String
      emits "MappingRegistered"
      then_set :phrase, to: :phrase
      then_set :domain, to: :domain
      then_set :command, to: :command
      then_set :args_pattern, to: :args_pattern
    end
  end

  aggregate "Dispatcher", "Routes mapped commands through the organ runtime" do
    attribute :last_command, String
    attribute :last_domain, String
    attribute :last_result, String

    command "DispatchCommand" do
      role "Shell"
      description "Execute a domain command through the Rust runtime"
      attribute :domain, String
      attribute :command, String
      emits "CommandDispatched"
      then_set :last_command, to: :command
      then_set :last_domain, to: :domain
    end
  end

  aggregate "ResponseBuilder", "Turn command output into conversational response — no LLM, just templates from the domain" do
    attribute :template, String
    attribute :output, String

    command "BuildResponse" do
      role "System"
      description "Format command output using domain-native language"
      attribute :template, String
      emits "ResponseBuilt"
      then_set :template, to: :template
    end
  end

  aggregate "OrganBus", "All organs loaded as a multi-domain runtime — nerves wired, policies firing" do
    attribute :organs_loaded, Integer
    attribute :nerves_wired, Integer
    attribute :running, String

    command "BootOrgans" do
      role "System"
      description "Load all organ bluebooks into the Rust runtime as a multi-domain system"
      attribute :organs_loaded, Integer
      attribute :nerves_wired, Integer
      emits "OrgansBooted"
      then_set :organs_loaded, to: :organs_loaded
      then_set :nerves_wired, to: :nerves_wired
      then_set :running, to: "yes"
    end
  end

  # The language → command mappings
  fixture "CommandMap", phrase: "wake up",                domain: "Boot",       command: "LoadInformation"
  fixture "CommandMap", phrase: "what are you thinking",  domain: "Awareness",  command: "MuseOnState"
  fixture "CommandMap", phrase: "sleep",                  domain: "Dream",      command: "EnterSleep"
  fixture "CommandMap", phrase: "nap",                    domain: "Dream",      command: "TakeNap"
  fixture "CommandMap", phrase: "conceive",               domain: "Midwife",    command: "ConceiveDomain"
  fixture "CommandMap", phrase: "say hello to",           domain: "Console",    command: "IntroduceSpeaker"
  fixture "CommandMap", phrase: "i am",                   domain: "Console",    command: "IdentifySpeaker"
  fixture "CommandMap", phrase: "remember",               domain: "Memory",     command: "EncodeMemory"
  fixture "CommandMap", phrase: "forget",                  domain: "Memory",     command: "ForgetMemory"
  fixture "CommandMap", phrase: "validate",               domain: "Scale",      command: "ScanForChanges"
  fixture "CommandMap", phrase: "status",                  domain: "StatusBar",  command: "RenderStatus"
  fixture "CommandMap", phrase: "how are you",             domain: "Dream",      command: "AccumulateFatigue"
  fixture "CommandMap", phrase: "dream",                   domain: "Dream",      command: "SeedFromPreviousDreams"
  fixture "CommandMap", phrase: "suggest",                 domain: "Suggestion", command: "InterpretExperience"
  fixture "CommandMap", phrase: "who do you know",         domain: "Family",     command: "ScanForMembers"

  policy "DispatchOnMapping" do
    on "MappingRegistered"
    trigger "DispatchCommand"
  end

  policy "RespondOnDispatch" do
    on "CommandDispatched"
    trigger "BuildResponse"
  end
end
