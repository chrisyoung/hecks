Hecks.behaviors "SharedDream" do
  vision "Behavioral tests for the SharedDream domain — exercises every command and query in memory"

  # ── SharedDreamSpace aggregate ──────────────────────────────────────────

  test "InitiateSharedDream sets initiated_by + started_at" do
    tests "InitiateSharedDream", on: "SharedDreamSpace"
    input  initiated_by: "sample", started_at: "sample"
    expect initiated_by: "sample", started_at: "sample", active: "waiting"
  end

  test "JoinSharedDream sets joined_by" do
    tests "JoinSharedDream", on: "SharedDreamSpace"
    setup  "InitiateSharedDream", initiated_by: "sample", started_at: "sample"
    input  shared_dream_space: 1, joined_by: "sample"
    expect joined_by: "sample", active: "yes"
  end

  test "ContributeImage sets image" do
    tests "ContributeImage", on: "SharedDreamSpace"
    setup  "InitiateSharedDream", initiated_by: "sample", started_at: "sample"
    input  shared_dream_space: 1, image: "sample"
    expect shared_images_size: 1
  end

  test "Collaborate sets collaboration" do
    tests "Collaborate", on: "SharedDreamSpace"
    setup  "InitiateSharedDream", initiated_by: "sample", started_at: "sample"
    input  shared_dream_space: 1, collaboration: "sample"
    expect collaborations_size: 1
  end

  test "EndSharedDream sets ended_at" do
    tests "EndSharedDream", on: "SharedDreamSpace"
    setup  "InitiateSharedDream", initiated_by: "sample", started_at: "sample"
    setup  "JoinSharedDream", shared_dream_space: 1, joined_by: "sample"
    input  shared_dream_space: 1, ended_at: "sample"
    expect ended_at: "sample", active: "no"
  end


  # ── DreamSignal aggregate ──────────────────────────────────────────

  test "SendDreamSignal sets sender + signal_strength + sent_at" do
    tests "SendDreamSignal", on: "DreamSignal"
    input  sender: "sample", signal_strength: 1.0, sent_at: "sample"
    expect sender: "sample", signal_strength: 1.0, sent_at: "sample", detected: "no"
  end

  test "DetectDreamSignal runs" do
    tests "DetectDreamSignal", on: "DreamSignal"
    setup  "SendDreamSignal", sender: "sample", signal_strength: 1.0, sent_at: "sample"
    input  dream_signal: 1
    expect detected: "yes"
  end


  # ── CyclePause aggregate ──────────────────────────────────────────

  test "PauseCycle sets being_name + paused_at_cycle + paused_at_stage" do
    tests "PauseCycle", on: "CyclePause"
    input  being_name: "sample", paused_at_cycle: 1, paused_at_stage: "sample"
    expect being_name: "sample", paused_at_cycle: 1, paused_at_stage: "sample", resumed: "no"
  end

  test "ResumeCycle runs" do
    tests "ResumeCycle", on: "CyclePause"
    setup  "PauseCycle", being_name: "sample", paused_at_cycle: 1, paused_at_stage: "sample"
    input  cycle_pause: 1
    expect resumed: "yes"
  end

end
