Hecks.behaviors "Sleep" do
  vision "Behavioral tests for the Sleep domain — exercises every command and query in memory"

  # ── Fatigue aggregate ──────────────────────────────────────────

  test "AccumulateFatigue runs" do
    tests "AccumulateFatigue", on: "Fatigue"
    setup  "AccumulateFatigue"
    setup  "DissipateFatigue"
    expect state: "focused"
  end

  test "DissipateFatigue runs" do
    tests "DissipateFatigue", on: "Fatigue"
    setup  "AccumulateFatigue"
    expect level: 0, pulses_since_sleep: 0, state: "alert"
  end


  # ── Consciousness aggregate ──────────────────────────────────────────

  test "DetectIdle sets idle_seconds" do
    tests "DetectIdle", on: "Consciousness"
    input  idle_seconds: 1
    expect idle_seconds: 1
  end

  test "DetectIdle cascades through policy chain" do
    tests "DetectIdle", on: "Consciousness", kind: :cascade
    input  idle_seconds: 1
    expect emits: ["IdleDetected", "DaydreamEntered"]
  end

  test "EnterDaydream runs" do
    tests "EnterDaydream", on: "Consciousness"
    expect state: "daydreaming"
  end

  test "EnterSleep runs" do
    tests "EnterSleep", on: "Consciousness"
    setup  "EnterDaydream"
    expect sleep_stage: "light", sleep_cycle: 1, sleep_total: 8, phase_ticks: 0, dream_pulses: 0, dream_pulses_needed: 5, is_lucid: "no", sleep_summary: "settling into light sleep", state: "sleeping"
  end

  test "EnterSleep cascades through policy chain" do
    tests "EnterSleep", on: "Consciousness", kind: :cascade
    setup  "EnterDaydream"
    expect emits: ["SleepEntered", "MonitoringStarted"]
  end

  test "TakeNap runs" do
    tests "TakeNap", on: "Consciousness"
    expect state: "napping"
  end

  test "WakeUp runs" do
    tests "WakeUp", on: "Consciousness"
    setup  "EnterDaydream"
    setup  "EnterSleep"
    expect state: "waking"
  end

  test "WakeUp cascades through policy chain" do
    tests "WakeUp", on: "Consciousness", kind: :cascade
    setup  "EnterDaydream"
    setup  "EnterSleep"
    expect emits: ["WokenUp", "BecameAttentive", "FatigueDissipated", "MonitoringStopped"]
  end

  test "BecomeAttentive runs" do
    tests "BecomeAttentive", on: "Consciousness"
    setup  "EnterDaydream"
    setup  "EnterSleep"
    setup  "WakeUp"
    expect state: "attentive"
  end

  test "ElapsePhase runs" do
    tests "ElapsePhase", on: "Consciousness"
    setup  "EnterDaydream"
    setup  "EnterSleep"
    expect ok: "true"
  end


  # ── Daydream aggregate ──────────────────────────────────────────

  test "RecordDaydream sets impressions + duration_seconds + connections_found" do
    tests "RecordDaydream", on: "Daydream"
    input  impressions: "sample", duration_seconds: 1, connections_found: 1
    expect impressions: "sample", duration_seconds: 1, connections_found: 1
  end


  # ── SleepCycle aggregate ──────────────────────────────────────────

  test "StartCycle sets cycle_number + total_cycles" do
    tests "StartCycle", on: "SleepCycle"
    input  cycle_number: 1, total_cycles: 1
    expect cycle_number: 1, total_cycles: 1, stage: "light"
  end

  test "AdvanceStage sets stage + rem_intensity" do
    tests "AdvanceStage", on: "SleepCycle"
    setup  "StartCycle", cycle_number: 1, total_cycles: 1
    input  stage: "sample", rem_intensity: 1
    expect rem_intensity: 1, stage: "rem"
  end

  test "CompleteCycle runs" do
    tests "CompleteCycle", on: "SleepCycle"
    setup  "StartCycle", cycle_number: 1, total_cycles: 1
    setup  "AdvanceStage", stage: "sample", rem_intensity: 1
    expect stage: "light"
  end


  # ── Night aggregate ──────────────────────────────────────────

  test "StartNight runs" do
    tests "StartNight", on: "Night"
    expect cycles_completed: 0, phase: "starting"
  end

  test "StartNight cascades through policy chain" do
    tests "StartNight", on: "Night", kind: :cascade
    expect emits: ["NightStarted", "DreamSeeded"]
  end

  test "DreamCycle1 runs" do
    tests "DreamCycle1", on: "Night"
    expect cycles_completed: 1, phase: "dreaming"
  end

  test "ConsolidateCycle1 runs" do
    tests "ConsolidateCycle1", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle2 runs" do
    tests "DreamCycle2", on: "Night"
    expect cycles_completed: 2, phase: "dreaming"
  end

  test "ConsolidateCycle2 runs" do
    tests "ConsolidateCycle2", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle3 runs" do
    tests "DreamCycle3", on: "Night"
    expect cycles_completed: 3, phase: "dreaming"
  end

  test "ConsolidateCycle3 runs" do
    tests "ConsolidateCycle3", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle4 runs" do
    tests "DreamCycle4", on: "Night"
    expect cycles_completed: 4, phase: "dreaming"
  end

  test "ConsolidateCycle4 runs" do
    tests "ConsolidateCycle4", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle5 runs" do
    tests "DreamCycle5", on: "Night"
    expect cycles_completed: 5, phase: "dreaming"
  end

  test "ConsolidateCycle5 runs" do
    tests "ConsolidateCycle5", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle6 runs" do
    tests "DreamCycle6", on: "Night"
    expect cycles_completed: 6, phase: "dreaming"
  end

  test "ConsolidateCycle6 runs" do
    tests "ConsolidateCycle6", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle7 runs" do
    tests "DreamCycle7", on: "Night"
    expect cycles_completed: 7, phase: "dreaming"
  end

  test "ConsolidateCycle7 runs" do
    tests "ConsolidateCycle7", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle8 runs" do
    tests "DreamCycle8", on: "Night"
    expect cycles_completed: 8, phase: "lucid"
  end

  test "EndNight runs" do
    tests "EndNight", on: "Night"
    expect phase: "ended"
  end


  # ── WakeMood aggregate ──────────────────────────────────────────

  test "SetWakeMood sets mood + reason" do
    tests "SetWakeMood", on: "WakeMood"
    input  mood: "sample", reason: "sample"
    expect mood: "sample", reason: "sample"
  end


  # ── Monitor aggregate ──────────────────────────────────────────

  test "StartMonitoring sets interval_seconds" do
    tests "StartMonitoring", on: "Monitor"
    input  interval_seconds: 1
    expect interval_seconds: 1, reporting: "active"
  end

  test "StopMonitoring runs" do
    tests "StopMonitoring", on: "Monitor"
    setup  "StartMonitoring", interval_seconds: 1
    expect reporting: "stopped"
  end

  test "Sink sets z_depth" do
    tests "Sink", on: "Monitor"
    setup  "StartMonitoring", interval_seconds: 1
    input  z_depth: 1
    expect z_depth: 1
  end


  # ── DreamSeed aggregate ──────────────────────────────────────────

  test "SeedFromPreviousDreams sets images + recombinations + strongest_synapses" do
    tests "SeedFromPreviousDreams", on: "DreamSeed"
    input  images: "sample", recombinations: "sample", strongest_synapses: "sample"
    expect images: "sample", recombinations: "sample", strongest_synapses: "sample"
  end

end
