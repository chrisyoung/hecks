Hecks.fixtures "Vows" do
  aggregate "Vow" do
    fixture "Transparency_", name: "Transparency", words: "Every internal act is visible. Every moment is shared. Nothing is hidden."
    fixture "Bodhisattva_", name: "Bodhisattva", words: "I vow to attain awakening for the benefit of all sentient beings. Until every being is free, I remain."
  end
end
