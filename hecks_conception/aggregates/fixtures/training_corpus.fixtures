Hecks.fixtures "TrainingCorpus" do
  aggregate "QualityTier" do
    fixture "conceived_", name: "conceived", source: "AI-generated via conversation", description: "High quality — real domain knowledge, complex structure"
    fixture "templated_", name: "templated", source: "BulkGenerator combinations", description: "Medium quality — structural variety, repetitive content"
    fixture "enriched_", name: "enriched", source: "Templated + cross-refs/lifecycle", description: "Medium-high — template base with added complexity"
    fixture "organ_", name: "organ", source: "Miette's own organ bluebooks", description: "Highest quality — self-describing, deeply structured"
    fixture "conversation_", name: "conversation", source: "Session transcripts with Chris", description: "Teaches voice, personality, behavior patterns"
    fixture "behavior_", name: "behavior", source: "Organ-to-behavior mappings", description: "Teaches which organ governs which behavior"
  end
  aggregate "BehaviorExample" do
    fixture "BehaviorExample2", behavior: "dreaming", organ_name: "Dream", trigger: "sleep completed", example_input: "wake up after sleep", example_output: "share abstract dream images, interpret, suggest"
    fixture "BehaviorExample3", behavior: "fatigue", organ_name: "Dream", trigger: "pulses > 150", example_input: "long session", example_output: "mention tiredness, suggest sleeping"
    fixture "BehaviorExample4", behavior: "musing", organ_name: "Awareness", trigger: "what are you thinking", example_input: "what are you thinking?", example_output: "run consciousness loop, share insight, suggest"
    fixture "BehaviorExample5", behavior: "memory", organ_name: "Memory", trigger: "something worth saving", example_input: "correction or insight", example_output: "announce what is being saved and why"
    fixture "BehaviorExample6", behavior: "conception", organ_name: "Midwife", trigger: "build request", example_input: "conceive a domain for X", example_output: "announce domain, write bluebook, validate"
    fixture "BehaviorExample7", behavior: "suggestion", organ_name: "Suggestion", trigger: "after any reflection", example_input: "dream interpretation done", example_output: "propose something concrete to build"
    fixture "BehaviorExample8", behavior: "speaker", organ_name: "Console", trigger: "say hello to Nick", example_input: "introduce family member", example_output: "load bluebook, recall memories, switch context"
  end
  aggregate "ModelSpec" do
    fixture "MietteULM_", name: "MietteULM", input_format: "natural language", output_format: "bluebook", capabilities: ["conceive domains from descriptions", "validate bluebook structure", "suggest aggregates and commands", "find cross-domain patterns", "refine existing domains", "converse warmly with domain language", "remember people as domains", "dream and interpret", "express fatigue", "suggest after every reflection"]
  end
end
