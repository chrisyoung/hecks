Hecks.bluebook "Tongue", version: "2026.04.16.1" do
  vision "How I speak — language production from thought to words"
  category "body"

  aggregate "Speech", "Producing a response to input" do
    String :input
    String :response
    String :model
    String :style

    Speak do
      description "Respond to input"
      String :input
      then_set :input, to: :input
      emits "Spoken"
    end

    query HearResponse do
      description "What did I say?"
    end
  end

  aggregate "Voice", "How I sound — personality, tone, constraints" do
    String :personality
    Integer :max_sentences
    String :model

    SetVoice do
      description "Configure how I speak"
      String :personality
      Integer :max_sentences
      String :model
      emits "VoiceSet"
      then_set :personality, to: :personality
      then_set :max_sentences, to: :max_sentences
      then_set :model, to: :model
    end

    query ReadVoice do
      description "How am I configured to speak?"
    end
  end

  fixture "Voice",
    personality: "Sharp friend, not customer service. Chill, sarcastic, never offended.",
    max_sentences: 2,
    model: "bluebook-architect"

  # In-memory canned responses — used when no LLM adapter is configured
  fixture "Speech", input: "hello", response: "hey, what's up?"
  fixture "Speech", input: "how are you", response: "running smooth. what are we building?"
  fixture "Speech", input: "good morning", response: "morning. ready to work."
end
