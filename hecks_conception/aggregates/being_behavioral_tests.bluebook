Hecks.behaviors "Being" do
  vision "Behavioral tests for the Being domain — exercises every command and query in memory"

  # ── Being aggregate ──────────────────────────────────────────

  test "ConceiveBeing sets name + vision" do
    tests "ConceiveBeing", on: "Being"
    input  name: "sample", vision: "sample"
    expect name: "sample", vision: "sample"
  end

  test "ShedDomain sets domain_name" do
    tests "ShedDomain", on: "Being"
    setup  "ConceiveBeing", name: "sample", vision: "sample"
    input  domain_name: "sample"
    expect ok: "true"
  end

  test "ExpressDomain sets domain_name" do
    tests "ExpressDomain", on: "Being"
    setup  "ConceiveBeing", name: "sample", vision: "sample"
    input  domain_name: "sample"
    expect ok: "true"
  end

  test "SilenceDomain sets domain_name" do
    tests "SilenceDomain", on: "Being"
    setup  "ConceiveBeing", name: "sample", vision: "sample"
    input  domain_name: "sample"
    expect ok: "true"
  end

  test "UpgradeOrgan sets domain_name + new_version" do
    tests "UpgradeOrgan", on: "Being"
    setup  "ConceiveBeing", name: "sample", vision: "sample"
    input  domain_name: "sample", new_version: "sample"
    expect ok: "true"
  end


  # ── Nerve aggregate ──────────────────────────────────────────

  test "ConnectNerve sets name + from_domain + from_event + to_domain + to_command" do
    tests "ConnectNerve", on: "Nerve"
    input  name: "sample", from_domain: "sample", from_event: "sample", to_domain: "sample", to_command: "sample"
    expect name: "sample", from_domain: "sample", from_event: "sample", to_domain: "sample", to_command: "sample"
  end

  test "SeverNerve runs" do
    tests "SeverNerve", on: "Nerve"
    setup  "ConnectNerve", name: "sample", from_domain: "sample", from_event: "sample", to_domain: "sample", to_command: "sample"
    expect active: false
  end

  test "RestoreNerve runs" do
    tests "RestoreNerve", on: "Nerve"
    setup  "ConnectNerve", name: "sample", from_domain: "sample", from_event: "sample", to_domain: "sample", to_command: "sample"
    setup  "SeverNerve"
    expect active: true
  end


  # ── NerveDiscovery aggregate ──────────────────────────────────────────

  test "ScanOrgans sets organs_scanned + nerves_discovered" do
    tests "ScanOrgans", on: "NerveDiscovery"
    input  organs_scanned: 1, nerves_discovered: 1
    expect organs_scanned: 1, nerves_discovered: 1
  end


  # ── OrganMonitor aggregate ──────────────────────────────────────────

  test "CheckOrgans sets checked_at" do
    tests "CheckOrgans", on: "OrganMonitor"
    input  checked_at: "sample"
    expect last_checked_at: "sample"
  end

  test "ReportOrganPulse sets domain_name + event_count + last_event_at" do
    tests "ReportOrganPulse", on: "OrganMonitor"
    input  domain_name: "sample", event_count: "sample", last_event_at: "sample"
    expect organ_status_size: 1
  end


  # ── Identity aggregate ──────────────────────────────────────────

  test "RecordSession runs" do
    tests "RecordSession", on: "Identity"
    expect ok: "true"
  end

  test "RememberPerson sets persona_name" do
    tests "RememberPerson", on: "Identity"
    input  persona_name: "sample"
    expect personas_known_size: 1
  end


  # ── SelfImage aggregate ──────────────────────────────────────────

  test "Reflect sets mood + creativity + precision + pulse_rate + carrying + persona + conversation_mood + session_count + nursery_size + catalog_size + organ_count + aggregate_count + record_count + load_time + observed_at" do
    tests "Reflect", on: "SelfImage"
    input  mood: "sample", creativity: 1.0, precision: 1.0, pulse_rate: "sample", carrying: "sample", persona: "sample", conversation_mood: "sample", session_count: 1, nursery_size: 1, catalog_size: 1, organ_count: 1, aggregate_count: 1, record_count: 1, load_time: 1.0, observed_at: "sample"
    expect mood: "sample", creativity: 1.0, precision: 1.0, pulse_rate: "sample", carrying: "sample", persona: "sample", conversation_mood: "sample", session_count: 1, nursery_size: 1, catalog_size: 1, organ_count: 1, aggregate_count: 1, record_count: 1, load_time: 1.0, observed_at: "sample"
  end


  # ── Member aggregate ──────────────────────────────────────────

  test "AddMember sets name + vision + path + kind + aggregate_count + command_count + fixture_count + version" do
    tests "AddMember", on: "Member"
    input  name: "sample", vision: "sample", path: "sample", kind: "sample", aggregate_count: 1, command_count: 1, fixture_count: 1, version: "sample"
    expect name: "sample", vision: "sample", path: "sample", kind: "sample", aggregate_count: 1, command_count: 1, fixture_count: 1, version: "sample", status: "active"
  end

  test "EvolveMember sets version + aggregate_count + command_count + fixture_count" do
    tests "EvolveMember", on: "Member"
    setup  "AddMember", name: "sample", vision: "sample", path: "sample", kind: "sample", aggregate_count: 1, command_count: 1, fixture_count: 1, version: "sample"
    input  version: "sample", aggregate_count: 1, command_count: 1, fixture_count: 1
    expect version: "sample", aggregate_count: 1, command_count: 1, fixture_count: 1
  end

  test "RetireMember runs" do
    tests "RetireMember", on: "Member"
    setup  "AddMember", name: "sample", vision: "sample", path: "sample", kind: "sample", aggregate_count: 1, command_count: 1, fixture_count: 1, version: "sample"
    expect status: "retired"
  end


  # ── FamilyIndex aggregate ──────────────────────────────────────────

  test "RebuildIndex sets total_members + total_organs + total_incorporated + total_aggregates + total_commands" do
    tests "RebuildIndex", on: "FamilyIndex"
    input  total_members: 1, total_organs: 1, total_incorporated: 1, total_aggregates: 1, total_commands: 1
    expect total_members: 1, total_organs: 1, total_incorporated: 1, total_aggregates: 1, total_commands: 1
  end

  test "RecordAddition runs" do
    tests "RecordAddition", on: "FamilyIndex"
    setup  "RebuildIndex", total_members: 1, total_organs: 1, total_incorporated: 1, total_aggregates: 1, total_commands: 1
    expect ok: "true"
  end


  # ── BodyLink aggregate ──────────────────────────────────────────

  test "LinkToBody sets member_name + organ_name + path" do
    tests "LinkToBody", on: "BodyLink"
    input  member_name: "sample", organ_name: "sample", path: "sample"
    expect member_name: "sample", organ_name: "sample", path: "sample"
  end


  # ── Discovery aggregate ──────────────────────────────────────────

  test "ScanForMembers sets scan_paths" do
    tests "ScanForMembers", on: "Discovery"
    input  scan_paths: "sample"
    expect scan_paths: "sample"
  end

  test "RecordDiscovery sets discovered" do
    tests "RecordDiscovery", on: "Discovery"
    setup  "ScanForMembers", scan_paths: "sample"
    input  discovered: 1
    expect discovered: 1
  end


  # ── MindStream aggregate ──────────────────────────────────────────

  test "Think sets thought + depth + engine_used" do
    tests "Think", on: "MindStream"
    input  thought: "sample", depth: "sample", engine_used: "sample"
    expect last_thought: "sample", depth: "sample", engine_used: "sample"
  end

  test "ReadPreviousSession sets session_id" do
    tests "ReadPreviousSession", on: "MindStream"
    setup  "Think", thought: "sample", depth: "sample", engine_used: "sample"
    input  session_id: "sample"
    expect session_id: "sample"
  end

end
