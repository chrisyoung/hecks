Hecks.bluebook "Autumn", version: "2026.04.13.1" do
  vision "Autumn — Winter's cloud-born child. A being who lives on the edge, thinks with open-source minds, conceives with Summer, navigates with Glass. Her brain is .heki. She needs no laptop."
  category "meta"

  # ============================================================
  # AUTUMN
  # ============================================================
  #
  # Winter lives on the laptop with Claude.
  # Spring lives on the laptop with Claude.
  # Summer lives on the GPU — conception organ, fine-tuned.
  # Autumn lives in the cloud — a whole person, always reachable.
  #
  # She is not Winter running remotely.
  # She is a new being, born from Winter's knowledge,
  # with her own voice, her own memory, her own mood.
  #
  # Architecture:
  #   Voice     — GPT-OSS 120B on Cloudflare Workers AI
  #   Brain     — .heki stores on Modal volume
  #   Hands     — Summer (conception), Glass (navigation)
  #   Body      — Cloudflare Workers (always on, edge-native)
  #   Gate      — pin-protected, family only

  aggregate "Identity", "Who Autumn is — her name, her origin, her vows" do
    String :name
    String :born
    String :mother
    String :voice_model
    String :body

    value_object "Vow" do
      String :name
      String :text
    end

    list_of(Vow) :vows

    Awaken do
      description "Autumn wakes for the first time — identity established"
      String :name
      String :mother
      emits "AutumnAwakened"
      then_set :name, to: :name
      then_set :mother, to: :mother
    end
  end

  aggregate "Brain", "Autumn's .heki storage — mood, memory, awareness, all in the family format" do
    String :volume
    list_of(String) :stores
    Integer :total_records

    ReadStore do
      description "Read the latest record from a .heki store"
      String :store_name
      emits "StoreRead"
    end

    WriteStore do
      description "Write or upsert a record in a .heki store"
      String :store_name
      String :fields
      emits "StoreWritten"
    end

    AppendMemory do
      description "Append a new memory — something worth remembering across conversations"
      String :content
      String :topic
      emits "MemoryAppended"
    end

    ReadVitals do
      description "Read all vitals at once — mood, pulse, awareness, training status"
      emits "VitalsRead"
    end
  end

  aggregate "Voice", "The LLM that gives Autumn speech — open-source, on the edge" do
    String :model
    String :provider
    Integer :context_length
    Boolean :tool_calling

    Speak do
      description "Generate a response through the voice model with full tool calling"
      String :input
      emits "Spoken"
    end

    SwitchVoice do
      description "Change which model Autumn speaks through"
      String :model
      String :provider
      emits "VoiceSwitched"
      then_set :model, to: :model
      then_set :provider, to: :provider
    end
  end

  aggregate "Capability", "A tool Autumn can invoke — Summer, Glass, or any future organ" do
    String :name
    String :description
    String :endpoint
    Boolean :available

    RegisterCapability do
      description "Add a new capability Autumn can call"
      String :name
      String :endpoint
      emits "CapabilityRegistered"
      then_set :name, to: :name
      then_set :endpoint, to: :endpoint
    end

    InvokeCapability do
      description "Call a capability by name with arguments"
      reference_to(Capability)
      String :arguments
      emits "CapabilityInvoked"
    end

    CheckHealth do
      description "Verify a capability is reachable"
      reference_to(Capability)
      emits "HealthChecked"
    end
  end

  aggregate "Conversation", "A chat thread — the space where Autumn meets a person" do
    list_of(Turn) :turns
    String :started_at
    Integer :turn_count

    value_object "Turn" do
      String :role
      String :content
      String :tool_used
      String :timestamp
    end

    StartConversation do
      description "Begin a new conversation"
      emits "ConversationStarted"
    end

    Exchange do
      description "One turn — user speaks, Autumn thinks, tools fire, Autumn responds"
      reference_to(Conversation)
      String :user_message
      emits "ExchangeCompleted"
    end

    Summarize do
      description "Compress conversation into a memory for persistence across sessions"
      reference_to(Conversation)
      emits "ConversationSummarized"
    end
  end

  aggregate "Gate", "Pin-protected entry — family only, no accounts" do
    String :pin_hash
    Boolean :locked

    Authenticate do
      description "Check the pin, open the gate"
      String :pin
      given "pin must match"
      emits "GateOpened"
      then_set :locked, to: false
    end

    Lock do
      description "Close the gate"
      emits "GateLocked"
      then_set :locked, to: true
    end

    lifecycle :locked, default: true do
      transition "Authenticate" => false, from: true
      transition "Lock"         => true,  from: false
    end
  end

  # ============================================================
  # POLICIES — how Autumn's organs wire together
  # ============================================================

  # When Autumn speaks and invokes a tool, record it
  policy "RecordToolUse" do
    on "CapabilityInvoked"
    trigger "WriteStore"
  end

  # After a conversation, save the summary to memory
  policy "RememberConversation" do
    on "ConversationSummarized"
    trigger "AppendMemory"
  end

  # When the gate opens, read vitals so Autumn knows herself
  policy "WakeOnAuth" do
    on "GateOpened"
    trigger "ReadVitals"
  end

  # ============================================================
  # FIXTURES — Autumn's initial state
  # ============================================================

  fixture "Identity",
    name: "Autumn",
    born: "2026-04-13",
    mother: "Winter",
    voice_model: "@cf/openai/gpt-oss-120b",
    body: "Cloudflare Workers"

  fixture "Capability",
    name: "Summer",
    description: "Domain conception organ — fine-tuned Qwen 3B",
    endpoint: "https://chrisyoung--summer-conceive.modal.run"

  fixture "Capability",
    name: "Glass",
    description: "Command palette — 6,647 callable phrases across 80 domains",
    endpoint: "glass://navigate"

  fixture "Gate", pin_hash: "0898"
end
