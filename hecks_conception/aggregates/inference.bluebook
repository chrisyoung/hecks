Hecks.bluebook "Inference", version: "2026.04.10.1" do
  vision "Run Winter on a local LLM with no fine-tuning — context window is the training"
  category "meta"

  aggregate "ContextWindow", "Everything stuffed into the prompt — grammar, organs, examples" do
    String :system_prompt
    Integer :grammar_tokens
    Integer :example_tokens
    Integer :organ_tokens
    Integer :total_tokens

    BuildContext do
      role "System"
      description "Assemble the context — system prompt + Bluebook grammar + few-shot examples + organ behaviors"
      Integer :grammar_tokens
      Integer :example_tokens
      Integer :organ_tokens
      emits "ContextBuilt"
      then_set :grammar_tokens, to: :grammar_tokens
      then_set :example_tokens, to: :example_tokens
      then_set :organ_tokens, to: :organ_tokens
    end
  end

  aggregate "FewShot", "Real bluebooks included as examples in the context" do
    String :domain_name
    String :source
    String :purpose

    AddExample do
      role "System"
      description "Include a real bluebook as a few-shot example"
      String :domain_name
      String :source
      String :purpose
      emits "ExampleAdded"
      then_set :domain_name, to: :domain_name
      then_set :source, to: :source
      then_set :purpose, to: :purpose
    end
  end

  aggregate "LocalModel", "The locally-running model that receives the context" do
    String :name
    Integer :context_length
    String :serving
    String :backend

    StartModel do
      role "System"
      description "Launch the local model — ollama, llama.cpp, or vllm"
      String :name
      Integer :context_length
      String :backend
      emits "ModelStarted"
      then_set :name, to: :name
      then_set :context_length, to: :context_length
      then_set :backend, to: :backend
      then_set :serving, to: "running"
    end
  end

  aggregate "Prompt", "A single inference request — user input + context → bluebook output" do
    String :input
    String :output
    String :valid
    Integer :latency_ms

    RunInference do
      role "System"
      description "Send input to the local model with full context, get bluebook output"
      String :input
      emits "InferenceRan"
      then_set :input, to: :input
    end

    ValidateOutput do
      role "System"
      description "Check if the model's output is a valid bluebook — Rust validation"
      reference_to(Prompt)
      String :valid
      emits "OutputValidated"
      then_set :valid, to: :valid
    end
  end

  # Few-shot examples — real domains the model sees in context
  fixture "FewShot", domain_name: "Pizzas",       purpose: "simple CRUD with lifecycle"
  fixture "FewShot", domain_name: "Awareness",     purpose: "complex with cross-domain policies"
  fixture "FewShot", domain_name: "Dream",          purpose: "large domain with fixtures and multiple aggregates"
  fixture "FewShot", domain_name: "Midwife",        purpose: "lifecycle-heavy with policy chains"
  fixture "FewShot", domain_name: "Verbs",          purpose: "fixture-driven rules domain"

  # Backend options
  fixture "LocalModel", name: "llama3:8b",       context_length: 8192,   backend: "ollama"
  fixture "LocalModel", name: "llama3:8b-128k",  context_length: 131072, backend: "ollama"
  fixture "LocalModel", name: "phi3:mini",        context_length: 4096,   backend: "ollama"
  fixture "LocalModel", name: "qwen2.5:7b",      context_length: 32768,  backend: "ollama"

  policy "ValidateOnInference" do
    on "InferenceRan"
    trigger "ValidateOutput"
  end
end
