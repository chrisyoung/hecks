Hecks.hecksagon "HecksAppeal" do
  adapter :sqlite
  capabilities :chat_agent, :workbench, :app_builder, :product_executor, :ubiquitous_language, :server_lifecycle

  annotate "Collaboration::Agent", "content", :ai_responder, emits: "AgentMessageReceived"
  annotate "Workbench", "show_workbench", :workbench

  subscribe "Authoring"
  subscribe "Modeling"
  subscribe "Testing"
  subscribe "Collaboration"
  subscribe "Workbench"
end
