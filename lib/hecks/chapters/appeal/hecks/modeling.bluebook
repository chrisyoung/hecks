Hecks.bluebook "Modeling" do
  vision "Domain visualization, event storming, ubiquitous language management, and version analysis"

    value_object "DiagramNode" do
      description "An element in a diagram -- aggregate, command, event, or value object"
      attribute :node_name, String
      attribute :kind, String
      attribute :metadata, String
    end
    value_object "DiagramEdge" do
      description "A directed relationship between two diagram nodes"
      attribute :from_node, String
      attribute :to_node, String
      attribute :relationship, String
    end
    value_object "Sticky" do
      description "A virtual sticky note for event storming sessions"
      attribute :label, String
      attribute :kind, String
      attribute :position_x, Integer
      attribute :position_y, Integer
    end
    value_object "GlossaryTerm" do
      description "A domain term with definition, category, and known aliases"
      attribute :term_name, String
      attribute :definition, String
      attribute :category, String
      attribute :aliases, String
    end
    value_object "InsightFinding" do
      description "A single analysis finding with severity and recommendation"
      attribute :rule, String
      attribute :severity, String
      attribute :aggregate_name, String
      attribute :suggestion, String
    end
    value_object "VersionDiff" do
      description "A version range representing a set of domain changes"
      attribute :from_version, String
      attribute :to_version, String
      attribute :changes, String
    end

    aggregate "Diagram", "Generated domain visualizations -- aggregate maps, event flows, command graphs." do
      attribute :view_type, String
      attribute :nodes, list_of("DiagramNode")
      attribute :edges, list_of("DiagramEdge")
      command "GenerateDiagram" do
        role "Developer"
        goal "Visualize domain structure as an interactive diagram"
        description "Build a diagram for a domain file. Uses Explorer.last_opened when path omitted."
        attribute :view_type, String
        attribute :path, String
        attribute :domain, String
        emits "DiagramGenerated"
      end
      command "GenerateOverview" do
        role "Developer"
        description "Build a cross-domain relationship diagram showing all bounded contexts"
        attribute :scope, String
        emits "OverviewGenerated"
      end
      command "SelectView" do
        role "Developer"
        description "Switch between aggregate map, event flow, or command graph"
        reference_to "Diagram"
        attribute :view_type, String
        emits "ViewSelected"
      end
      command "FilterByAggregate" do
        role "Developer"
        description "Show only nodes related to a specific aggregate"
        reference_to "Diagram"
        attribute :aggregate_name, String
        emits "DiagramFiltered"
      end
      command "RunAnalysis" do
        role "Developer"
        description "Analyze domain patterns -- coupling, cohesion, naming issues"
        emits "AnalysisCompleted"
      end
    end

    aggregate "EventStorm", "Interactive event storming session. Place and arrange domain concept stickies." do
      attribute :storm_name, String
      attribute :stickies, list_of("Sticky")
      command "StartStorm" do
        role "Developer"
        goal "Kick off a collaborative event storming session"
        description "Begin a new event storming session with a name"
        attribute :storm_name, String
        emits "StormStarted"
      end
      command "PlaceSticky" do
        role "Developer"
        description "Place a new sticky note on the board"
        reference_to "EventStorm"
        attribute :label, String
        attribute :kind, String
        emits "StickyPlaced"
      end
      command "MoveSticky" do
        role "Developer"
        description "Reposition a sticky on the board"
        reference_to "EventStorm"
        attribute :label, String
        attribute :position_x, Integer
        attribute :position_y, Integer
        emits "StickyMoved"
      end
      command "ConvertToDomain" do
        role "Developer"
        description "Transform stickies into Bluebook DSL aggregates, commands, and events"
        reference_to "EventStorm"
        emits "StormConverted"
      end
      validation :storm_name, presence: true
    end

    aggregate "Glossary", "Ubiquitous language dictionary. Defines terms and enforces naming consistency." do
      attribute :terms, list_of("GlossaryTerm")
      command "ShowGlossary" do
        role "DomainExpert"
        description "Display the full glossary of domain terms"
        emits "GlossaryShown"
      end
      command "DefineTerm" do
        role "DomainExpert"
        goal "Establish shared vocabulary for the ubiquitous language"
        description "Add or update a term in the glossary"
        attribute :term_name, String
        attribute :definition, String
        attribute :category, String
        emits "TermDefined"
      end
      command "RenameTerm" do
        role "DomainExpert"
        description "Rename a term and cascade the change to all references"
        reference_to "Glossary"
        attribute :old_name, String
        attribute :new_name, String
        emits "TermRenamed"
      end
      command "FlagAmbiguity" do
        role "DomainExpert"
        goal "Surface a naming conflict for team resolution"
        description "Mark a term as ambiguous -- needs team clarification"
        reference_to "Glossary"
        attribute :term_name, String
        attribute :reason, String
        emits "AmbiguityFlagged"
      end
      command "LinkTerms" do
        role "DomainExpert"
        description "Declare a relationship between two glossary terms"
        reference_to "Glossary"
        attribute :from_term, String
        attribute :to_term, String
        attribute :relationship, String
        emits "TermsLinked"
      end
    end

    aggregate "Insight", "Domain health analysis -- coupling metrics, design smells, completeness checks." do
      attribute :findings, list_of("InsightFinding")
      command "AnalyzeDomain" do
        role "Developer"
        description "Run all analysis rules against the current domain"
        attribute :scope, String
        emits "DomainAnalyzed"
      end
      command "DismissInsight" do
        role "Developer"
        description "Acknowledge and hide a specific finding"
        reference_to "Insight"
        attribute :rule, String
        attribute :aggregate_name, String
        emits "InsightDismissed"
      end
      command "ConfigureRules" do
        role "Developer"
        description "Enable or disable specific analysis rules"
        reference_to "Insight"
        attribute :rule, String
        attribute :enabled, String
        emits "RulesConfigured"
      end
    end

    aggregate "Migration", "Breaking change detection and migration path generation between domain versions." do
      attribute :diff, "VersionDiff"
      command "DetectChanges" do
        role "Developer"
        description "Compare current bluebook against a previous version"
        attribute :from_version, String
        emits "ChangesDetected"
      end
      command "GenerateMigration" do
        role "Developer"
        description "Produce a migration script for the detected changes"
        reference_to "Migration"
        emits "MigrationGenerated"
      end
      command "ApplyMigration" do
        role "Developer"
        description "Execute the migration against a target environment"
        reference_to "Migration"
        emits "MigrationApplied"
      end
    end

  policy "AnalyzeOnDiagram" do
    on "DiagramGenerated"
    trigger "AnalyzeDomain"
  end
  policy "RefreshGlossaryOnConvert" do
    on "StormConverted"
    trigger "ShowGlossary"
  end
end
