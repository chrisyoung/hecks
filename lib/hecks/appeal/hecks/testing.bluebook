Hecks.bluebook "Testing" do
  vision "Automated acceptance testing, executable scenarios, and interactive domain playground"

    aggregate "AcceptanceTest", "Runs domain commands and validates the event log against expected outcomes." do
      attribute :lifecycle_state, String, default: "idle"
      attribute :results, list_of(TestResult)
      attribute :passed_count, Integer, default: 0
      attribute :failed_count, Integer, default: 0

      value_object "TestResult" do
        description "Outcome of dispatching a single domain command"
        attribute :command_tested, String
        attribute :aggregate_tested, String
        attribute :outcome, String
        attribute :event_emitted, String
        attribute :error_message, String
        invariant("outcome must be passed, failed, or skipped") { %w[passed failed skipped].include?(outcome) }
      end

      lifecycle :lifecycle_state, default: "idle" do
        transition "RunAllTests" => "running", from: "idle"
        transition "AllTestsCompleted" => "complete", from: "running"
        transition "RunSingleTest" => "running", from: "idle"
        transition "ResetResults" => "idle"
      end

      command "RunAllTests" do
        role "Tester"
        goal "Validate all domain commands produce expected events"
        description "Dispatch every domain command and collect results"
        reference_to AcceptanceTest
        emits "AllTestsStarted"
        then_set :lifecycle_state, to: "running"
        then_set :results, to: []
      end

      command "RunSingleTest" do
        role "Tester"
        description "Dispatch one command and validate its event"
        reference_to AcceptanceTest
        attribute :aggregate_name, String
        attribute :command_name, String
        emits "SingleTestCompleted"
        then_set :lifecycle_state, to: "running"
      end

      command "ResetResults" do
        role "Tester"
        description "Clear all results and return to idle"
        reference_to AcceptanceTest
        emits "ResultsReset"
        then_set :lifecycle_state, to: "idle"
        then_set :results, to: []
        then_set :passed_count, to: 0
        then_set :failed_count, to: 0
      end
    end

    aggregate "Scenario", "Executable given/when/then specification that validates domain behavior." do
      attribute :scenario_name, String
      attribute :steps, list_of(ScenarioStep)

      value_object "ScenarioStep" do
        description "One step: the command to dispatch and the expected event"
        attribute :step_description, String
        attribute :command_name, String
        attribute :expected_event, String
        attribute :actual_result, String
      end

      command "WriteScenario" do
        role "Tester"
        goal "Define an executable acceptance scenario"
        description "Define a new scenario with a descriptive name"
        attribute :scenario_name, String
        emits "ScenarioWritten"
        then_set :scenario_name, to: :scenario_name
        then_set :steps, to: []
      end

      command "AddStep" do
        role "Tester"
        description "Append a step to the scenario"
        reference_to Scenario
        attribute :step_description, String
        attribute :command_name, String
        attribute :expected_event, String
        emits "StepAdded"
        then_set :steps, append: { step_description: :step_description, command_name: :command_name, expected_event: :expected_event, actual_result: "" }
      end

      command "ExecuteScenario" do
        role "Tester"
        goal "Run a given/when/then scenario against the live domain"
        description "Run all steps and record pass/fail for each"
        reference_to Scenario
        emits "ScenarioExecuted"
        given("Scenario has no steps") { !steps.empty? }
      end

      command "RecordOutcome" do
        role "Tester"
        description "Store the outcome after scenario execution"
        reference_to Scenario
        attribute :step_index, Integer
        attribute :actual_result, String
        emits "OutcomeRecorded"
        # TODO: array index mutation not yet supported in Bluebook
        handler do |s|
          s.steps[step_index]["actual_result"] = actual_result
          s
        end
      end

      validation :scenario_name, presence: true
    end

    aggregate "Fixture", "Reusable data set that seeds scenarios with known aggregate state." do
      attribute :fixture_name, String
      attribute :entries, list_of(FixtureEntry)

      value_object "FixtureEntry" do
        description "A seed record: which aggregate and what attribute values"
        attribute :aggregate_name, String
        attribute :attribute_values, String
      end

      command "DefineFixture" do
        role "Developer"
        description "Create a new named fixture set"
        attribute :fixture_name, String
        emits "FixtureDefined"
        then_set :fixture_name, to: :fixture_name
        then_set :entries, to: []
      end

      command "AddEntry" do
        role "Developer"
        description "Append a seed record to the fixture"
        reference_to Fixture
        attribute :aggregate_name, String
        attribute :attribute_values, String
        emits "EntryAdded"
        then_set :entries, append: { aggregate_name: :aggregate_name, attribute_values: :attribute_values }
      end

      command "ApplyToScenario" do
        role "Developer"
        description "Load this fixture as given-state for a scenario"
        reference_to Fixture
        reference_to Scenario
        emits "FixtureApplied"
        given("Fixture has no entries") { !entries.empty? }
      end

      validation :fixture_name, presence: true
    end

    aggregate "Playground", "Interactive sandbox for dispatching commands and inspecting live state." do
      attribute :active_aggregate, String
      attribute :sandbox_state, String

      command "OpenPlayground" do
        role "Developer"
        description "Launch the sandbox for a domain"
        emits "PlaygroundOpened"
        then_set :sandbox_state, to: "ready"
      end

      command "ExecuteCommand" do
        role "Developer"
        description "Dispatch a domain command inside the sandbox"
        reference_to Playground
        attribute :aggregate_name, String
        attribute :command_name, String
        attribute :attributes, String
        emits "CommandExecuted"
        then_set :active_aggregate, to: :aggregate_name
      end

      command "InspectState" do
        role "Developer"
        description "View the current state of an aggregate in the sandbox"
        reference_to Playground
        attribute :aggregate_name, String
        emits "StateInspected"
        then_set :active_aggregate, to: :aggregate_name
      end

      command "ResetSandbox" do
        role "Developer"
        description "Clear all sandbox state and start fresh"
        reference_to Playground
        emits "SandboxReset"
        then_set :active_aggregate, to: nil
        then_set :sandbox_state, to: nil
      end
    end
end
