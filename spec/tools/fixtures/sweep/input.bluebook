Hecks.bluebook "SweepFixture" do
  aggregate "Thing" do
    attribute :name, String
    list_of(Part) :parts
    reference_to "OtherThing"

    value_object "Part" do
      attribute :label, String
    end

    command "DoThing" do
      reference_to "Thing"
      list_of "Widget"
      emits "ThingDid"
    end

    list_of "InlineVO" do
      attribute :foo, String
      attribute :bar, Integer
    end
  end
end
