Hecks.bluebook "WithFixture", version: "2026.04.18.1" do
  vision "Aggregate with seed fixtures — exercises fixture serialization"

  aggregate "Topping", "A pizza topping" do
    attribute :name, String
    attribute :price, Integer
  end

  fixture "Topping", name: "Pepperoni", price: 200
  fixture "Topping", name: "Mushroom", price: 150
end
