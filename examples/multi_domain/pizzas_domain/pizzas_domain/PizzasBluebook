Hecks.bluebook "Pizzas" do
  aggregate "Pizza" do
    attribute :name, String
    attribute :style, String
    attribute :price, Float

    query "Classics" do
      where(style: "Classic")
    end

    command "CreatePizza" do
      attribute :name, String
      attribute :style, String
      attribute :price, Float
    end
  end

  aggregate "Order" do
    attribute :quantity, Integer
    reference_to "Pizza"

    command "PlaceOrder" do
      attribute :quantity, Integer
      reference_to "Pizza"
    end
  end
end
