#!/bin/bash
#
# Pre-commit hook: runs all domain specs and fails if any take over 1 second.
# Install: ln -sf ../../bin/pre-commit .git/hooks/pre-commit
#

ROOT=$(git rev-parse --show-toplevel)
GEMFILE="$ROOT/Gemfile"
total_failures=0

for domain_dir in "$ROOT"/*_domain; do
  [ -d "$domain_dir/spec" ] || continue
  name=$(basename "$domain_dir")

  cd "$domain_dir"
  output=$(BUNDLE_GEMFILE="$GEMFILE" bundle exec rspec --order defined 2>&1)
  exit_code=$?

  time_line=$(echo "$output" | grep 'Finished in')
  seconds=$(echo "$time_line" | grep -oE '[0-9]+\.[0-9]+' | head -1)

  if [ $exit_code -ne 0 ]; then
    echo "COMMIT BLOCKED: $name specs failed"
    echo "$output" | tail -10
    exit 1
  fi

  if [ "$(echo "$seconds > 1.0" | bc -l)" = "1" ]; then
    echo "COMMIT BLOCKED: $name specs too slow (${seconds}s > 1.0s limit)"
    exit 1
  fi
done

cd "$ROOT"
echo "All domain specs passed"
