Hecks.hecksagon "Pizzas" do
  gate "Pizza", :admin do
    allow :find, :all, :create_pizza, :add_topping
  end

  gate "Pizza", :customer do
    allow :find, :all
  end

  gate "Order", :admin do
    allow :find, :all, :place_order, :cancel_order
  end

  gate "Order", :customer do
    allow :find, :all, :place_order
  end
end
