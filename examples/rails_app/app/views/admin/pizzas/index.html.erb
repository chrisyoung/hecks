<h1>Admin — Pizzas</h1>

<div style="background:#f5f5f5; padding:12px; border-radius:6px; margin-bottom:20px">
  <h3 style="margin-top:0">Pricing</h3>
  <%= form_with url: admin_pricing_path, method: :post, style: "display:flex; gap:10px; align-items:end" do |f| %>
    <div>
      <%= f.label :extra_topping_price, "Extra Topping Price (cents)" %>
      <%= f.number_field :extra_topping_price, value: @pricing&.extra_topping_price || 200, min: 0, style: "width:120px" %>
    </div>
    <%= f.submit "Save", class: "btn btn-sm" %>
    <span style="color:#666; font-size:13px">
      Currently: $<%= "%.2f" % ((@pricing&.extra_topping_price || 200) / 100.0) %> per extra topping
    </span>
  <% end %>
</div>

<div id="pizzas">
  <%= render partial: "admin/pizzas/pizza", collection: @pizzas, as: :pizza %>
  <% if @pizzas.empty? %>
    <em>No pizzas yet — create one below.</em>
  <% end %>
</div>

<h3>New Pizza</h3>
<%= form_with url: admin_pizzas_path, method: :post, id: "new-pizza-form" do |f| %>
  <div><%= f.label :name %><%= f.text_field :name, required: true %></div>
  <div><%= f.label :description %><%= f.text_field :description %></div>
  <div><%= f.label :price, "Price (cents)" %><%= f.number_field :price, min: 0, placeholder: "e.g. 1299" %></div>
  <%= f.submit "Create Pizza" %>
<% end %>
