<div class="card" id="pizza_<%= pizza.id %>">
  <div style="display:flex; justify-content:space-between; align-items:center">
    <div>
      <strong><%= pizza.name %></strong> — <%= pizza.description %>
      <% if pizza.price && pizza.price > 0 %>
        <span style="color:green; font-weight:bold">$<%= "%.2f" % (pizza.price / 100.0) %></span>
      <% end %>
      <div class="toppings" id="toppings_<%= pizza.id %>">
        <% if pizza.respond_to?(:toppings) && pizza.toppings&.any? %>
          <% pizza.toppings.each do |t| %>
            <span class="topping-tag"><%= t.respond_to?(:name) ? t.name : t %></span>
          <% end %>
        <% else %>
          <em id="no-toppings-<%= pizza.id %>">no toppings</em>
        <% end %>
      </div>
    </div>
    <%= button_to "Delete", admin_pizza_path(pizza), method: :delete, class: "btn btn-danger btn-sm" %>
  </div>
  <div style="margin-top:8px">
    <%= form_with url: add_topping_admin_pizza_path(pizza), method: :post, id: "topping-form-#{pizza.id}", style: "display:inline-flex; gap:6px; align-items:center" do |f| %>
      <%= f.text_field :topping_name, placeholder: "Add topping...", size: 15, style: "padding:4px 8px" %>
      <%= f.submit "Add", class: "btn btn-sm" %>
    <% end %>
  </div>
</div>
