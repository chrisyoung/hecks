<% pizza = pizzas.find { |p| p.id == order.pizza_id } %>
<% toppings = order.respond_to?(:extra_toppings) ? (order.extra_toppings || "") : "" %>
<% topping_list = toppings.is_a?(String) ? toppings.split(",").reject(&:blank?) : [] %>
<% pizza_price = pizza&.price || 0 %>
<% total = (pizza_price + topping_list.size * extra_price) * order.quantity %>
<tr id="order_<%= order.id %>">
  <td><%= pizza&.name || order.pizza_id %></td>
  <td>
    <% topping_list.each do |t| %>
      <span class="topping-tag"><%= t %></span>
    <% end %>
  </td>
  <td><%= order.quantity %></td>
  <td><%= total > 0 ? "$#{"%.2f" % (total / 100.0)}" : "—" %></td>
  <td><span class="status-<%= order.status&.downcase %>"><%= order.status || "pending" %></span></td>
  <td>
    <% unless order.status&.downcase == "cancelled" %>
      <%= button_to "Cancel", cancel_order_path(order), method: :post, class: "btn btn-danger btn-sm" %>
    <% end %>
  </td>
</tr>
