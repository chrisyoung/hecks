<h1>Configuration</h1>
<div class="detail">
  <dl>
    <dt>Role</dt>
    <dd>
      <form class="inline" method="post" action="/config/role">
        <select class="inline" name="role">
          <% roles.each do |r| %>
            <option value="<%= r %>"<%= ' selected' if r == current_role %>><%= r %></option>
          <% end %>
        </select>
        <button class="btn btn-sm" type="submit">Switch</button>
      </form>
    </dd>
    <dt>Adapter</dt>
    <dd>
      <form class="inline" method="post" action="/config/reboot">
        <select class="inline" name="adapter">
          <% adapters.each do |a| %>
            <option value="<%= a %>"<%= ' selected' if a == current_adapter %>><%= a %></option>
          <% end %>
        </select>
        <button class="btn btn-sm" type="submit">Switch</button>
      </form>
    </dd>
    <dt>Events</dt>
    <dd><%= event_count %> total</dd>
    <dt>Booted</dt>
    <dd><%= booted_at %></dd>
    <dt>Reset</dt>
    <dd>
      <form class="inline" method="post" action="/_reset">
        <button class="btn btn-sm" type="submit">Clear All Data</button>
      </form>
    </dd>
    <dt>Policies</dt>
    <dd>
      <% if policies.empty? %>
        (none)
      <% else %>
        <ul>
          <% policies.each do |p| %>
            <li class="mono"><%= p %></li>
          <% end %>
        </ul>
      <% end %>
    </dd>
  </dl>
</div>
<h2>Aggregates</h2>
<table>
  <thead>
    <tr><th>Aggregate</th><th>Count</th><th>Commands</th><th>Ports</th></tr>
  </thead>
  <tbody>
    <% aggregates.each do |row| %>
      <tr>
        <td><a href="<%= row[:href] %>"><%= row[:name] %></a></td>
        <td><%= row[:count] %></td>
        <td class="mono"><%= row[:commands] %></td>
        <td class="mono"><%= row[:ports] %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<% if defined?(structure_diagram) && structure_diagram && !structure_diagram.empty? %>
<h2>Domain Wiring</h2>
<details open><summary>Structure</summary>
  <pre class="mermaid"><%= structure_diagram %></pre>
</details>
<details><summary>Behavior</summary>
  <pre class="mermaid"><%= behavior_diagram %></pre>
</details>
<details><summary>Flows</summary>
  <pre class="mermaid"><%= flows_diagram %></pre>
</details>
<% end %>
