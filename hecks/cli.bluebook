Hecks.bluebook "Cli" do
  # --- Core ---

  aggregate "CLI", "Thor-based command-line interface entry point" do
    command("Start") { attribute :argv, String }
  end

  # --- Commands Paragraph ---

  aggregate "InitCommand", "Scaffolds a new Hecks domain project" do
    command("Init") { attribute :project_name, String }
  end

  aggregate "BuildCommand", "Compiles domain DSL into Ruby classes" do
    command("Build") { attribute :target, String }
  end

  aggregate "ValidateCommand", "Lints a domain definition for errors" do
    command("Validate") { attribute :domain_path, String }
  end

  aggregate "ListCommand", "Lists aggregates and commands in a domain" do
    command("List") { attribute :domain_path, String }
  end

  aggregate "InspectCommand", "Displays detailed domain structure" do
    command("Inspect") { attribute :domain_path, String }
  end

  aggregate "TreeCommand", "Renders domain as ASCII tree" do
    command("Tree") { attribute :domain_path, String }
  end

  aggregate "DiffCommand", "Shows diff between domain versions" do
    command("Diff") { attribute :from_version, String; attribute :to_version, String }
  end

  aggregate "DumpCommand", "Exports domain in various formats" do
    command("Dump") { attribute :format, String }
  end

  aggregate "GemCommand", "Packages domain as a Ruby gem" do
    command("Package") { attribute :domain_path, String }
  end

  aggregate "ImportCommand", "Imports Rails models into domain DSL" do
    command("Import") { attribute :source_path, String }
  end

  aggregate "InterviewCommand", "Runs interactive domain wizard" do
    command("Interview") { attribute :domain_name, String }
  end

  aggregate "VersionCommand", "Shows framework version" do
    command("Show") { attribute :format, String }
  end

  aggregate "VersionTagCommand", "Tags a domain version snapshot" do
    command("Tag") { attribute :version, String }
  end

  aggregate "VersionLogCommand", "Lists domain version history" do
    command("Log") { attribute :domain_path, String }
  end

  aggregate "VisualizeCommand", "Generates domain diagrams" do
    command("Visualize") { attribute :format, String }
  end

  aggregate "ContextMapCommand", "Generates context map for multi-domain" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "GlossaryCommand", "Outputs ubiquitous language glossary" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "LlmsCommand", "Generates LLM context file" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "ExtractCommand", "Extracts aggregate to new domain" do
    command("Extract") { attribute :aggregate_name, String }
  end

  aggregate "GenerateStubCommand", "Generates test stubs for domain" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "GenerateSinatraCommand", "Generates Sinatra app from domain" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "GenerateConfigCommand", "Generates configuration files" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "InfoCommand", "Shows domain metadata and stats" do
    command("Show") { attribute :domain_path, String }
  end

  aggregate "CompileCommand", "Compiles Hecks into a self-contained binary" do
    command("Compile") { attribute :output, String }
  end

  aggregate "ClaudeCommand", "Starts file watchers and launches Claude Code" do
    command("Launch") { attribute :args, String }
  end

  aggregate "AppealCommand", "Launches the HecksAppeal IDE server" do
    command("Launch") { attribute :path, String }
  end

  aggregate "NewProjectCommand", "Scaffolds a new Hecks domain project" do
    command("Create") { attribute :project_name, String }
  end

  aggregate "SelfDiffCommand", "Compares generated code against actual gem code" do
    command("Diff") { attribute :chapter, String; attribute :framework, String }
  end

  aggregate "VerifyCommand", "Runs Bluebook self-verification" do
    command("Verify") { attribute :format, String }
  end

  # --- Formatters Paragraph ---

  aggregate "AggregateFormatter", "Formats a single aggregate IR into readable terminal output" do
    command("Format") { attribute :aggregate, String }
  end

  aggregate "BehaviorFormatters", "Formats commands, events, and queries for display" do
    command("Format") { attribute :aggregate, String }
  end

  aggregate "StructureFormatters", "Formats attributes, value objects, and entities for display" do
    command("Format") { attribute :aggregate, String }
  end

  aggregate "LifecycleFormatter", "Formats lifecycle states and transitions for display" do
    command("Format") { attribute :aggregate, String }
  end

  aggregate "RuleFormatters", "Formats validations, invariants, and policies for display" do
    command("Format") { attribute :aggregate, String }
  end

  aggregate "SecondaryFormatters", "Formats scopes, specifications, subscribers, references, computed attributes" do
    command("Format") { attribute :aggregate, String }
  end

  aggregate "DomainInspector", "Formats domain IR for terminal display" do
    command("InspectDomain") { attribute :domain_name, String }
  end

  # --- Import Paragraph ---

  aggregate "DomainAssembler", "Combines schema and model data into Hecks DSL source" do
    command("Assemble") { attribute :schema_data, String; attribute :model_data, String }
  end

  aggregate "ModelParser", "Parses Rails model files via Prism AST for associations and validations" do
    command("Parse") { attribute :models_dir, String }
  end

  aggregate "ModelOnlyAssembler", "Builds Hecks DSL from model files without schema.rb" do
    command("Assemble") { attribute :model_data, String }
  end

  aggregate "SchemaParser", "Evaluates Rails schema.rb in sandbox to capture table structure" do
    command("Parse") { attribute :schema_path, String }
  end

  aggregate "SchemaSandbox", "Sandboxed receiver for create_table calls during schema eval" do
    command("CreateTable") { attribute :name, String }
  end

  aggregate "ColumnCollector", "Captures column definitions from schema table blocks" do
    command("Collect") { attribute :type, String; attribute :name, String }
  end

  aggregate "PrismHelpers", "Prism AST node accessors shared by model parser extractors" do
    command("Extract") { attribute :call_node, String }
  end

  # --- Internals Paragraph ---

  aggregate "VersionLogFormatter", "Formats version history with change summaries between snapshots" do
    command("Format") { attribute :entries, String }
  end

  aggregate "Steps", "Step definitions for the guided architecture tour" do
    command("BuildSteps") { attribute :domain_name, String }
  end

  aggregate "SinatraAppGenerator", "Generates Sinatra app scaffold from domain IR" do
    command("Generate") { attribute :domain_path, String }
  end

  aggregate "Interviewer", "Interactive domain definition wizard" do
    command("Interview") { attribute :domain_name, String }
  end

  aggregate "WorldConcernsPrompt", "Prompts user for world concerns during init" do
    command("Prompt") { attribute :domain_name, String }
  end

  aggregate "Cli", "Thor-based command-line interface entry point" do
    command("Start") { attribute :argv, String }
  end

  aggregate "ArchitectureTour", "Guided walkthrough of a domain" do
    command("RunTour") { attribute :domain_name, String }
  end

  aggregate "Import", "Reverse-engineers Rails apps into Hecks domain definitions" do
    command("FromRails") { attribute :app_path, String }
  end

  # --- Tools Paragraph ---

  aggregate "DomainStats", "Aggregate/command/event/policy counts" do
    command("Calculate") { attribute :domain, String }
  end

  aggregate "ProjectStats", "Project-wide metrics across all domains" do
    command("Calculate") { attribute :project_path, String }
  end

  aggregate "ImportPipeline", "Rails model import: parse, assemble, generate" do
    command("ParseModels") { attribute :source_path, String }
    command("ParseSchemas") { attribute :schema_path, String }
    command("AssembleDomain") { attribute :models, String }
  end

  aggregate "StubGenerator", "Generates test stub files for a domain" do
    command("Generate") { attribute :domain_name, String }
  end

  aggregate "DomainHelpers", "Shared helpers for CLI domain loading" do
    command("LoadDomain") { attribute :domain_path, String }
  end

  aggregate "GemBuilder", "Builds and installs Hecks component gems" do
    command("Build") { attribute :root, String }
  end

  aggregate "DomainIntrospector", "Analyzes cross-domain connections and extension wiring" do
    command("Introspect") { attribute :domains, String }
  end

  aggregate "ConflictHandler", "Handles file conflicts during generation" do
    command("Resolve") { attribute :file_path, String }
  end
end
