<div class="header-row">
  <h1><%= aggregate_name %>s (<%= items.size %>)</h1>
  <div>
    <% buttons.each do |btn| %>
      <a class="btn<%= ' btn-faded' unless btn[:allowed] %>" href="<%= btn[:href] %>"><%= btn[:label] %></a>
    <% end %>
  </div>
</div>
<% if defined?(description) && description && !description.empty? %>
  <p style="color:#666;margin:-1rem 0 1.5rem"><%= description %></p>
<% end %>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <% columns.each do |col| %>
        <th><%= col[:label] %></th>
      <% end %>
      <% if row_actions.any? %>
        <th>Actions</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% items.each do |item| %>
      <tr>
        <td class="mono"><a href="<%= item[:show_href] %>"><%= item[:short_id] %></a></td>
        <% item[:cells].each do |cell| %>
          <td><%= h(cell) %></td>
        <% end %>
        <% if row_actions.any? %>
          <td>
            <% row_actions.each do |action| %>
              <% if action[:direct] %>
                <form class="inline" method="post" action="<%= action[:href_prefix] %>">
                  <input type="hidden" name="<%= action[:id_field] %>" value="<%= item[:id] %>">
                  <button class="btn btn-sm<%= ' btn-faded' unless action[:allowed] %>" type="submit"><%= action[:label] %></button>
                </form>
              <% else %>
                <a class="btn btn-sm<%= ' btn-faded' unless action[:allowed] %>"
                   href="<%= action[:href_prefix] %><%= item[:id] %>"><%= action[:label] %></a>
              <% end %>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
